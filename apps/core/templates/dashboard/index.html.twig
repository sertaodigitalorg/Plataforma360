{# Generated by GitHub Copilot #}
{% extends 'base.html.twig' %}

{% block title %}Dashboard | Olinda 360{% endblock %}

{% block stylesheets %}
    <style>
        .dashboard-hero {
            background: linear-gradient(135deg, #0b3c5d 0%, #13678a 48%, #eff7fb 100%);
            border-radius: 1.5rem;
            color: #fff;
            overflow: hidden;
            position: relative;
        }

        .dashboard-hero::after {
            background: radial-gradient(circle at top right, rgba(255, 255, 255, 0.3), transparent 42%);
            content: '';
            inset: 0;
            position: absolute;
        }

        .dashboard-hero__content,
        .dashboard-glass-card {
            position: relative;
            z-index: 1;
        }

        .dashboard-glass-card {
            backdrop-filter: blur(10px);
            background: rgba(255, 255, 255, 0.12);
            border: 1px solid rgba(255, 255, 255, 0.22);
            box-shadow: 0 1rem 2rem rgba(11, 60, 93, 0.12);
        }

        .dashboard-section-card,
        .dashboard-surface-card,
        .dashboard-stat-card,
        .dashboard-footer-card {
            background: #fff;
            border: 1px solid rgba(11, 60, 93, 0.08);
            border-radius: 1.5rem;
            box-shadow: 0 1rem 2rem rgba(11, 60, 93, 0.06);
            transition: transform 0.2s ease, box-shadow 0.2s ease, border-color 0.2s ease;
        }

        .dashboard-surface-card:hover,
        .dashboard-stat-card:hover,
        .dashboard-footer-card:hover {
            border-color: rgba(19, 103, 138, 0.18);
            box-shadow: 0 1.5rem 2.5rem rgba(11, 60, 93, 0.1);
            transform: translateY(-4px);
        }

        .dashboard-stat-card__value {
            color: #0b3c5d;
            font-size: clamp(1.75rem, 3vw, 2.5rem);
            font-weight: 700;
        }

        .dashboard-stat-card__icon,
        .dashboard-section-icon,
        .dashboard-architecture-icon,
        .dashboard-indicator-icon {
            align-items: center;
            background: #eef5f8;
            border-radius: 1rem;
            color: #0b3c5d;
            display: inline-flex;
            font-size: 1.35rem;
            height: 3rem;
            justify-content: center;
            width: 3rem;
        }

        .dashboard-stat-card--teal .dashboard-stat-card__icon,
        .dashboard-stat-card--teal .dashboard-stat-card__value { color: #0f766e; }
        .dashboard-stat-card--blue .dashboard-stat-card__icon,
        .dashboard-stat-card--blue .dashboard-stat-card__value { color: #13678a; }
        .dashboard-stat-card--amber .dashboard-stat-card__icon,
        .dashboard-stat-card--amber .dashboard-stat-card__value { color: #b7791f; }
        .dashboard-stat-card--cyan .dashboard-stat-card__icon,
        .dashboard-stat-card--cyan .dashboard-stat-card__value { color: #0e7490; }
        .dashboard-stat-card--emerald .dashboard-stat-card__icon,
        .dashboard-stat-card--emerald .dashboard-stat-card__value { color: #15803d; }
        .dashboard-stat-card--slate .dashboard-stat-card__icon,
        .dashboard-stat-card--slate .dashboard-stat-card__value { color: #475569; }
        .dashboard-stat-card--purple .dashboard-stat-card__icon,
        .dashboard-stat-card--purple .dashboard-stat-card__value { color: #7c3aed; }
        .dashboard-stat-card--rose .dashboard-stat-card__icon,
        .dashboard-stat-card--rose .dashboard-stat-card__value { color: #be185d; }

        .dashboard-status {
            border-radius: 999px;
            display: inline-flex;
            font-size: 0.8rem;
            font-weight: 600;
            padding: 0.35rem 0.75rem;
        }

        .dashboard-status--success {
            background: rgba(25, 135, 84, 0.12);
            color: #146c43;
        }

        .dashboard-status--warning {
            background: rgba(255, 193, 7, 0.18);
            color: #997404;
        }

        .dashboard-status--pending {
            background: rgba(108, 117, 125, 0.14);
            color: #495057;
        }

        .dashboard-status--info,
        .dashboard-status--primary {
            background: rgba(13, 110, 253, 0.12);
            color: #0a58ca;
        }

        .dashboard-status-indicator {
            border-radius: 50%;
            display: inline-block;
            height: 0.9rem;
            width: 0.9rem;
        }

        .dashboard-status-indicator--success { background: #198754; }
        .dashboard-status-indicator--warning { background: #ffc107; }
        .dashboard-status-indicator--pending { background: #6c757d; }
        .dashboard-status-indicator--info,
        .dashboard-status-indicator--primary { background: #0d6efd; }

        .dashboard-indicator-grid,
        .dashboard-architecture-grid {
            display: grid;
            gap: 1rem;
        }

        .dashboard-indicator-grid {
            grid-template-columns: repeat(auto-fit, minmax(220px, 1fr));
        }

        .dashboard-architecture-grid {
            grid-template-columns: repeat(auto-fit, minmax(180px, 1fr));
        }

        .dashboard-architecture-step {
            position: relative;
        }

        .dashboard-architecture-step::after {
            color: rgba(19, 103, 138, 0.35);
            content: '→';
            font-size: 1.5rem;
            position: absolute;
            right: -0.8rem;
            top: 50%;
            transform: translateY(-50%);
        }

        .dashboard-architecture-step:last-child::after {
            content: '';
        }

        .dashboard-action-button {
            align-items: center;
            display: inline-flex;
            gap: 0.5rem;
        }

        .dashboard-footer-card {
            background: linear-gradient(135deg, #0b3c5d 0%, #0f4f76 100%);
            color: #fff;
        }

        .dashboard-section-card a:focus-visible,
        .dashboard-surface-card a:focus-visible,
        .dashboard-action-button:focus-visible {
            outline: 3px solid #ffbf47;
            outline-offset: 2px;
        }

        @media (max-width: 1199.98px) {
            .dashboard-architecture-step::after {
                content: '↓';
                left: 50%;
                right: auto;
                top: auto;
                bottom: -1rem;
                transform: translateX(-50%);
            }
        }
    </style>
{% endblock %}

{% block body %}
    <section class="py-4 py-lg-5" aria-labelledby="dashboard-title">
        {% include 'dashboard/_hero_dashboard.html.twig' with {hero: hero} only %}
        {% include 'dashboard/_stats_cards.html.twig' with {statsCards: statsCards} only %}

        <div class="row g-4 mb-4">
            <div class="col-lg-8">
                <div class="dashboard-section-card p-4 h-100">
                    <div class="d-flex justify-content-between align-items-start gap-3 flex-wrap mb-4">
                        <div>
                            <span class="badge rounded-pill text-bg-light text-primary mb-2">Infraestrutura Digital</span>
                            <h2 class="h3 mb-1">Ecossistema operacional da plataforma</h2>
                            <p class="text-secondary mb-0">Módulos institucionais alinhados para observabilidade, dados abertos, governança e inteligência territorial.</p>
                        </div>
                    </div>
                    {% include 'dashboard/_infrastructure_cards.html.twig' with {infrastructureCards: infrastructureCards} only %}
                </div>
            </div>
            <div class="col-lg-4">
                <div class="dashboard-section-card p-4 h-100">
                    <span class="badge rounded-pill text-bg-light text-primary mb-2">Ações Rápidas</span>
                    <h2 class="h3 mb-3">Orquestração imediata</h2>
                    <p class="text-secondary mb-4">Atalhos para rotinas críticas, interfaces públicas, exportação e operação executiva.</p>
                    {% include 'dashboard/_quick_actions.html.twig' with {quickActions: quickActions} only %}
                </div>
            </div>
        </div>

        <div class="dashboard-section-card p-4 mb-4">
            <div class="d-flex justify-content-between align-items-start gap-3 flex-wrap mb-4">
                <div>
                    <span class="badge rounded-pill text-bg-light text-primary mb-2">Fontes Estratégicas</span>
                    <h2 class="h3 mb-1">Matriz de dados monitorados</h2>
                    <p class="text-secondary mb-0">Fontes estruturantes para turismo inteligente, dados abertos e inteligência governamental.</p>
                </div>
            </div>
            {% include 'dashboard/_sources_cards.html.twig' with {sourcesCards: sourcesCards} only %}
        </div>

        <div class="row g-4 mb-4">
            <div class="col-lg-7">
                <div class="dashboard-section-card p-4 h-100">
                    <span class="badge rounded-pill text-bg-light text-primary mb-2">Indicadores Operacionais</span>
                    <h2 class="h3 mb-3">Pulse da infraestrutura digital</h2>
                    <div class="dashboard-indicator-grid">
                        {% for indicator in operationalIndicators %}
                            <article class="dashboard-surface-card p-4 h-100">
                                <div class="d-flex justify-content-between gap-3 mb-3">
                                    <div>
                                        <p class="text-muted text-uppercase small fw-semibold mb-2">{{ indicator.label }}</p>
                                        <p class="dashboard-stat-card__value mb-1">{{ indicator.value }}</p>
                                    </div>
                                    <div class="dashboard-indicator-icon">
                                        <twig:ux:icon name="{{ indicator.icon }}" />
                                    </div>
                                </div>
                                <p class="text-secondary mb-0 small">{{ indicator.detail }}</p>
                            </article>
                        {% endfor %}
                    </div>
                </div>
            </div>
            <div class="col-lg-5">
                <div class="dashboard-section-card p-4 h-100">
                    <span class="badge rounded-pill text-bg-light text-primary mb-2">Central GovTech</span>
                    <h2 class="h3 mb-3">Visão executiva</h2>
                    <p class="text-secondary mb-4">O Dashboard consolida observabilidade, governança e inteligência operacional para uma plataforma de turismo inteligente orientada por dados.</p>
                    <div class="dashboard-surface-card p-4 mb-3">
                        <p class="text-muted text-uppercase small fw-semibold mb-2">Cobertura analítica</p>
                        <p class="dashboard-stat-card__value mb-1">{{ hero.sourcesMonitored }}</p>
                        <p class="text-secondary mb-0 small">Fontes estratégicas prontas para expansão e integração contínua.</p>
                    </div>
                    <div class="dashboard-surface-card p-4">
                        <p class="text-muted text-uppercase small fw-semibold mb-2">APIs abertas e internas</p>
                        <p class="dashboard-stat-card__value mb-1">{{ stats.publicApis + 1 }}</p>
                        <p class="text-secondary mb-0 small">Camadas digitais sustentando transparência, operação e interoperabilidade.</p>
                    </div>
                </div>
            </div>
        </div>

        <div class="dashboard-section-card p-4 mb-4">
            <span class="badge rounded-pill text-bg-light text-primary mb-2">Arquitetura da Plataforma</span>
            <h2 class="h3 mb-3">Fluxo de inteligência territorial</h2>
            <p class="text-secondary mb-4">Pipeline institucional da coleta à visualização executiva, concebido para turismo inteligente, rastreabilidade e cidades orientadas por dados.</p>
            <div class="dashboard-architecture-grid">
                {% for step in architectureSteps %}
                    <article class="dashboard-surface-card dashboard-architecture-step p-4 h-100">
                        <div class="dashboard-architecture-icon mb-3">
                            <twig:ux:icon name="{{ step.icon }}" />
                        </div>
                        <h3 class="h5 mb-2">{{ step.title }}</h3>
                        <p class="text-secondary mb-0 small">{{ step.description }}</p>
                    </article>
                {% endfor %}
            </div>
        </div>

        <div class="dashboard-footer-card p-4 p-lg-5">
            <h2 class="h4 mb-2">Olinda360 — Plataforma de Governança e Inteligência Turística</h2>
            <p class="mb-0 text-white-50">Infraestrutura digital de dados abertos para turismo inteligente, governança territorial e cidades inteligentes.</p>
        </div>
    </section>
{% endblock %}
