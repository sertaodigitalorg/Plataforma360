{# Generated by GitHub Copilot #}
<div class="d-flex flex-wrap gap-2" aria-label="Ações rápidas do dashboard">
    {% for action in quickActions %}
        {% set href = action.path is defined ? path(action.path) : action.url %}
        <a class="btn btn-{{ action.variant }} dashboard-action-button" href="{{ href }}">
            <twig:ux:icon name="{{ action.icon }}" />
            <span>{{ action.label }}</span>
        </a>
    {% endfor %}
</div>