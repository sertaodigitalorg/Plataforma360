{# Generated by GitHub Copilot #}
<div class="row g-3" aria-label="Fontes estratégicas monitoradas">
    {% for source in sourcesCards %}
        <div class="col-12 col-md-6 col-xl-4">
            <article class="dashboard-surface-card h-100 p-4">
                <div class="d-flex justify-content-between align-items-start gap-3 mb-3">
                    <div class="d-flex align-items-center gap-3">
                        <div class="dashboard-section-icon">
                            <twig:ux:icon name="{{ source.icon }}" />
                        </div>
                        <div>
                            <h3 class="h5 mb-1">{{ source.name }}</h3>
                            <p class="text-secondary small mb-0">{{ source.type }}</p>
                        </div>
                    </div>
                    <span class="dashboard-status dashboard-status--{{ source.statusTone }}">{{ source.status }}</span>
                </div>
                <div class="d-flex justify-content-between align-items-end gap-3">
                    <div>
                        <span class="text-muted text-uppercase small fw-semibold d-block mb-1">Última atualização</span>
                        <span class="text-secondary">{{ source.updatedAt }}</span>
                    </div>
                    <span class="dashboard-status-indicator dashboard-status-indicator--{{ source.statusTone }}"></span>
                </div>
            </article>
        </div>
    {% endfor %}
</div>