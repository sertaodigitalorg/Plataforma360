{# Generated by GitHub Copilot #}
<div class="row g-3" aria-label="Infraestrutura digital da plataforma">
    {% for item in infrastructureCards %}
        <div class="col-12 col-md-6 col-xl-4">
            <article class="dashboard-surface-card h-100 p-4">
                <div class="d-flex justify-content-between align-items-start gap-3 mb-3">
                    <div class="dashboard-section-icon">
                        <twig:ux:icon name="{{ item.icon }}" />
                    </div>
                    <a class="btn btn-sm btn-outline-primary" href="{{ path(item.actionPath) }}">{{ item.actionLabel }}</a>
                </div>
                <h3 class="h5 mb-2">{{ item.title }}</h3>
                <p class="text-secondary mb-0">{{ item.description }}</p>
            </article>
        </div>
    {% endfor %}
</div>