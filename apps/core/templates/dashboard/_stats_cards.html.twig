{# Generated by GitHub Copilot #}
<div class="row g-3 mb-4" aria-label="Indicadores estratégicos do dashboard">
    {% for card in statsCards %}
        <div class="col-12 col-md-6 col-xl-3">
            <article class="dashboard-stat-card dashboard-stat-card--{{ card.tone }} h-100 p-4">
                <div class="d-flex justify-content-between align-items-start gap-3 mb-3">
                    <div>
                        <p class="text-muted text-uppercase small fw-semibold mb-2">{{ card.title }}</p>
                        <p class="dashboard-stat-card__value mb-1">{{ card.value }}</p>
                        <p class="mb-0 text-secondary small">{{ card.subtitle }}</p>
                    </div>
                    <div class="dashboard-stat-card__icon">
                        <twig:ux:icon name="{{ card.icon }}" />
                    </div>
                </div>
                <p class="mb-0 text-secondary small">{{ card.description }}</p>
            </article>
        </div>
    {% endfor %}
</div>