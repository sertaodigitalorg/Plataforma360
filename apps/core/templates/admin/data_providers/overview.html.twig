{# Generated by GitHub Copilot #}
{% extends 'base.html.twig' %}

{% block title %}Visão Geral – Ingestão Pública | Plataforma360{% endblock %}

{% block stylesheets %}
    {{ parent() }}
    {% include 'admin/data_providers/_styles.html.twig' %}
{% endblock %}

{% block body %}
    <section class="py-4 py-lg-5" aria-labelledby="overview-title">
        <div class="container">
            {% include 'default/_flash_messages.html.twig' %}

            <div class="data-management-hero p-4 p-lg-5 mb-4">
                <div class="row g-4 align-items-end">
                    <div class="col-lg-8">
                        <span class="badge rounded-pill text-bg-light text-primary mb-3">Ingestão Pública</span>
                        <h1 id="overview-title" class="display-6 fw-bold mb-3">Visão Geral</h1>
                        <p class="lead mb-0">Painel executivo da ingestão pública via API CKAN — provedores, pacotes monitorados, pipeline operacional e arquivos RAW.</p>
                    </div>
                    <div class="col-lg-4">
                        <div class="provider-hero-note p-4 h-100">
                            <p class="text-uppercase small fw-semibold mb-2">Provedores ativos</p>
                            <p class="fs-2 fw-bold mb-1">{{ summary.activeProviders }} / {{ summary.totalProviders }}</p>
                            <p class="mb-0">Conectores aptos para sincronização imediata.</p>
                        </div>
                    </div>
                </div>
            </div>

            {# Summary cards #}
            <div class="row g-3 mb-4">
                <div class="col-12 col-md-6 col-xl-3">
                    <article class="provider-summary-card h-100 p-4">
                        <p class="text-muted text-uppercase small fw-semibold mb-2">Pacotes CKAN</p>
                        <p class="provider-summary-card__value mb-1">{{ summary.totalPackages }}</p>
                        <p class="mb-0 text-secondary small">Inventário total sincronizado.</p>
                    </article>
                </div>
                <div class="col-12 col-md-6 col-xl-3">
                    <article class="provider-summary-card h-100 p-4">
                        <p class="text-muted text-uppercase small fw-semibold mb-2">Monitorados</p>
                        <p class="provider-summary-card__value mb-1">{{ summary.monitoredPackages }}</p>
                        <p class="mb-0 text-secondary small">Selecionados para automação diária.</p>
                    </article>
                </div>
                <div class="col-12 col-md-6 col-xl-3">
                    <article class="provider-summary-card h-100 p-4">
                        <p class="text-muted text-uppercase small fw-semibold mb-2">Arquivos RAW</p>
                        <p class="provider-summary-card__value mb-1">{{ summary.totalRawFiles }}</p>
                        <p class="mb-0 text-secondary small">Baixados no storage local.</p>
                    </article>
                </div>
                <div class="col-12 col-md-6 col-xl-3">
                    <article class="provider-summary-card h-100 p-4">
                        <p class="text-muted text-uppercase small fw-semibold mb-2">Previewáveis</p>
                        <p class="provider-summary-card__value mb-1">{{ summary.previewableFiles }}</p>
                        <p class="mb-0 text-secondary small">Arquivos CSV/XLSX com preview disponível.</p>
                    </article>
                </div>
            </div>

            {# Status counts #}
            {% if statusCounts is not empty %}
                <div class="row g-3 mb-4">
                    {% for status, count in statusCounts %}
                        {% set presentation = statusPresentation[status] ?? {label: status, tone: 'secondary'} %}
                        <div class="col-6 col-md-4 col-xl-2">
                            <article class="provider-summary-card h-100 p-3 text-center">
                                <p class="mb-1">
                                    <span class="badge bg-{{ presentation.tone }} rounded-pill px-3">{{ presentation.label }}</span>
                                </p>
                                <p class="provider-summary-card__value mb-0">{{ count }}</p>
                            </article>
                        </div>
                    {% endfor %}
                </div>
            {% endif %}

            {# Quick navigation #}
            <div class="row g-3 mb-4">
                <div class="col-12">
                    <h2 class="h5 fw-semibold mb-3">Acesso rápido</h2>
                </div>
                <div class="col-12 col-sm-6 col-lg-4">
                    <a href="{{ path('app_admin_data_providers') }}" class="provider-summary-card d-block p-4 text-decoration-none h-100">
                        <div class="d-flex align-items-start gap-3">
                            <i class="bi bi-cloud-arrow-down fs-4 text-primary flex-shrink-0"></i>
                            <div>
                                <p class="fw-semibold mb-1">Provedores de Dados</p>
                                <p class="text-muted small mb-0">Cadastro de provedores CKAN e sincronização institucional.</p>
                            </div>
                        </div>
                    </a>
                </div>
                <div class="col-12 col-sm-6 col-lg-4">
                    <a href="{{ path('app_admin_provider_packages') }}" class="provider-summary-card d-block p-4 text-decoration-none h-100">
                        <div class="d-flex align-items-start gap-3">
                            <i class="bi bi-boxes fs-4 text-primary flex-shrink-0"></i>
                            <div>
                                <p class="fw-semibold mb-1">Pacotes CKAN</p>
                                <p class="text-muted small mb-0">Inventário de pacotes sincronizados para monitoramento.</p>
                            </div>
                        </div>
                    </a>
                </div>
                <div class="col-12 col-sm-6 col-lg-4">
                    <a href="{{ path('app_admin_ingestion_runs') }}" class="provider-summary-card d-block p-4 text-decoration-none h-100">
                        <div class="d-flex align-items-start gap-3">
                            <i class="bi bi-database-fill-gear fs-4 text-primary flex-shrink-0"></i>
                            <div>
                                <p class="fw-semibold mb-1">Ingestão de Dados</p>
                                <p class="text-muted small mb-0">Downloads, preview e preparação para orquestração.</p>
                            </div>
                        </div>
                    </a>
                </div>
                <div class="col-12 col-sm-6 col-lg-4">
                    <a href="{{ path('app_admin_raw_files') }}" class="provider-summary-card d-block p-4 text-decoration-none h-100">
                        <div class="d-flex align-items-start gap-3">
                            <i class="bi bi-folder-symlink fs-4 text-primary flex-shrink-0"></i>
                            <div>
                                <p class="fw-semibold mb-1">Arquivos RAW</p>
                                <p class="text-muted small mb-0">Inventário de arquivos físicos no storage local.</p>
                            </div>
                        </div>
                    </a>
                </div>
                <div class="col-12 col-sm-6 col-lg-4">
                    <a href="{{ path('app_admin_dataset_previews') }}" class="provider-summary-card d-block p-4 text-decoration-none h-100">
                        <div class="d-flex align-items-start gap-3">
                            <i class="bi bi-table fs-4 text-primary flex-shrink-0"></i>
                            <div>
                                <p class="fw-semibold mb-1">Preview Dataset</p>
                                <p class="text-muted small mb-0">Visualização tabular das primeiras linhas dos arquivos.</p>
                            </div>
                        </div>
                    </a>
                </div>
                <div class="col-12 col-sm-6 col-lg-4">
                    <a href="{{ path('app_admin_ingestion_history') }}" class="provider-summary-card d-block p-4 text-decoration-none h-100">
                        <div class="d-flex align-items-start gap-3">
                            <i class="bi bi-journal-text fs-4 text-primary flex-shrink-0"></i>
                            <div>
                                <p class="fw-semibold mb-1">Histórico de Execuções</p>
                                <p class="text-muted small mb-0">Trilha operacional das sincronizações CKAN realizadas.</p>
                            </div>
                        </div>
                    </a>
                </div>
            </div>

            {# Recent runs #}
            {% if recentRuns is not empty %}
                <div class="card border-0 shadow-sm rounded-4">
                    <div class="card-header bg-white border-0 pt-4 pb-0 px-4">
                        <div class="d-flex align-items-center justify-content-between">
                            <h2 class="h6 fw-semibold mb-0">Execuções recentes</h2>
                            <a href="{{ path('app_admin_ingestion_runs') }}" class="btn btn-sm btn-outline-secondary">Ver todas</a>
                        </div>
                    </div>
                    <div class="card-body p-0">
                        <div class="table-responsive">
                            <table class="table table-hover mb-0">
                                <thead class="table-light">
                                    <tr>
                                        <th class="ps-4">Provedor</th>
                                        <th>Status</th>
                                        <th>Pacotes</th>
                                        <th class="pe-4">Iniciado em</th>
                                    </tr>
                                </thead>
                                <tbody>
                                    {% for run in recentRuns %}
                                        {% set presentation = statusPresentation[run.status] ?? {label: run.status, tone: 'secondary'} %}
                                        <tr>
                                            <td class="ps-4">{{ run.dataProvider.name }}</td>
                                            <td>
                                                <span class="badge bg-{{ presentation.tone }} rounded-pill px-3">{{ presentation.label }}</span>
                                            </td>
                                            <td>{{ run.packagesSynced ?? '—' }}</td>
                                            <td class="pe-4 text-muted small">
                                                {% if run.startedAt %}
                                                    {{ run.startedAt|date('d/m/Y H:i') }}
                                                {% else %}
                                                    —
                                                {% endif %}
                                            </td>
                                        </tr>
                                    {% endfor %}
                                </tbody>
                            </table>
                        </div>
                    </div>
                </div>
            {% endif %}
        </div>
    </section>
{% endblock %}
