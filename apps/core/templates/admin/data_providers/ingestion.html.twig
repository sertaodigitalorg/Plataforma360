{# Generated by GitHub Copilot #}
{% extends 'base.html.twig' %}

{% block title %}Ingestão de Dados | Plataforma360{% endblock %}

{% block stylesheets %}
    {{ parent() }}
    {% include 'admin/data_providers/_styles.html.twig' %}
{% endblock %}

{% block body %}
    <section class="py-4 py-lg-5" aria-labelledby="ingestion-title">
        <div class="container">
            {% include 'default/_flash_messages.html.twig' %}

            <div class="data-management-hero p-4 p-lg-5 mb-4">
                <div class="row g-4 align-items-end">
                    <div class="col-lg-8">
                        <span class="badge rounded-pill text-bg-light text-primary mb-3">Preparação de Pipeline</span>
                        <h1 id="ingestion-title" class="display-6 fw-bold mb-3">Ingestão de Dados</h1>
                        <p class="lead mb-0">Painel operacional para acompanhar downloads CKAN, storage RAW, preview de datasets e descoberta de schema, já desacoplado para orquestração futura.</p>
                    </div>
                    <div class="col-lg-4">
                        <div class="provider-hero-note p-4 h-100">
                            <p class="text-uppercase small fw-semibold mb-2">Provedores disponíveis</p>
                            <p class="fs-2 fw-bold mb-1">{{ providers|length }}</p>
                            <p class="mb-0">Base pronta para acoplamento com jobs de automação e trilha operacional.</p>
                        </div>
                    </div>
                </div>
            </div>

            <div class="row g-3 mb-4">
                <div class="col-12 col-md-6 col-xl-3">
                    <article class="provider-summary-card h-100 p-4">
                        <p class="text-muted text-uppercase small fw-semibold mb-2">Execuções recentes</p>
                        <p class="provider-summary-card__value mb-1">{{ summary.totalRuns }}</p>
                        <p class="mb-0 text-secondary small">Eventos persistidos na trilha de ingestão.</p>
                    </article>
                </div>
                <div class="col-12 col-md-6 col-xl-3">
                    <article class="provider-summary-card h-100 p-4">
                        <p class="text-muted text-uppercase small fw-semibold mb-2">Em execução</p>
                        <p class="provider-summary-card__value mb-1">{{ summary.running }}</p>
                        <p class="mb-0 text-secondary small">Jobs ativos neste momento.</p>
                    </article>
                </div>
                <div class="col-12 col-md-6 col-xl-3">
                    <article class="provider-summary-card h-100 p-4">
                        <p class="text-muted text-uppercase small fw-semibold mb-2">Concluídas</p>
                        <p class="provider-summary-card__value mb-1">{{ summary.success }}</p>
                        <p class="mb-0 text-secondary small">Fluxos encerrados com sucesso.</p>
                    </article>
                </div>
                <div class="col-12 col-md-6 col-xl-3">
                    <article class="provider-summary-card h-100 p-4">
                        <p class="text-muted text-uppercase small fw-semibold mb-2">Falhas</p>
                        <p class="provider-summary-card__value mb-1">{{ summary.failed }}</p>
                        <p class="mb-0 text-secondary small">Ocorrências prontas para auditoria e retry futuro.</p>
                    </article>
                </div>
            </div>

            <div class="row g-4 mb-4">
                <div class="col-lg-5">
                    <div class="data-management-panel p-4 h-100">
                        <span class="badge rounded-pill text-bg-light text-primary mb-2">Roadmap operacional</span>
                        <h2 class="h4 mb-3">Pronto para a próxima etapa</h2>
                        <div class="provider-inline-list">
                            <article>
                                <p>1. Verificação diária</p>
                                <p>Rodina futura iterará sobre pacotes monitorados.</p>
                            </article>
                            <article>
                                <p>2. Novo resource</p>
                                <p>Comparação entre metadata atual e resources já persistidos.</p>
                            </article>
                            <article>
                                <p>3. Download e preview</p>
                                <p>Arquivos seguem para o RAW com parser CSV/XLSX e schema inferido.</p>
                            </article>
                            <article>
                                <p>4. Kestra</p>
                                <p>Jobs futuros poderão substituir a execução síncrona atual sem alterar a camada de domínio.</p>
                            </article>
                        </div>
                    </div>
                </div>
                <div class="col-lg-7">
                    <div class="data-management-table-card p-3 p-lg-4 h-100">
                        <div class="d-flex justify-content-between align-items-start gap-3 flex-wrap mb-3">
                            <div>
                                <h2 class="h4 mb-1">Últimas execuções</h2>
                                <p class="text-secondary mb-0">Histórico recente das sincronizações disparadas pela interface administrativa.</p>
                            </div>
                            <a class="btn btn-outline-primary" href="{{ path('app_admin_ingestion_history') }}">Ver histórico completo</a>
                        </div>

                        <div class="table-responsive">
                            <table class="table align-middle mb-0">
                                <thead>
                                    <tr>
                                        <th>Status</th>
                                        <th>Provedor</th>
                                        <th>Pacote</th>
                                        <th>Início</th>
                                        <th>Fim</th>
                                        <th>Mensagem</th>
                                        <th>Eventos</th>
                                    </tr>
                                </thead>
                                <tbody>
                                    {% for run in runs %}
                                        {% set meta = statusPresentation[run.status] ?? statusPresentation.pending %}
                                        <tr>
                                            <td><span class="provider-soft-badge provider-soft-badge--{{ meta.tone }}">{{ meta.label }}</span></td>
                                            <td>{{ run.dataProvider.name }}</td>
                                            <td>{{ run.providerPackage ? run.providerPackage.packageId : 'Sincronização de lista' }}</td>
                                            <td>{{ run.startedAt ? run.startedAt|date('d/m/Y H:i') : 'N/D' }}</td>
                                            <td>{{ run.finishedAt ? run.finishedAt|date('d/m/Y H:i') : 'Em aberto' }}</td>
                                            <td class="text-secondary">{{ run.message ?: 'Sem mensagem' }}</td>
                                            <td>
                                                <div class="d-flex gap-1 flex-wrap">
                                                    {% for log in run.logs|reverse|slice(0, 2) %}
                                                        <span class="provider-soft-badge provider-soft-badge--secondary">{{ log.event ?? 'evento' }}</span>
                                                    {% else %}
                                                        <span class="text-secondary">Sem eventos</span>
                                                    {% endfor %}
                                                </div>
                                            </td>
                                        </tr>
                                    {% else %}
                                        <tr>
                                            <td colspan="7" class="text-center py-5 text-secondary">Nenhuma execução registrada ainda.</td>
                                        </tr>
                                    {% endfor %}
                                </tbody>
                            </table>
                        </div>
                    </div>
                </div>
            </div>
        </div>
    </section>
{% endblock %}