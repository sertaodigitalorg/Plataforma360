{# Generated by GitHub Copilot #}
{% extends 'base.html.twig' %}

{% block title %}Pacotes CKAN | Plataforma360{% endblock %}

{% block stylesheets %}
    {{ parent() }}
    {% include 'admin/data_providers/_styles.html.twig' %}
{% endblock %}

{% block body %}
    <section class="py-4 py-lg-5" aria-labelledby="provider-packages-title">
        <div class="container">
            {% include 'default/_flash_messages.html.twig' %}

            <div class="data-management-hero p-4 p-lg-5 mb-4">
                <div class="d-flex justify-content-between align-items-start gap-3 flex-wrap">
                    <div>
                        <span class="badge rounded-pill text-bg-light text-primary mb-3">Inventário CKAN</span>
                        <h1 id="provider-packages-title" class="display-6 fw-bold mb-3">{{ provider ? 'Pacotes do provedor ' ~ provider.name : 'Pacotes CKAN sincronizados' }}</h1>
                        <p class="lead mb-0">Selecione os pacotes que devem entrar no monitoramento automatizado e consulte seus detalhes sob demanda via package_show.</p>
                    </div>
                    <div class="d-flex gap-2 flex-wrap">
                        {% if provider %}
                            <a class="btn btn-light" href="{{ path('app_admin_data_providers') }}">Voltar aos provedores</a>
                            <form method="post" action="{{ path('app_admin_data_providers_sync', {id: provider.id}) }}">
                                <button type="submit" class="btn btn-primary">Sincronizar pacotes</button>
                            </form>
                        {% else %}
                            <a class="btn btn-light" href="{{ path('app_admin_data_providers') }}">Provedores de Dados</a>
                            <a class="btn btn-primary" href="{{ path('app_admin_ingestion_runs') }}">Ingestão de Dados</a>
                        {% endif %}
                    </div>
                </div>
            </div>

            <div class="data-management-table-card p-3 p-lg-4">
                <div class="table-responsive">
                    <table class="table align-middle mb-0">
                        <thead>
                            <tr>
                                {% if not provider %}<th>Provedor</th>{% endif %}
                                <th>Package ID</th>
                                <th>Título</th>
                                <th>Descrição</th>
                                <th>Status</th>
                                <th>Automação</th>
                                <th>Última verificação</th>
                                <th class="text-end">Ações</th>
                            </tr>
                        </thead>
                        <tbody>
                            {% for package in packages %}
                                <tr>
                                    {% if not provider %}
                                        <td>
                                            <a href="{{ path('app_admin_data_providers_packages', {id: package.dataProvider.id}) }}">{{ package.dataProvider.name }}</a>
                                        </td>
                                    {% endif %}
                                    <td>
                                        <div class="fw-semibold">{{ package.packageId }}</div>
                                        <div class="small text-secondary">ID interno #{{ package.id }}</div>
                                    </td>
                                    <td>{{ package.title ?: 'Título ainda não sincronizado' }}</td>
                                    <td class="text-secondary">{{ package.description ? (package.description|length > 100 ? package.description|slice(0, 100) ~ '...' : package.description) : 'Descrição não disponível.' }}</td>
                                    <td>
                                        <span class="provider-soft-badge {{ package.isActive ? 'provider-soft-badge--success' : 'provider-soft-badge--secondary' }}">
                                            {{ package.isActive ? 'Ativo' : 'Inativo' }}
                                        </span>
                                    </td>
                                    <td>
                                        <span class="provider-soft-badge {{ package.isMonitored ? 'provider-soft-badge--warning' : 'provider-soft-badge--secondary' }}">
                                            {{ package.isMonitored ? 'Monitorado' : 'Não monitorado' }}
                                        </span>
                                    </td>
                                    <td>
                                        {% if package.lastCheckedAt %}
                                            {{ package.lastCheckedAt|date('d/m/Y H:i') }}
                                        {% else %}
                                            <span class="text-secondary">Ainda não verificado</span>
                                        {% endif %}
                                    </td>
                                    <td>
                                        <div class="d-flex justify-content-end gap-2 flex-wrap">
                                            <a class="btn btn-sm btn-outline-primary" href="{{ path('app_admin_provider_package_show', {id: package.id}) }}">Ver detalhes</a>
                                            <a class="btn btn-sm btn-outline-secondary" href="{{ path('app_admin_provider_package_show', {id: package.id}) }}#resources">Ver recursos</a>
                                            {% if package.isMonitored %}
                                                <form method="post" action="{{ path('app_admin_provider_package_monitor_off', {id: package.id}) }}">
                                                    <button type="submit" class="btn btn-sm btn-outline-danger">Desativar monitoramento</button>
                                                </form>
                                            {% else %}
                                                <form method="post" action="{{ path('app_admin_provider_package_monitor_on', {id: package.id}) }}">
                                                    <button type="submit" class="btn btn-sm btn-primary">Ativar monitoramento</button>
                                                </form>
                                            {% endif %}
                                        </div>
                                    </td>
                                </tr>
                            {% else %}
                                <tr>
                                    <td colspan="{{ provider ? 7 : 8 }}" class="text-center py-5 text-secondary">Nenhum pacote sincronizado ainda. Execute a sincronização do provedor para preencher esta listagem.</td>
                                </tr>
                            {% endfor %}
                        </tbody>
                    </table>
                </div>
            </div>
        </div>
    </section>
{% endblock %}