{# Generated by GitHub Copilot #}
{% extends 'base.html.twig' %}

{% block title %}{{ package.displayTitle }} | Pacote CKAN{% endblock %}

{% block stylesheets %}
    {{ parent() }}
    {% include 'admin/data_providers/_styles.html.twig' %}
{% endblock %}

{% block body %}
    <section class="py-4 py-lg-5" aria-labelledby="provider-package-title">
        <div class="container">
            {% include 'default/_flash_messages.html.twig' %}

            <div class="data-management-hero p-4 p-lg-5 mb-4">
                <div class="d-flex justify-content-between align-items-start gap-3 flex-wrap">
                    <div>
                        <span class="badge rounded-pill text-bg-light text-primary mb-3">Package Show</span>
                        <h1 id="provider-package-title" class="display-6 fw-bold mb-3">{{ package.displayTitle }}</h1>
                        <p class="lead mb-0">Metadados atualizados em tempo real via CKAN, com resources prontos para download físico, preview de dataset e descoberta de schema.</p>
                    </div>
                    <div class="d-flex gap-2 flex-wrap">
                        <a class="btn btn-light" href="{{ path('app_admin_data_providers_packages', {id: package.dataProvider.id}) }}">Voltar aos pacotes</a>
                        <form method="post" action="{{ path('app_admin_provider_package_pipeline', {id: package.id}) }}">
                            <button type="submit" class="btn btn-primary">Executar pipeline</button>
                        </form>
                        <a class="btn btn-outline-light" href="{{ package.dataProvider.baseUrl }}" target="_blank" rel="noreferrer">Abrir portal</a>
                    </div>
                </div>
            </div>

            <div class="row g-4 mb-4">
                <div class="col-lg-8">
                    <div class="data-management-panel p-4 h-100">
                        <span class="badge rounded-pill text-bg-light text-primary mb-2">Metadados básicos</span>
                        <h2 class="h4 mb-3">Resumo do pacote</h2>
                        <dl class="data-management-detail-grid mb-0">
                            <div class="data-management-detail-item">
                                <dt>Provedor</dt>
                                <dd>{{ package.dataProvider.name }}</dd>
                            </div>
                            <div class="data-management-detail-item">
                                <dt>Package ID</dt>
                                <dd>{{ package.packageId }}</dd>
                            </div>
                            <div class="data-management-detail-item">
                                <dt>Status</dt>
                                <dd>{{ metadata.state ?: (package.isActive ? 'active' : 'inactive') }}</dd>
                            </div>
                            <div class="data-management-detail-item">
                                <dt>Monitoramento</dt>
                                <dd>{{ package.isMonitored ? 'Ativado' : 'Desativado' }}</dd>
                            </div>
                            <div class="data-management-detail-item">
                                <dt>Última verificação</dt>
                                <dd>{{ package.lastCheckedAt ? package.lastCheckedAt|date('d/m/Y H:i') : 'Ainda não verificado' }}</dd>
                            </div>
                            <div class="data-management-detail-item">
                                <dt>Endpoint consultado</dt>
                                <dd>{{ package.dataProvider.getPackageShowUrl(package.packageId) }}</dd>
                            </div>
                        </dl>
                    </div>
                </div>
                <div class="col-lg-4">
                    <div class="data-management-panel p-4 h-100">
                        <span class="badge rounded-pill text-bg-light text-primary mb-2">Descrição</span>
                        <h2 class="h4 mb-3">Contexto institucional</h2>
                        <p class="text-secondary mb-3">{{ package.description ?: metadata.notes ?: metadata.description ?: 'O provedor não retornou descrição detalhada para este pacote.' }}</p>
                        <div class="provider-inline-list">
                            <article>
                                <p>Organização</p>
                                <p>{{ metadata.organization.title ?? metadata.organization.name ?? 'Não informado' }}</p>
                            </article>
                            <article>
                                <p>Licença</p>
                                <p>{{ metadata.license_title ?? metadata.license_id ?? 'Não informada' }}</p>
                            </article>
                            <article>
                                <p>Atualização CKAN</p>
                                <p>{{ metadata.metadata_modified ?? metadata.revision_timestamp ?? 'Não informada' }}</p>
                            </article>
                            <article>
                                <p>Tags</p>
                                <p>
                                    {% if metadata.tags is defined and metadata.tags is iterable %}
                                        {{ metadata.tags|map(tag => tag.display_name ?? tag.name ?? '')|filter(v => v)|join(', ') ?: 'Sem tags' }}
                                    {% else %}
                                        Sem tags
                                    {% endif %}
                                </p>
                            </article>
                        </div>
                    </div>
                </div>
            </div>

            <div id="resources" class="data-management-table-card p-3 p-lg-4">
                <div class="d-flex justify-content-between align-items-start gap-3 flex-wrap mb-3">
                    <div>
                        <h2 class="h4 mb-1">Resources disponíveis</h2>
                        <p class="text-secondary mb-0">Arquivos e endpoints retornados pelo package_show, já persistidos para futuras rotinas de download e pipeline.</p>
                    </div>
                    <div>
                        <span class="provider-soft-badge provider-soft-badge--info">{{ resources|length }} resource(s)</span>
                    </div>
                </div>

                <div class="table-responsive">
                    <table class="table align-middle mb-0">
                        <thead>
                            <tr>
                                <th>Resource ID</th>
                                <th>Nome</th>
                                <th>Formato</th>
                                <th>URL</th>
                                <th>Criado</th>
                                <th>Última modificação</th>
                                <th>Tamanho</th>
                                <th>Download</th>
                                <th class="text-end">Ações</th>
                            </tr>
                        </thead>
                        <tbody>
                            {% for resource in resources %}
                                {% set rawFile = resource.latestRawFile %}
                                <tr>
                                    <td>{{ resource.resourceId }}</td>
                                    <td>{{ resource.name ?: 'Sem nome' }}</td>
                                    <td>{{ resource.format ?: 'N/D' }}</td>
                                    <td>
                                        <a class="provider-resource-url d-inline-block" href="{{ resource.url }}" target="_blank" rel="noreferrer">{{ resource.url }}</a>
                                    </td>
                                    <td>{{ resource.createdAtSource ? resource.createdAtSource|date('d/m/Y H:i') : 'N/D' }}</td>
                                    <td>{{ resource.lastModifiedSource ? resource.lastModifiedSource|date('d/m/Y H:i') : 'N/D' }}</td>
                                    <td>{{ resource.size is not null ? resource.size|number_format(0, ',', '.') ~ ' bytes' : 'N/D' }}</td>
                                    <td>
                                        {% if rawFile %}
                                            <div class="fw-semibold {{ rawFile.downloadStatus == constant('App\\Entity\\Data\\RawFile::STATUS_DUPLICATE') ? 'text-warning' : 'text-success' }}">{{ rawFile.downloadStatus == constant('App\\Entity\\Data\\RawFile::STATUS_DUPLICATE') ? 'Duplicado por hash' : 'Baixado' }}</div>
                                            <div class="small text-secondary">{{ rawFile.downloadedAt ? rawFile.downloadedAt|date('d/m/Y H:i') : 'N/D' }}</div>
                                            <div class="small text-secondary raw-file-path">{{ rawFile.localPath }}</div>
                                        {% else %}
                                            <span class="text-secondary">Ainda não baixado</span>
                                        {% endif %}
                                    </td>
                                    <td>
                                        <div class="d-flex justify-content-end gap-2 flex-wrap">
                                            <form method="post" action="{{ path('app_admin_dataset_resource_pipeline', {id: resource.id}) }}">
                                                <button type="submit" class="btn btn-sm btn-primary">Executar pipeline</button>
                                            </form>
                                            <form method="post" action="{{ path('app_admin_dataset_resource_download', {id: resource.id}) }}">
                                                <button type="submit" class="btn btn-sm btn-outline-primary">Baixar resource</button>
                                            </form>
                                            {% if rawFile and rawFile.extension in ['csv', 'xlsx'] %}
                                                <a class="btn btn-sm btn-outline-secondary" href="{{ path('app_admin_dataset_preview_show', {id: rawFile.id}) }}">Preview</a>
                                            {% endif %}
                                            {% if rawFile %}
                                                <a class="btn btn-sm btn-outline-secondary" href="{{ path('app_admin_raw_files_metadata', {id: rawFile.id}) }}">Metadata</a>
                                            {% endif %}
                                            <a class="btn btn-sm btn-outline-secondary" href="{{ resource.url }}" target="_blank" rel="noreferrer">Abrir origem</a>
                                        </div>
                                    </td>
                                </tr>
                            {% else %}
                                <tr>
                                    <td colspan="9" class="text-center py-5 text-secondary">Nenhum resource retornado para este pacote.</td>
                                </tr>
                            {% endfor %}
                        </tbody>
                    </table>
                </div>
            </div>
        </div>
    </section>
{% endblock %}