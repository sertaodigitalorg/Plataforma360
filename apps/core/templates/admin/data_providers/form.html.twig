{# Generated by GitHub Copilot #}
{% extends 'base.html.twig' %}

{% block title %}{{ isEdit ? 'Editar Provedor de Dados' : 'Novo Provedor de Dados' }} | Plataforma360{% endblock %}

{% block stylesheets %}
    {{ parent() }}
    {% include 'admin/data_providers/_styles.html.twig' %}
{% endblock %}

{% block body %}
    <section class="py-4 py-lg-5">
        <div class="container">
            {% include 'default/_flash_messages.html.twig' %}

            <div class="data-management-hero p-4 p-lg-5 mb-4">
                <div class="d-flex justify-content-between align-items-start gap-3 flex-wrap">
                    <div>
                        <span class="badge rounded-pill text-bg-light text-primary mb-3">Cadastro CKAN</span>
                        <h1 class="display-6 fw-bold mb-3">{{ isEdit ? 'Editar provedor de dados' : 'Novo provedor de dados' }}</h1>
                        <p class="lead mb-0">Configure os endpoints de package_list e package_show para ingestão automatizada de datasets públicos via CKAN.</p>
                    </div>
                    <div class="d-flex gap-2 flex-wrap">
                        <a class="btn btn-light" href="{{ path('app_admin_data_providers') }}">Voltar à listagem</a>
                        {% if isEdit %}
                            <a class="btn btn-outline-light" href="{{ path('app_admin_data_providers_packages', {id: provider.id}) }}">Ver pacotes</a>
                        {% endif %}
                    </div>
                </div>
            </div>

            <div class="row g-4">
                <div class="col-lg-8">
                    <div class="data-management-form-card data-management-panel p-4 h-100">
                        {{ form_start(form) }}
                            <div class="row g-3">
                                <div class="col-md-6">{{ form_row(form.name) }}</div>
                                <div class="col-md-6">{{ form_row(form.type) }}</div>
                                <div class="col-12">{{ form_row(form.baseUrl) }}</div>
                                <div class="col-md-6">{{ form_row(form.packageListPath) }}</div>
                                <div class="col-md-6">{{ form_row(form.packageShowPath) }}</div>
                                <div class="col-12">{{ form_row(form.notes) }}</div>
                                <div class="col-12">{{ form_row(form.isActive) }}</div>
                            </div>

                            <div class="d-flex gap-2 flex-wrap mt-4">
                                <button type="submit" class="btn btn-primary">Salvar provedor</button>
                                <a class="btn btn-outline-secondary" href="{{ path('app_admin_data_providers') }}">Cancelar</a>
                            </div>
                        {{ form_end(form) }}
                    </div>
                </div>

                <div class="col-lg-4">
                    <div class="data-management-panel p-4 h-100">
                        <span class="badge rounded-pill text-bg-light text-primary mb-2">Padrão recomendado</span>
                        <h2 class="h4 mb-3">Valores padrão CKAN</h2>
                        <div class="provider-inline-list">
                            <article>
                                <p>Package List</p>
                                <p>/api/3/action/package_list</p>
                            </article>
                            <article>
                                <p>Package Show</p>
                                <p>/api/3/action/package_show?id={package_id}</p>
                            </article>
                            <article>
                                <p>API exclusiva</p>
                                <p>Use apenas endpoints CKAN oficiais, sem scraping HTML.</p>
                            </article>
                            <article>
                                <p>Automação futura</p>
                                <p>O monitoramento de pacotes será a base da rotina diária integrada ao Kestra.</p>
                            </article>
                        </div>
                    </div>
                </div>
            </div>
        </div>
    </section>
{% endblock %}