{# Generated by GitHub Copilot #}
{% extends 'base.html.twig' %}

{% block title %}Histórico de Execuções | Plataforma360{% endblock %}

{% block stylesheets %}
    {{ parent() }}
    {% include 'admin/data_providers/_styles.html.twig' %}
{% endblock %}

{% block body %}
    <section class="py-4 py-lg-5" aria-labelledby="ingestion-history-title">
        <div class="container">
            {% include 'default/_flash_messages.html.twig' %}

            <div class="data-management-hero p-4 p-lg-5 mb-4">
                <div class="d-flex justify-content-between align-items-start gap-3 flex-wrap">
                    <div>
                        <span class="badge rounded-pill text-bg-light text-primary mb-3">Trilha Operacional</span>
                        <h1 id="ingestion-history-title" class="display-6 fw-bold mb-3">Histórico de Execuções</h1>
                        <p class="lead mb-0">Auditoria das sincronizações CKAN executadas pela interface, pronta para ser enriquecida por automações futuras.</p>
                    </div>
                    <div class="d-flex gap-2 flex-wrap">
                        <a class="btn btn-light" href="{{ path('app_admin_ingestion_runs') }}">Voltar à ingestão</a>
                        <a class="btn btn-outline-light" href="{{ path('app_admin_data_providers') }}">Provedores</a>
                    </div>
                </div>
            </div>

            <div class="data-management-table-card p-3 p-lg-4">
                <div class="table-responsive">
                    <table class="table align-middle mb-0">
                        <thead>
                            <tr>
                                <th>Status</th>
                                <th>Provedor</th>
                                <th>Pacote</th>
                                <th>Resource</th>
                                <th>Início</th>
                                <th>Fim</th>
                                <th>Mensagem</th>
                            </tr>
                        </thead>
                        <tbody>
                            {% for run in runs %}
                                {% set meta = statusPresentation[run.status] ?? statusPresentation.pending %}
                                <tr>
                                    <td><span class="provider-soft-badge provider-soft-badge--{{ meta.tone }}">{{ meta.label }}</span></td>
                                    <td>{{ run.dataProvider.name }}</td>
                                    <td>{{ run.providerPackage ? run.providerPackage.packageId : 'Sincronização de lista' }}</td>
                                    <td>{{ run.datasetResource ? run.datasetResource.resourceId : 'N/D' }}</td>
                                    <td>{{ run.startedAt ? run.startedAt|date('d/m/Y H:i') : 'N/D' }}</td>
                                    <td>{{ run.finishedAt ? run.finishedAt|date('d/m/Y H:i') : 'Em aberto' }}</td>
                                    <td class="text-secondary">{{ run.message ?: 'Sem mensagem' }}</td>
                                </tr>
                            {% else %}
                                <tr>
                                    <td colspan="7" class="text-center py-5 text-secondary">Ainda não há execuções registradas.</td>
                                </tr>
                            {% endfor %}
                        </tbody>
                    </table>
                </div>
            </div>
        </div>
    </section>
{% endblock %}