{# Generated by GitHub Copilot #}
{% extends 'base.html.twig' %}

{% block title %}Provedores de Dados | Plataforma360{% endblock %}

{% block stylesheets %}
    {{ parent() }}
    {% include 'admin/data_providers/_styles.html.twig' %}
{% endblock %}

{% block body %}
    <section class="py-4 py-lg-5" aria-labelledby="providers-title">
        <div class="container">
            {% include 'default/_flash_messages.html.twig' %}

            <div class="data-management-hero p-4 p-lg-5 mb-4">
                <div class="row g-4 align-items-end">
                    <div class="col-lg-8">
                        <span class="badge rounded-pill text-bg-light text-primary mb-3">Dados Abertos via CKAN</span>
                        <h1 id="providers-title" class="display-6 fw-bold mb-3">Provedores de Dados</h1>
                        <p class="lead mb-3">Catálogo institucional de provedores CKAN para sincronização de pacotes, monitoramento seletivo e preparação da esteira futura com storage RAW e Kestra.</p>
                        <p class="mb-0 opacity-75">A camada opera exclusivamente pela API CKAN, sem scraping, com foco em rastreabilidade, governança e automação progressiva.</p>
                    </div>
                    <div class="col-lg-4">
                        <div class="provider-hero-note p-4 h-100">
                            <p class="text-uppercase small fw-semibold mb-2">Próxima etapa preparada</p>
                            <p class="mb-2">Verificação diária de pacotes monitorados, detecção de novos resources, armazenamento RAW e disparo de pipeline Kestra.</p>
                            <div class="d-flex flex-wrap gap-2">
                                <a class="btn btn-light" href="{{ path('app_admin_data_providers_new') }}">Novo provedor</a>
                                <a class="btn btn-outline-light" href="{{ path('app_admin_ingestion_runs') }}">Ver ingestão</a>
                            </div>
                        </div>
                    </div>
                </div>
            </div>

            <div class="row g-3 mb-4" aria-label="Resumo de provedores CKAN">
                <div class="col-12 col-md-6 col-xl-3">
                    <article class="provider-summary-card h-100 p-4">
                        <p class="text-muted text-uppercase small fw-semibold mb-2">Total de provedores</p>
                        <p class="provider-summary-card__value mb-1">{{ summary.totalProviders }}</p>
                        <p class="mb-0 text-secondary small">Fontes cadastradas para ingestão pública.</p>
                    </article>
                </div>
                <div class="col-12 col-md-6 col-xl-3">
                    <article class="provider-summary-card h-100 p-4">
                        <p class="text-muted text-uppercase small fw-semibold mb-2">Provedores ativos</p>
                        <p class="provider-summary-card__value mb-1">{{ summary.activeProviders }}</p>
                        <p class="mb-0 text-secondary small">Conectores aptos para sincronização imediata.</p>
                    </article>
                </div>
                <div class="col-12 col-md-6 col-xl-3">
                    <article class="provider-summary-card h-100 p-4">
                        <p class="text-muted text-uppercase small fw-semibold mb-2">Pacotes sincronizados</p>
                        <p class="provider-summary-card__value mb-1">{{ summary.syncedPackages }}</p>
                        <p class="mb-0 text-secondary small">Inventário persistido a partir de package_list.</p>
                    </article>
                </div>
                <div class="col-12 col-md-6 col-xl-3">
                    <article class="provider-summary-card h-100 p-4">
                        <p class="text-muted text-uppercase small fw-semibold mb-2">Pacotes monitorados</p>
                        <p class="provider-summary-card__value mb-1">{{ summary.monitoredPackages }}</p>
                        <p class="mb-0 text-secondary small">Selecionados para automação futura diária.</p>
                    </article>
                </div>
            </div>

            <div class="data-management-table-card p-3 p-lg-4 mb-4">
                <div class="d-flex justify-content-between align-items-start gap-3 flex-wrap mb-3">
                    <div>
                        <h2 class="h4 mb-1">Catálogo de provedores</h2>
                        <p class="text-secondary mb-0">Cadastre endpoints CKAN, sincronize a lista de pacotes e acompanhe a prontidão operacional do módulo.</p>
                    </div>
                    <div class="d-flex gap-2 flex-wrap">
                        <a class="btn btn-outline-primary" href="{{ path('app_admin_provider_packages') }}">Pacotes CKAN</a>
                        <a class="btn btn-primary" href="{{ path('app_admin_data_providers_new') }}">Cadastrar provedor</a>
                    </div>
                </div>

                <div class="table-responsive">
                    <table class="table align-middle mb-0">
                        <thead>
                            <tr>
                                <th>Nome do provedor</th>
                                <th>Tipo</th>
                                <th>Base URL</th>
                                <th>Status</th>
                                <th>Última sincronização</th>
                                <th class="text-end">Ações</th>
                            </tr>
                        </thead>
                        <tbody>
                            {% for provider in providers %}
                                <tr>
                                    <td>
                                        <div class="fw-semibold">{{ provider.name }}</div>
                                        {% if provider.notes %}
                                            <div class="small text-secondary">{{ provider.notes|length > 90 ? provider.notes|slice(0, 90) ~ '...' : provider.notes }}</div>
                                        {% endif %}
                                    </td>
                                    <td><span class="provider-soft-badge provider-soft-badge--info">{{ provider.type }}</span></td>
                                    <td>
                                        <a href="{{ provider.baseUrl }}" target="_blank" rel="noreferrer">{{ provider.baseUrl }}</a>
                                        <div class="small text-secondary">{{ provider.packageListPath }}</div>
                                    </td>
                                    <td>
                                        <span class="provider-soft-badge {{ provider.isActive ? 'provider-soft-badge--success' : 'provider-soft-badge--danger' }}">
                                            {{ provider.isActive ? 'Ativo' : 'Inativo' }}
                                        </span>
                                    </td>
                                    <td>
                                        {% if provider.lastSyncedAt %}
                                            {{ provider.lastSyncedAt|date('d/m/Y H:i') }}
                                        {% else %}
                                            <span class="text-secondary">Ainda não sincronizado</span>
                                        {% endif %}
                                    </td>
                                    <td>
                                        <div class="d-flex justify-content-end gap-2 flex-wrap">
                                            <a class="btn btn-sm btn-outline-primary" href="{{ path('app_admin_data_providers_packages', {id: provider.id}) }}">Ver pacotes</a>
                                            <a class="btn btn-sm btn-outline-secondary" href="{{ path('app_admin_data_providers_edit', {id: provider.id}) }}">Editar</a>
                                            <form method="post" action="{{ path('app_admin_data_providers_sync', {id: provider.id}) }}">
                                                <button type="submit" class="btn btn-sm btn-primary">Sincronizar pacotes</button>
                                            </form>
                                        </div>
                                    </td>
                                </tr>
                            {% else %}
                                <tr>
                                    <td colspan="6" class="text-center py-5 text-secondary">Nenhum provedor cadastrado ainda.</td>
                                </tr>
                            {% endfor %}
                        </tbody>
                    </table>
                </div>
            </div>

            <div class="row g-4">
                <div class="col-lg-8">
                    <div class="data-management-panel p-4 h-100">
                        <span class="badge rounded-pill text-bg-light text-primary mb-2">Arquitetura preparada</span>
                        <h2 class="h3 mb-3">Fluxo de ingestão pública pronto para expansão</h2>
                        <div class="provider-inline-list">
                            <article>
                                <p>Verificação diária</p>
                                <p>Os pacotes monitorados já possuem persistência própria para execução programada futura.</p>
                            </article>
                            <article>
                                <p>Detecção de resources</p>
                                <p>Os detalhes do pacote já sincronizam a lista de arquivos e metadados técnicos do CKAN.</p>
                            </article>
                            <article>
                                <p>Storage RAW</p>
                                <p>A camada de resources e runs deixa o caminho aberto para salvar artefatos em RAW sem redesenhar o domínio.</p>
                            </article>
                            <article>
                                <p>Kestra</p>
                                <p>O histórico de execuções já delimita o ponto de integração para disparo de pipeline orquestrada.</p>
                            </article>
                        </div>
                    </div>
                </div>
                <div class="col-lg-4">
                    <div class="data-management-panel p-4 h-100">
                        <span class="badge rounded-pill text-bg-light text-primary mb-2">Navegação</span>
                        <h2 class="h3 mb-3">Acessos diretos</h2>
                        <div class="d-grid gap-2">
                            <a class="btn btn-outline-primary text-start" href="{{ path('app_admin_data_management') }}">Visão Geral</a>
                            <a class="btn btn-outline-primary text-start" href="{{ path('app_admin_provider_packages') }}">Pacotes CKAN</a>
                            <a class="btn btn-outline-primary text-start" href="{{ path('app_admin_ingestion_runs') }}">Ingestão de Dados</a>
                            <a class="btn btn-outline-primary text-start" href="{{ path('app_admin_ingestion_history') }}">Histórico de Execuções</a>
                        </div>
                    </div>
                </div>
            </div>
        </div>
    </section>
{% endblock %}