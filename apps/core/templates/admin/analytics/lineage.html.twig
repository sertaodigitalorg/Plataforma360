{# Generated by GitHub Copilot #}
{% extends 'base.html.twig' %}

{% block title %}Linhagem de Dados · Plataforma360{% endblock %}

{% block main %}
<div class="mb-4">
    <nav aria-label="breadcrumb">
        <ol class="breadcrumb small mb-1">
            <li class="breadcrumb-item"><a href="{{ path('app_admin_warehouse_overview') }}" class="text-decoration-none">Warehouse</a></li>
            <li class="breadcrumb-item active">Linhagem de Dados</li>
        </ol>
    </nav>
    <h1 class="h3 fw-bold mb-1" style="color:#0b3c5d;">Linhagem de Dados</h1>
    <p class="text-muted mb-0">Visualização do fluxo completo dos dados desde a ingestão até os dashboards.</p>
</div>

{# Lineage Flow #}
<div class="card border-0 rounded-4 shadow-sm mb-4">
    <div class="card-body p-4 p-lg-5">
        <div class="d-flex align-items-center justify-content-center flex-wrap gap-2">
            {% set steps = [
                {key: 'ckan', label: 'CKAN', icon: 'cloud-download', desc: 'Provedores de dados públicos', color: 'teal'},
                {key: 'raw', label: 'RAW', icon: 'folder-symlink', desc: 'Arquivos físicos baixados', color: 'blue'},
                {key: 'staging', label: 'STAGING', icon: 'layers', desc: 'Dados normalizados', color: 'amber'},
                {key: 'warehouse', label: 'WAREHOUSE', icon: 'database-fill', desc: 'Tabelas analíticas', color: 'emerald'},
                {key: 'indicators', label: 'INDICADORES', icon: 'graph-up-arrow', desc: 'KPIs executivos', color: 'purple'},
                {key: 'dashboards', label: 'DASHBOARDS', icon: 'bar-chart-line', desc: 'Metabase & BI', color: 'rose'},
            ] %}

            {% for i, step in steps %}
                <div class="text-center" style="min-width:9rem;">
                    <div class="rounded-4 p-3 mb-2 d-inline-flex align-items-center justify-content-center"
                         style="width:3.5rem;height:3.5rem;background:{% if step.color == 'teal' %}linear-gradient(135deg,#eff7fb,#e4f7f4){% elseif step.color == 'blue' %}linear-gradient(135deg,#eff6ff,#dbeafe){% elseif step.color == 'amber' %}linear-gradient(135deg,#fefce8,#fef9c3){% elseif step.color == 'emerald' %}linear-gradient(135deg,#f0fdf4,#dcfce7){% elseif step.color == 'purple' %}linear-gradient(135deg,#fdf4ff,#fae8ff){% else %}linear-gradient(135deg,#fff1f2,#ffe4e6){% endif %};">
                        <i class="bi bi-{{ step.icon }} fs-5" style="color:{% if step.color == 'teal' %}#0f766e{% elseif step.color == 'blue' %}#2563eb{% elseif step.color == 'amber' %}#ca8a04{% elseif step.color == 'emerald' %}#16a34a{% elseif step.color == 'purple' %}#9333ea{% else %}#e11d48{% endif %};"></i>
                    </div>
                    <div class="fw-bold small mb-1" style="color:#0b3c5d;">{{ step.label }}</div>
                    <div class="text-muted" style="font-size:0.73rem;">{{ step.desc }}</div>
                </div>
                {% if not loop.last %}
                    <div class="text-muted" style="font-size:1.4rem;margin-bottom:2.5rem;">→</div>
                {% endif %}
            {% endfor %}
        </div>
    </div>
</div>

<div class="row g-4">
    {# Staging Tables #}
    <div class="col-md-4">
        <div class="card border-0 rounded-4 shadow-sm h-100">
            <div class="card-header bg-white border-0 rounded-top-4 pt-4 px-4 pb-2">
                <h6 class="fw-bold mb-0" style="color:#0b3c5d;"><i class="bi bi-layers me-2 text-warning"></i>Staging</h6>
            </div>
            <div class="card-body px-4 pb-4">
                {% if stagingTables is empty %}
                    <p class="text-muted small">Nenhuma tabela staging detectada.</p>
                {% else %}
                    {% for t in stagingTables %}
                        <div class="d-flex align-items-center gap-2 mb-2">
                            <i class="bi bi-table text-warning small"></i>
                            <code class="small">{{ t }}</code>
                        </div>
                    {% endfor %}
                {% endif %}
            </div>
        </div>
    </div>

    {# Warehouse Tables #}
    <div class="col-md-4">
        <div class="card border-0 rounded-4 shadow-sm h-100">
            <div class="card-header bg-white border-0 rounded-top-4 pt-4 px-4 pb-2">
                <h6 class="fw-bold mb-0" style="color:#0b3c5d;"><i class="bi bi-database-fill me-2 text-success"></i>Warehouse</h6>
            </div>
            <div class="card-body px-4 pb-4">
                {% if warehouseTables is empty %}
                    <p class="text-muted small">Nenhuma tabela no warehouse ainda.</p>
                {% else %}
                    {% for t in warehouseTables %}
                        <div class="d-flex align-items-center gap-2 mb-2">
                            <i class="bi bi-table text-success small"></i>
                            <code class="small">{{ t.name }}</code>
                        </div>
                    {% endfor %}
                {% endif %}
            </div>
        </div>
    </div>

    {# Models #}
    <div class="col-md-4">
        <div class="card border-0 rounded-4 shadow-sm h-100">
            <div class="card-header bg-white border-0 rounded-top-4 pt-4 px-4 pb-2">
                <h6 class="fw-bold mb-0" style="color:#0b3c5d;"><i class="bi bi-gear-wide-connected me-2 text-primary"></i>Modelos Ativos</h6>
            </div>
            <div class="card-body px-4 pb-4">
                {% if models is empty %}
                    <p class="text-muted small">Nenhum modelo analítico ativo.</p>
                {% else %}
                    {% for m in models %}
                        <div class="mb-3 pb-2 border-bottom">
                            <div class="fw-semibold small" style="color:#0b3c5d;">{{ m.name }}</div>
                            <div class="text-muted" style="font-size:0.75rem;">
                                <code>{{ m.sourceTable }}</code> → <code>{{ m.targetTable }}</code>
                            </div>
                        </div>
                    {% endfor %}
                {% endif %}
            </div>
        </div>
    </div>
</div>

{# Recent History #}
<div class="card border-0 rounded-4 shadow-sm mt-4">
    <div class="card-header bg-white border-0 rounded-top-4 pt-4 px-4 pb-2">
        <h5 class="fw-bold mb-0" style="color:#0b3c5d;"><i class="bi bi-clock-history me-2 text-secondary"></i>Histórico Analítico</h5>
    </div>
    <div class="card-body p-0">
        {% if recentHistory is empty %}
            <p class="text-muted text-center py-4">Nenhum evento registrado ainda.</p>
        {% else %}
            <div class="table-responsive">
                <table class="table table-sm table-hover align-middle mb-0">
                    <thead><tr class="text-muted small" style="background:#f8fafc;">
                        <th class="px-4 py-3">Evento</th>
                        <th>Assunto</th>
                        <th>Status</th>
                        <th>Linhas</th>
                        <th>Duração</th>
                        <th>Data</th>
                    </tr></thead>
                    <tbody>
                    {% for h in recentHistory %}
                        <tr>
                            <td class="px-4 py-3">
                                <span class="badge text-bg-light text-dark rounded-pill">{{ h.eventType|replace({'_': ' '})|capitalize }}</span>
                            </td>
                            <td class="text-muted small">{{ h.subject }}</td>
                            <td>
                                {% if h.status == 'success' %}
                                    <span class="badge text-bg-success rounded-pill">Sucesso</span>
                                {% elseif h.status == 'failed' %}
                                    <span class="badge text-bg-danger rounded-pill">Falhou</span>
                                {% elseif h.status == 'warning' %}
                                    <span class="badge text-bg-warning text-dark rounded-pill">Alerta</span>
                                {% else %}
                                    <span class="badge text-bg-secondary rounded-pill">{{ h.status }}</span>
                                {% endif %}
                            </td>
                            <td class="text-muted small">{{ h.rowsAffected is not null ? h.rowsAffected|number_format(0,',','.') : '—' }}</td>
                            <td class="text-muted small">{{ h.durationMs is not null ? h.durationMs ~ 'ms' : '—' }}</td>
                            <td class="text-muted small">{{ h.createdAt|date('d/m H:i') }}</td>
                        </tr>
                    {% endfor %}
                    </tbody>
                </table>
            </div>
        {% endif %}
    </div>
</div>
{% endblock %}
