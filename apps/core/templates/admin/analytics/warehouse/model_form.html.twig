{# Generated by GitHub Copilot #}
{% extends 'base.html.twig' %}

{% block title %}{{ model ? 'Editar' : 'Novo' }} Modelo Analítico · Plataforma360{% endblock %}

{% block main %}
<div class="mb-4">
    <nav aria-label="breadcrumb">
        <ol class="breadcrumb small mb-1">
            <li class="breadcrumb-item"><a href="{{ path('app_admin_warehouse_overview') }}" class="text-decoration-none">Warehouse</a></li>
            <li class="breadcrumb-item"><a href="{{ path('app_admin_analytic_models') }}" class="text-decoration-none">Modelos Analíticos</a></li>
            <li class="breadcrumb-item active">{{ model ? 'Editar: ' ~ model.name : 'Novo Modelo' }}</li>
        </ol>
    </nav>
    <h1 class="h3 fw-bold mb-0" style="color:#0b3c5d;">{{ model ? 'Editar Modelo Analítico' : 'Novo Modelo Analítico' }}</h1>
</div>

<div class="row g-4">
    <div class="col-lg-8">
        <div class="card border-0 rounded-4 shadow-sm">
            <div class="card-body p-4">
                <form method="post">
                    <div class="row g-3">
                        <div class="col-12">
                            <label class="form-label fw-semibold small" for="name">Nome do Modelo <span class="text-danger">*</span></label>
                            <input type="text" class="form-control rounded-3" id="name" name="name" value="{{ model ? model.name : '' }}" required placeholder="Ex: Agências de Turismo por Estado">
                        </div>
                        <div class="col-12">
                            <label class="form-label fw-semibold small" for="description">Descrição</label>
                            <textarea class="form-control rounded-3" id="description" name="description" rows="2" placeholder="Descreva o objetivo deste modelo analítico">{{ model ? model.description : '' }}</textarea>
                        </div>
                        <div class="col-md-6">
                            <label class="form-label fw-semibold small" for="source_table">Tabela Origem (STAGING) <span class="text-danger">*</span></label>
                            {% if stagingTables is not empty %}
                                <select class="form-select rounded-3" id="source_table" name="source_table" required>
                                    <option value="">Selecione a tabela staging...</option>
                                    {% for t in stagingTables %}
                                        <option value="{{ t }}" {{ model and model.sourceTable == t ? 'selected' : '' }}>{{ t }}</option>
                                    {% endfor %}
                                </select>
                            {% else %}
                                <input type="text" class="form-control rounded-3" id="source_table" name="source_table"
                                       value="{{ model ? model.sourceTable : '' }}"
                                       required placeholder="Ex: staging_agencias_turismo">
                                <div class="form-text text-muted">Nenhuma tabela staging detectada automaticamente — informe o nome manualmente.</div>
                            {% endif %}
                        </div>
                        <div class="col-md-6">
                            <label class="form-label fw-semibold small" for="target_table">Tabela Destino (WAREHOUSE) <span class="text-danger">*</span></label>
                            <input type="text" class="form-control rounded-3" id="target_table" name="target_table"
                                   value="{{ model ? model.targetTable : 'warehouse.dw_' }}"
                                   required placeholder="Ex: warehouse.dw_agencias_turismo">
                            <div class="form-text">Prefixo recomendado: <code>warehouse.dw_</code></div>
                        </div>
                        <div class="col-md-6">
                            <label class="form-label fw-semibold small" for="dimensions">Dimensões (colunas separadas por vírgula)</label>
                            <input type="text" class="form-control rounded-3" id="dimensions" name="dimensions"
                                   value="{{ model ? model.dimensions|join(',') : '' }}"
                                   placeholder="estado,municipio,regiao">
                            <div class="form-text">Colunas de agrupamento. Deixe vazio para incluir todas.</div>
                        </div>
                        <div class="col-md-6">
                            <label class="form-label fw-semibold small" for="metrics">Métricas (colunas separadas por vírgula)</label>
                            <input type="text" class="form-control rounded-3" id="metrics" name="metrics"
                                   value="{{ model ? model.metrics|join(',') : '' }}"
                                   placeholder="total_agencias,media_receita">
                            <div class="form-text">Colunas numéricas para análise.</div>
                        </div>
                        <div class="col-md-6">
                            <label class="form-label fw-semibold small" for="refresh_strategy">Estratégia de Atualização</label>
                            <select class="form-select rounded-3" id="refresh_strategy" name="refresh_strategy">
                                {% for strategy in refreshStrategies %}
                                    <option value="{{ strategy }}" {{ model and model.refreshStrategy == strategy ? 'selected' : (strategy == 'manual' ? 'selected' : '') }}>
                                        {{ strategy|capitalize }}
                                    </option>
                                {% endfor %}
                            </select>
                        </div>
                        {% if model %}
                        <div class="col-md-6">
                            <label class="form-label fw-semibold small d-block">Status</label>
                            <div class="form-check form-switch mt-2">
                                <input class="form-check-input" type="checkbox" id="is_active" name="is_active" {{ model.active ? 'checked' : '' }}>
                                <label class="form-check-label" for="is_active">Modelo ativo</label>
                            </div>
                        </div>
                        {% endif %}
                    </div>

                    <div class="d-flex gap-2 mt-4">
                        <button type="submit" class="btn btn-primary rounded-3">
                            <i class="bi bi-check-lg me-1"></i> {{ model ? 'Salvar alterações' : 'Criar modelo' }}
                        </button>
                        <a href="{{ path('app_admin_analytic_models') }}" class="btn btn-outline-secondary rounded-3">Cancelar</a>
                    </div>
                </form>
            </div>
        </div>
    </div>

    <div class="col-lg-4">
        <div class="card border-0 rounded-4" style="background:linear-gradient(135deg,#eff7fb,#e4f7f4);">
            <div class="card-body p-4">
                <h6 class="fw-bold mb-3" style="color:#0b3c5d;"><i class="bi bi-info-circle me-2"></i>Como funciona</h6>
                <ol class="text-muted small ps-3 mb-0">
                    <li class="mb-2">Selecione a <strong>tabela staging</strong> como fonte de dados</li>
                    <li class="mb-2">Defina as <strong>dimensões</strong> (colunas de agrupamento como estado, município)</li>
                    <li class="mb-2">Defina as <strong>métricas</strong> (colunas numéricas para análise)</li>
                    <li class="mb-2">O sistema cria a <strong>tabela no warehouse</strong> com um SELECT</li>
                    <li>Execute clicando no botão <i class="bi bi-play-fill text-success"></i> na listagem</li>
                </ol>
            </div>
        </div>

        <div class="card border-0 rounded-4 mt-3" style="background:#fffbeb;">
            <div class="card-body p-4">
                <h6 class="fw-bold mb-2" style="color:#92400e;"><i class="bi bi-lightbulb me-2"></i>Exemplos de tabelas destino</h6>
                <ul class="text-muted small ps-3 mb-0">
                    <li><code>warehouse.dw_turismo_agencias</code></li>
                    <li><code>warehouse.fact_agencias_turismo</code></li>
                    <li><code>warehouse.dim_municipios</code></li>
                </ul>
            </div>
        </div>
    </div>
</div>
{% endblock %}
