{# Generated by GitHub Copilot #}
{% extends 'base.html.twig' %}

{% block title %}Warehouse · Data Warehouse · Plataforma360{% endblock %}

{% block main %}
<div class="data-management-hero p-4 p-lg-5 mb-4 rounded-4" style="background: linear-gradient(135deg, rgba(7,40,68,0.06) 0%, rgba(14,116,144,0.08) 100%); border: 1px solid rgba(14,116,144,0.12);">
    <div class="d-flex align-items-start gap-3 flex-wrap">
        <div class="flex-grow-1">
            <div class="d-flex align-items-center gap-2 mb-2">
                <span class="badge text-bg-primary rounded-pill px-3 py-2" style="font-size:0.72rem;letter-spacing:0.06em;">DATA WAREHOUSE · FASE 4</span>
                <span class="badge text-bg-success rounded-pill px-3 py-2" style="font-size:0.72rem;">Operacional</span>
            </div>
            <h1 class="h3 fw-bold mb-1" style="color:#0b3c5d;">Data Warehouse</h1>
            <p class="text-muted mb-0" style="max-width:62ch;">Camada analítica consolidada. Dados transformados do STAGING para tabelas otimizadas para BI, indicadores executivos e APIs analíticas.</p>
        </div>
        <div class="d-flex gap-2 flex-wrap">
            <a href="{{ path('app_admin_analytic_models_new') }}" class="btn btn-primary rounded-3">
                <i class="bi bi-plus-lg me-1"></i> Novo Modelo
            </a>
            <a href="{{ path('app_admin_data_lineage') }}" class="btn btn-outline-secondary rounded-3">
                <i class="bi bi-diagram-3 me-1"></i> Linhagem
            </a>
        </div>
    </div>
</div>

{# KPI Cards #}
<div class="row g-3 mb-4">
    <div class="col-6 col-md-3">
        <div class="card border-0 rounded-4 h-100" style="background:linear-gradient(135deg,#eff7fb,#e4f7f4);">
            <div class="card-body p-3">
                <div class="d-flex align-items-center gap-2 mb-2">
                    <span class="rounded-3 p-2" style="background:rgba(15,118,110,0.12);color:#0f766e;"><i class="bi bi-database-fill-gear fs-5"></i></span>
                    <span class="text-muted small">Modelos Ativos</span>
                </div>
                <div class="fw-bold fs-3" style="color:#0b3c5d;">{{ summary.activeModels }}</div>
                <div class="text-muted small">de {{ summary.totalModels }} cadastrados</div>
            </div>
        </div>
    </div>
    <div class="col-6 col-md-3">
        <div class="card border-0 rounded-4 h-100" style="background:linear-gradient(135deg,#f0fdf4,#dcfce7);">
            <div class="card-body p-3">
                <div class="d-flex align-items-center gap-2 mb-2">
                    <span class="rounded-3 p-2" style="background:rgba(22,163,74,0.12);color:#16a34a;"><i class="bi bi-check-circle-fill fs-5"></i></span>
                    <span class="text-muted small">Prontos</span>
                </div>
                <div class="fw-bold fs-3" style="color:#0b3c5d;">{{ summary.readyModels }}</div>
                <div class="text-muted small">modelos com dados</div>
            </div>
        </div>
    </div>
    <div class="col-6 col-md-3">
        <div class="card border-0 rounded-4 h-100" style="background:linear-gradient(135deg,#eff6ff,#dbeafe);">
            <div class="card-body p-3">
                <div class="d-flex align-items-center gap-2 mb-2">
                    <span class="rounded-3 p-2" style="background:rgba(37,99,235,0.12);color:#2563eb;"><i class="bi bi-table fs-5"></i></span>
                    <span class="text-muted small">Tabelas Warehouse</span>
                </div>
                <div class="fw-bold fs-3" style="color:#0b3c5d;">{{ summary.warehouseTables }}</div>
                <div class="text-muted small">no schema warehouse</div>
            </div>
        </div>
    </div>
    <div class="col-6 col-md-3">
        <div class="card border-0 rounded-4 h-100" style="background:linear-gradient(135deg,#fefce8,#fef9c3);">
            <div class="card-body p-3">
                <div class="d-flex align-items-center gap-2 mb-2">
                    <span class="rounded-3 p-2" style="background:rgba(202,138,4,0.12);color:#ca8a04;"><i class="bi bi-rows fs-5"></i></span>
                    <span class="text-muted small">Linhas Totais</span>
                </div>
                <div class="fw-bold fs-3" style="color:#0b3c5d;">{{ summary.totalRows|number_format(0, ',', '.') }}</div>
                <div class="text-muted small">registros consolidados</div>
            </div>
        </div>
    </div>
</div>

<div class="row g-4">
    {# Warehouse Tables #}
    <div class="col-lg-7">
        <div class="card border-0 rounded-4 shadow-sm h-100">
            <div class="card-header bg-white border-0 rounded-top-4 pt-4 px-4 pb-2">
                <div class="d-flex align-items-center justify-content-between">
                    <h5 class="fw-bold mb-0" style="color:#0b3c5d;"><i class="bi bi-stack me-2 text-primary"></i>Tabelas no Warehouse</h5>
                    <span class="badge text-bg-secondary rounded-pill">schema: warehouse</span>
                </div>
            </div>
            <div class="card-body px-4 pb-4">
                {% if warehouseTables is empty %}
                    <div class="text-center py-5">
                        <i class="bi bi-database-x fs-1 text-muted"></i>
                        <p class="text-muted mt-3 mb-0">Nenhuma tabela no warehouse ainda.<br>Execute um modelo analítico para popular o warehouse.</p>
                    </div>
                {% else %}
                    <div class="table-responsive">
                        <table class="table table-sm table-hover align-middle">
                            <thead><tr class="text-muted small"><th>Tabela</th><th>Colunas</th><th>Tamanho</th></tr></thead>
                            <tbody>
                            {% for t in warehouseTables %}
                                <tr>
                                    <td><code class="small">{{ t.name }}</code></td>
                                    <td><span class="badge text-bg-light text-dark">{{ t.column_count }}</span></td>
                                    <td class="text-muted small">{{ t.size }}</td>
                                </tr>
                            {% endfor %}
                            </tbody>
                        </table>
                    </div>
                {% endif %}
            </div>
        </div>
    </div>

    {# Recent History #}
    <div class="col-lg-5">
        <div class="card border-0 rounded-4 shadow-sm h-100">
            <div class="card-header bg-white border-0 rounded-top-4 pt-4 px-4 pb-2">
                <h5 class="fw-bold mb-0" style="color:#0b3c5d;"><i class="bi bi-clock-history me-2 text-secondary"></i>Histórico Recente</h5>
            </div>
            <div class="card-body px-4 pb-4">
                {% if recentHistory is empty %}
                    <p class="text-muted text-center py-4">Nenhum evento registrado ainda.</p>
                {% else %}
                    {% for event in recentHistory %}
                        <div class="d-flex align-items-start gap-2 mb-3 pb-3 border-bottom">
                            <span class="rounded-3 p-2 flex-shrink-0 {% if event.status == 'success' %}text-success bg-success bg-opacity-10{% elseif event.status == 'failed' %}text-danger bg-danger bg-opacity-10{% else %}text-warning bg-warning bg-opacity-10{% endif %}">
                                <i class="bi bi-{% if event.status == 'success' %}check-circle{% elseif event.status == 'failed' %}x-circle{% else %}exclamation-circle{% endif %}"></i>
                            </span>
                            <div class="flex-grow-1 min-width-0">
                                <div class="fw-semibold small text-truncate" style="color:#0b3c5d;">{{ event.subject }}</div>
                                <div class="text-muted" style="font-size:0.78rem;">{{ event.eventType|replace({'_': ' '})|capitalize }} · {{ event.createdAt|date('d/m H:i') }}</div>
                                {% if event.rowsAffected %}
                                    <div class="text-muted" style="font-size:0.75rem;">{{ event.rowsAffected|number_format(0,',','.') }} linhas</div>
                                {% endif %}
                            </div>
                        </div>
                    {% endfor %}
                {% endif %}
            </div>
        </div>
    </div>
</div>

{# Quick Nav #}
<div class="row g-3 mt-2">
    <div class="col-md-4">
        <a href="{{ path('app_admin_analytic_models') }}" class="card border-0 rounded-4 text-decoration-none hover-lift" style="background:linear-gradient(135deg,#eff7fb,#e4f7f4);">
            <div class="card-body d-flex align-items-center gap-3 p-3">
                <span class="rounded-3 p-2" style="background:rgba(15,118,110,0.15);color:#0f766e;font-size:1.2rem;"><i class="bi bi-gear-wide-connected"></i></span>
                <div>
                    <div class="fw-bold small" style="color:#0b3c5d;">Modelos Analíticos</div>
                    <div class="text-muted" style="font-size:0.78rem;">Configurar transformações</div>
                </div>
            </div>
        </a>
    </div>
    <div class="col-md-4">
        <a href="{{ path('app_admin_data_lineage') }}" class="card border-0 rounded-4 text-decoration-none hover-lift" style="background:linear-gradient(135deg,#eff6ff,#dbeafe);">
            <div class="card-body d-flex align-items-center gap-3 p-3">
                <span class="rounded-3 p-2" style="background:rgba(37,99,235,0.15);color:#2563eb;font-size:1.2rem;"><i class="bi bi-diagram-3"></i></span>
                <div>
                    <div class="fw-bold small" style="color:#0b3c5d;">Linhagem de Dados</div>
                    <div class="text-muted" style="font-size:0.78rem;">CKAN → RAW → WAREHOUSE</div>
                </div>
            </div>
        </a>
    </div>
    <div class="col-md-4">
        <a href="{{ path('app_admin_metabase_dashboards') }}" class="card border-0 rounded-4 text-decoration-none hover-lift" style="background:linear-gradient(135deg,#fdf4ff,#fae8ff);">
            <div class="card-body d-flex align-items-center gap-3 p-3">
                <span class="rounded-3 p-2" style="background:rgba(147,51,234,0.15);color:#9333ea;font-size:1.2rem;"><i class="bi bi-bar-chart-line"></i></span>
                <div>
                    <div class="fw-bold small" style="color:#0b3c5d;">Dashboards Metabase</div>
                    <div class="text-muted" style="font-size:0.78rem;">Visualizações integradas</div>
                </div>
            </div>
        </a>
    </div>
</div>
{% endblock %}
