{# Generated by GitHub Copilot #}
{% extends 'base.html.twig' %}

{% block title %}Modelos Analíticos · Warehouse · Plataforma360{% endblock %}

{% block main %}
<div class="d-flex align-items-center justify-content-between mb-4 flex-wrap gap-3">
    <div>
        <nav aria-label="breadcrumb">
            <ol class="breadcrumb small mb-1">
                <li class="breadcrumb-item"><a href="{{ path('app_admin_warehouse_overview') }}" class="text-decoration-none">Warehouse</a></li>
                <li class="breadcrumb-item active">Modelos Analíticos</li>
            </ol>
        </nav>
        <h1 class="h3 fw-bold mb-0" style="color:#0b3c5d;">Modelos Analíticos</h1>
        <p class="text-muted mb-0 small">Defina como dados do STAGING são transformados em tabelas analíticas no Warehouse.</p>
    </div>
    <a href="{{ path('app_admin_analytic_models_new') }}" class="btn btn-primary rounded-3">
        <i class="bi bi-plus-lg me-1"></i> Novo Modelo
    </a>
</div>

{# Summary #}
<div class="row g-3 mb-4">
    <div class="col-4">
        <div class="card border-0 rounded-4 text-center py-3" style="background:linear-gradient(135deg,#eff7fb,#e4f7f4);">
            <div class="fw-bold fs-4" style="color:#0b3c5d;">{{ totalModels }}</div>
            <div class="text-muted small">Total</div>
        </div>
    </div>
    <div class="col-4">
        <div class="card border-0 rounded-4 text-center py-3" style="background:linear-gradient(135deg,#f0fdf4,#dcfce7);">
            <div class="fw-bold fs-4 text-success">{{ activeModels }}</div>
            <div class="text-muted small">Ativos</div>
        </div>
    </div>
    <div class="col-4">
        <div class="card border-0 rounded-4 text-center py-3" style="background:linear-gradient(135deg,#eff6ff,#dbeafe);">
            <div class="fw-bold fs-4 text-primary">{{ readyModels }}</div>
            <div class="text-muted small">Prontos</div>
        </div>
    </div>
</div>

{% if models is empty %}
    <div class="card border-0 rounded-4 shadow-sm">
        <div class="card-body text-center py-5">
            <i class="bi bi-gear-wide-connected fs-1 text-muted"></i>
            <h5 class="mt-3 mb-2" style="color:#0b3c5d;">Nenhum modelo analítico cadastrado</h5>
            <p class="text-muted mb-4">Crie um modelo para definir como os dados do STAGING serão transformados em tabelas do warehouse.</p>
            <a href="{{ path('app_admin_analytic_models_new') }}" class="btn btn-primary rounded-3">
                <i class="bi bi-plus-lg me-1"></i> Criar primeiro modelo
            </a>
        </div>
    </div>
{% else %}
    <div class="card border-0 rounded-4 shadow-sm">
        <div class="card-body p-0">
            <div class="table-responsive">
                <table class="table table-hover align-middle mb-0">
                    <thead>
                        <tr class="text-muted small border-bottom" style="background:#f8fafc;">
                            <th class="px-4 py-3">Modelo</th>
                            <th>Tabela Origem</th>
                            <th>Tabela Destino</th>
                            <th>Status</th>
                            <th>Linhas</th>
                            <th>Atualizado</th>
                            <th>Ações</th>
                        </tr>
                    </thead>
                    <tbody>
                        {% for model in models %}
                        <tr>
                            <td class="px-4 py-3">
                                <div class="fw-semibold" style="color:#0b3c5d;">{{ model.name }}</div>
                                <div class="text-muted small">{{ model.description|default('') }}</div>
                            </td>
                            <td><code class="small">{{ model.sourceTable }}</code></td>
                            <td><code class="small">{{ model.targetTable }}</code></td>
                            <td>
                                {% set status = model.lastRefreshStatus %}
                                {% if status == 'ready' %}
                                    <span class="badge text-bg-success rounded-pill">Pronto</span>
                                {% elseif status == 'running' %}
                                    <span class="badge text-bg-primary rounded-pill">Executando</span>
                                {% elseif status == 'failed' %}
                                    <span class="badge text-bg-danger rounded-pill">Falhou</span>
                                {% else %}
                                    <span class="badge text-bg-secondary rounded-pill">Pendente</span>
                                {% endif %}
                                {% if not model.active %}
                                    <span class="badge text-bg-light text-dark ms-1 rounded-pill">Inativo</span>
                                {% endif %}
                            </td>
                            <td>
                                {% if model.rowCount is not null %}
                                    <span class="text-muted small">{{ model.rowCount|number_format(0,',','.') }}</span>
                                {% else %}
                                    <span class="text-muted small">—</span>
                                {% endif %}
                            </td>
                            <td class="text-muted small">
                                {{ model.lastRefreshedAt ? model.lastRefreshedAt|date('d/m H:i') : '—' }}
                            </td>
                            <td>
                                <div class="d-flex gap-1">
                                    <form method="post" action="{{ path('app_admin_analytic_models_run', {id: model.id}) }}">
                                        <input type="hidden" name="_token" value="{{ csrf_token('run-model-' ~ model.id) }}">
                                        <button type="submit" class="btn btn-sm btn-outline-success rounded-3" title="Executar transformação">
                                            <i class="bi bi-play-fill"></i>
                                        </button>
                                    </form>
                                    <a href="{{ path('app_admin_analytic_models_edit', {id: model.id}) }}" class="btn btn-sm btn-outline-secondary rounded-3" title="Editar">
                                        <i class="bi bi-pencil"></i>
                                    </a>
                                    <form method="post" action="{{ path('app_admin_analytic_models_delete', {id: model.id}) }}" onsubmit="return confirm('Remover modelo {{ model.name }}?')">
                                        <input type="hidden" name="_token" value="{{ csrf_token('delete-model-' ~ model.id) }}">
                                        <button type="submit" class="btn btn-sm btn-outline-danger rounded-3" title="Remover">
                                            <i class="bi bi-trash3"></i>
                                        </button>
                                    </form>
                                </div>
                            </td>
                        </tr>
                        {% endfor %}
                    </tbody>
                </table>
            </div>
        </div>
    </div>
{% endif %}
{% endblock %}
