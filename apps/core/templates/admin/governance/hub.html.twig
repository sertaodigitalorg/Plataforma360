{% extends 'base.html.twig' %}
{% block title %}Governança · Hub{% endblock %}

{% block stylesheets %}
    {{ parent() }}
    {% include 'admin/data_management/_styles.html.twig' %}
{% endblock %}

{% block body %}
<section class="py-4 py-lg-5">

  {# Hero banner #}
  <div class="data-management-hero p-4 p-lg-5 mb-4">
    <div class="row align-items-center g-4">
      <div class="col-lg-8">
        <span class="badge rounded-pill text-bg-light text-primary mb-3">Fase 6 · Conformidade e Auditoria</span>
        <h1 class="display-6 fw-bold mb-3">Governança</h1>
        <p class="lead mb-3">Conformidade LGPD, rastreamento de uso de IA, custos e trilha de auditoria administrativa.</p>
        <p class="mb-0 opacity-75">Classifique datasets, acompanhe o uso de provedores de IA, monitore custos e mantenha rastreabilidade completa de todas as ações administrativas.</p>
      </div>
      <div class="col-lg-4">
        <div class="data-management-panel p-4 h-100">
          <p class="text-uppercase small fw-semibold text-primary mb-2">Resumo</p>
          <div class="row g-2 text-center">
            <div class="col-6">
              <p class="data-management-card__total mb-0" style="font-size:1.75rem">{{ stats.data_records }}</p>
              <p class="text-muted small mb-0">Registros LGPD</p>
            </div>
            <div class="col-6">
              <p class="data-management-card__total mb-0" style="font-size:1.75rem">{{ stats.audit_logs }}</p>
              <p class="text-muted small mb-0">Logs auditoria</p>
            </div>
          </div>
          <div class="mt-3 d-flex flex-wrap gap-2">
            <a class="btn btn-primary btn-sm" href="{{ path('app_admin_governance_audit') }}">
              <i class="bi bi-journal-check me-1"></i>Ver auditoria
            </a>
            <a class="btn btn-outline-primary btn-sm" href="{{ path('app_admin_governance_data') }}">
              <i class="bi bi-shield-lock me-1"></i>Dados LGPD
            </a>
          </div>
        </div>
      </div>
    </div>
  </div>

  {# Module cards #}
  <div class="row g-4">

    <div class="col-md-6 col-xl-3">
      <a href="{{ path('app_admin_governance_data') }}" class="text-decoration-none">
        <article class="data-management-card p-4">
          <div class="d-flex justify-content-between align-items-start gap-3 mb-3">
            <div class="data-management-icon"><i class="bi bi-shield-lock"></i></div>
            <span class="badge rounded-pill text-bg-light text-primary">{{ stats.data_records }} registros</span>
          </div>
          <h3 class="h5 mb-2">Dados LGPD</h3>
          <p class="text-secondary small mb-3">Classificação de sensibilidade, política de retenção e responsáveis pelos datasets.</p>
          <span class="btn btn-outline-primary btn-sm w-100">Gerenciar</span>
        </article>
      </a>
    </div>

    <div class="col-md-6 col-xl-3">
      <a href="{{ path('app_admin_governance_ai') }}" class="text-decoration-none">
        <article class="data-management-card p-4">
          <div class="d-flex justify-content-between align-items-start gap-3 mb-3">
            <div class="data-management-icon"><i class="bi bi-robot"></i></div>
            <span class="badge rounded-pill text-bg-light text-primary">{{ stats.ai_interactions }} interações</span>
          </div>
          <h3 class="h5 mb-2">Governança IA</h3>
          <p class="text-secondary small mb-3">Rastreamento de uso de IA, provedores externos e conformidade operacional.</p>
          <span class="btn btn-outline-primary btn-sm w-100">Visualizar</span>
        </article>
      </a>
    </div>

    <div class="col-md-6 col-xl-3">
      <a href="{{ path('app_admin_governance_costs') }}" class="text-decoration-none">
        <article class="data-management-card p-4">
          <div class="d-flex justify-content-between align-items-start gap-3 mb-3">
            <div class="data-management-icon"><i class="bi bi-currency-dollar"></i></div>
            <span class="badge rounded-pill text-bg-light text-primary">{{ stats.cost_records }} registros</span>
          </div>
          <h3 class="h5 mb-2">Custos</h3>
          <p class="text-secondary small mb-3">Rastreamento de custos por serviço externo — OpenAI, APIs e integrações pagas.</p>
          <span class="btn btn-outline-primary btn-sm w-100">Ver custos</span>
        </article>
      </a>
    </div>

    <div class="col-md-6 col-xl-3">
      <a href="{{ path('app_admin_governance_audit') }}" class="text-decoration-none">
        <article class="data-management-card p-4">
          <div class="d-flex justify-content-between align-items-start gap-3 mb-3">
            <div class="data-management-icon"><i class="bi bi-journal-check"></i></div>
            <span class="badge rounded-pill text-bg-light text-primary">{{ stats.audit_logs }} logs</span>
          </div>
          <h3 class="h5 mb-2">Auditoria</h3>
          <p class="text-secondary small mb-3">Trilha completa de todas as ações administrativas — quem fez o quê e quando.</p>
          <span class="btn btn-outline-primary btn-sm w-100">Ver trilha</span>
        </article>
      </a>
    </div>

  </div>

</section>
{% endblock %}
