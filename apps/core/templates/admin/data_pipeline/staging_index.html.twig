{# Generated by GitHub Copilot #}
{% extends 'base.html.twig' %}

{% block title %}Preview Staging | Plataforma360{% endblock %}

{% block stylesheets %}
    {{ parent() }}
    {% include 'admin/data_providers/_styles.html.twig' %}
{% endblock %}

{% block body %}
    <section class="py-4 py-lg-5" aria-labelledby="staging-title">
        <div class="container">
            {% include 'default/_flash_messages.html.twig' %}

            <div class="data-management-hero p-4 p-lg-5 mb-4">
                <div class="row g-4 align-items-end">
                    <div class="col-lg-8">
                        <span class="badge rounded-pill text-bg-light text-primary mb-3">Staging · Fase 3</span>
                        <h1 id="staging-title" class="display-6 fw-bold mb-3">Preview Staging</h1>
                        <p class="lead mb-0">Arquivos RAW transformados e normalizados disponíveis na camada staging, prontos para analytics, APIs e carregamento futuro no warehouse.</p>
                    </div>
                    <div class="col-lg-4">
                        <div class="provider-hero-note p-4 h-100">
                            <p class="text-uppercase small fw-semibold mb-2">Diretório staging</p>
                            <p class="fs-6 fw-bold mb-1 font-monospace">storage/staging/{provider}/{dataset}/{Y}/{m}</p>
                            <p class="mb-0">Derivado do RAW — staging não substitui a origem.</p>
                        </div>
                    </div>
                </div>
            </div>

            <div class="row g-3 mb-4">
                <div class="col-12 col-md-6">
                    <article class="provider-summary-card h-100 p-4">
                        <p class="text-muted text-uppercase small fw-semibold mb-2">Arquivos em staging</p>
                        <p class="provider-summary-card__value mb-1">{{ summary.totalStaged }}</p>
                        <p class="mb-0 text-secondary small">Datasets normalizados prontos para analytics.</p>
                    </article>
                </div>
                <div class="col-12 col-md-6">
                    <article class="provider-summary-card h-100 p-4">
                        <p class="text-muted text-uppercase small fw-semibold mb-2">Transformações falhas</p>
                        <p class="provider-summary-card__value mb-1">{{ summary.totalFailed }}</p>
                        <p class="mb-0 text-secondary small">Arquivos com erro durante transformação.</p>
                    </article>
                </div>
            </div>

            <div class="data-management-table-card p-3 p-lg-4">
                <div class="d-flex justify-content-between align-items-start gap-3 flex-wrap mb-3">
                    <div>
                        <h2 class="h4 mb-1">Arquivos em staging</h2>
                        <p class="text-secondary mb-0">RAW Files com transformação concluída e dados normalizados disponíveis.</p>
                    </div>
                </div>

                {% if files is empty %}
                    <div class="alert alert-info rounded-3 mb-0">
                        <i class="bi bi-layers me-2"></i>
                        Nenhum arquivo em staging ainda. Execute uma transformação em um arquivo RAW para criar o primeiro dataset staging.
                    </div>
                {% else %}
                    <div class="table-responsive">
                        <table class="table align-middle mb-0">
                            <thead>
                                <tr>
                                    <th>Arquivo RAW</th>
                                    <th>Provedor</th>
                                    <th>Staging path</th>
                                    <th>Status</th>
                                    <th>Download</th>
                                    <th class="text-end">Ações</th>
                                </tr>
                            </thead>
                            <tbody>
                                {% for file in files %}
                                    <tr>
                                        <td>
                                            <div class="fw-semibold">{{ file.originalName }}</div>
                                            <div class="small text-secondary">ID #{{ file.id }}</div>
                                        </td>
                                        <td>{{ file.dataProvider.name }}</td>
                                        <td class="font-monospace small text-secondary">{{ file.stagingPath|slice(0, 60) }}{% if file.stagingPath|length > 60 %}…{% endif %}</td>
                                        <td>
                                            <span class="provider-soft-badge provider-soft-badge--{{ file.transformationStatus == 'done' ? 'success' : (file.transformationStatus == 'failed' ? 'danger' : 'secondary') }}">
                                                {{ file.transformationStatus|capitalize }}
                                            </span>
                                        </td>
                                        <td>{{ file.downloadedAt ? file.downloadedAt|date('d/m/Y H:i') : '—' }}</td>
                                        <td class="text-end">
                                            <a class="btn btn-sm btn-outline-primary" href="{{ path('app_admin_staging_show', {id: file.id}) }}">
                                                Preview staging
                                            </a>
                                        </td>
                                    </tr>
                                {% endfor %}
                            </tbody>
                        </table>
                    </div>
                {% endif %}
            </div>
        </div>
    </section>
{% endblock %}
