{# Generated by GitHub Copilot #}
{% extends 'base.html.twig' %}

{% block title %}{{ isEdit ? 'Editar' : 'Novo' }} Mapeamento | Plataforma360{% endblock %}

{% block stylesheets %}
    {{ parent() }}
    {% include 'admin/data_providers/_styles.html.twig' %}
{% endblock %}

{% block body %}
    <section class="py-4 py-lg-5" aria-labelledby="mapping-form-title">
        <div class="container">
            {% include 'default/_flash_messages.html.twig' %}

            <div class="data-management-hero p-4 p-lg-5 mb-4">
                <div class="row g-4 align-items-center">
                    <div class="col">
                        <span class="badge rounded-pill text-bg-light text-primary mb-3">Mapeamento de Colunas</span>
                        <h1 id="mapping-form-title" class="display-6 fw-bold mb-2">{{ isEdit ? 'Editar mapeamento' : 'Novo mapeamento' }}</h1>
                        <p class="lead mb-0">{{ package.title ?? package.packageId }} · {{ package.dataProvider.name }}</p>
                    </div>
                </div>
            </div>

            <div class="data-management-table-card p-4 mb-4">
                <form method="post">
                    <div class="row g-4">
                        <div class="col-12 col-md-6">
                            <label class="form-label fw-semibold" for="original_column">Coluna original</label>
                            <input type="text" id="original_column" name="original_column" class="form-control font-monospace"
                                   value="{{ mapping.originalColumn ?? '' }}" required
                                   placeholder="ex: Nome Fantasia">
                            <div class="form-text">O nome exato da coluna no arquivo CSV/XLSX original.</div>
                        </div>

                        <div class="col-12 col-md-6">
                            <label class="form-label fw-semibold" for="normalized_column">Campo normalizado</label>
                            <input type="text" id="normalized_column" name="normalized_column" class="form-control font-monospace"
                                   value="{{ mapping.normalizedColumn ?? '' }}" required
                                   placeholder="ex: nome_fantasia"
                                   pattern="[a-z][a-z0-9_]*">
                            <div class="form-text">Usar snake_case — ex: <code>nome_fantasia</code>, <code>municipio</code>, <code>uf</code>.</div>
                        </div>

                        <div class="col-12 col-md-4">
                            <label class="form-label fw-semibold" for="target_data_type">Tipo de dado alvo</label>
                            <select id="target_data_type" name="target_data_type" class="form-select">
                                {% for type in availableTypes %}
                                    <option value="{{ type }}" {{ (mapping.targetDataType ?? 'string') == type ? 'selected' }}>
                                        {{ typeLabelMap[type] ?? type }}
                                    </option>
                                {% endfor %}
                            </select>
                        </div>

                        <div class="col-12 col-md-4">
                            <label class="form-label fw-semibold" for="normalization_rule">Regra de normalização</label>
                            <select id="normalization_rule" name="normalization_rule" class="form-select">
                                <option value="">— Nenhuma —</option>
                                {% for rule in availableRules %}
                                    <option value="{{ rule }}" {{ (mapping.normalizationRule ?? '') == rule ? 'selected' }}>
                                        {{ ruleLabelMap[rule] ?? rule }}
                                    </option>
                                {% endfor %}
                            </select>
                        </div>

                        <div class="col-12 col-md-4 d-flex flex-column justify-content-end">
                            <div class="d-flex gap-4 pt-2">
                                <div class="form-check">
                                    <input class="form-check-input" type="checkbox" id="required_field" name="required_field" value="1"
                                           {{ (mapping.requiredField ?? false) ? 'checked' }}>
                                    <label class="form-check-label" for="required_field">Campo obrigatório</label>
                                </div>
                                <div class="form-check">
                                    <input class="form-check-input" type="checkbox" id="is_active" name="is_active" value="1"
                                           {{ (mapping.active ?? true) ? 'checked' }}>
                                    <label class="form-check-label" for="is_active">Ativo</label>
                                </div>
                            </div>
                        </div>
                    </div>

                    <div class="d-flex gap-2 mt-4 pt-2 border-top">
                        <button type="submit" class="btn btn-primary">
                            {{ isEdit ? 'Salvar alterações' : 'Criar mapeamento' }}
                        </button>
                        <a class="btn btn-light" href="{{ path('app_admin_column_mapping_package', {id: package.id}) }}">Cancelar</a>
                    </div>
                </form>
            </div>
        </div>
    </section>
{% endblock %}
