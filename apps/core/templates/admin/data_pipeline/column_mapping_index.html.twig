{# Generated by GitHub Copilot #}
{% extends 'base.html.twig' %}

{% block title %}Mapeamento de Colunas | Plataforma360{% endblock %}

{% block stylesheets %}
    {{ parent() }}
    {% include 'admin/data_providers/_styles.html.twig' %}
{% endblock %}

{% block body %}
    <section class="py-4 py-lg-5" aria-labelledby="mapping-title">
        <div class="container">
            {% include 'default/_flash_messages.html.twig' %}

            <div class="data-management-hero p-4 p-lg-5 mb-4">
                <div class="row g-4 align-items-end">
                    <div class="col-lg-8">
                        <span class="badge rounded-pill text-bg-light text-primary mb-3">Transformação · Fase 3</span>
                        <h1 id="mapping-title" class="display-6 fw-bold mb-3">Mapeamento de Colunas</h1>
                        <p class="lead mb-0">Padronize colunas entre datasets diferentes — defina o campo normalizado, o tipo de dado alvo e a regra de normalização para cada coluna original do provedor.</p>
                    </div>
                    <div class="col-lg-4">
                        <div class="provider-hero-note p-4 h-100">
                            <p class="text-uppercase small fw-semibold mb-2">Pacotes monitorados</p>
                            <p class="fs-2 fw-bold mb-1">{{ packages|length }}</p>
                            <p class="mb-0">Disponíveis para configuração de mapeamento.</p>
                        </div>
                    </div>
                </div>
            </div>

            {% if packages is empty %}
                <div class="alert alert-info rounded-4">
                    <i class="bi bi-info-circle me-2"></i>
                    Nenhum pacote monitorado encontrado. Ative o monitoramento de pacotes CKAN para configurar mapeamentos.
                </div>
            {% else %}
                <div class="data-management-table-card p-3 p-lg-4">
                    <div class="d-flex justify-content-between align-items-start gap-3 flex-wrap mb-3">
                        <div>
                            <h2 class="h4 mb-1">Pacotes disponíveis para mapeamento</h2>
                            <p class="text-secondary mb-0">Selecione um pacote para configurar o mapeamento das colunas originais para campos normalizados.</p>
                        </div>
                    </div>

                    <div class="table-responsive">
                        <table class="table align-middle mb-0">
                            <thead>
                                <tr>
                                    <th>Pacote</th>
                                    <th>Provedor</th>
                                    <th>Status</th>
                                    <th>Última sincronização</th>
                                    <th class="text-end">Ações</th>
                                </tr>
                            </thead>
                            <tbody>
                                {% for package in packages %}
                                    <tr>
                                        <td>
                                            <div class="fw-semibold">{{ package.title ?? package.packageId }}</div>
                                            <div class="small text-secondary font-monospace">{{ package.packageId }}</div>
                                        </td>
                                        <td>{{ package.dataProvider.name }}</td>
                                        <td>
                                            <span class="provider-soft-badge {{ package.isActive ? 'provider-soft-badge--success' : 'provider-soft-badge--secondary' }}">
                                                {{ package.isActive ? 'Ativo' : 'Inativo' }}
                                            </span>
                                        </td>
                                        <td class="text-secondary small">
                                            {% if package.lastCheckedAt %}
                                                {{ package.lastCheckedAt|date('d/m/Y H:i') }}
                                            {% else %}
                                                —
                                            {% endif %}
                                        </td>
                                        <td class="text-end">
                                            <a class="btn btn-sm btn-outline-primary" href="{{ path('app_admin_column_mapping_package', {id: package.id}) }}">
                                                Configurar mapeamento
                                            </a>
                                        </td>
                                    </tr>
                                {% endfor %}
                            </tbody>
                        </table>
                    </div>
                </div>
            {% endif %}
        </div>
    </section>
{% endblock %}
