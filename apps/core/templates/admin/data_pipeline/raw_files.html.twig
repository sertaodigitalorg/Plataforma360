{% extends 'base.html.twig' %}

{% block title %}Arquivos RAW | Plataforma360{% endblock %}

{% block stylesheets %}
    {{ parent() }}
    {% include 'admin/data_providers/_styles.html.twig' %}
{% endblock %}

{% block body %}
    <section class="py-4 py-lg-5" aria-labelledby="raw-files-title">
        <div class="container">
            {% include 'default/_flash_messages.html.twig' %}

            <div class="data-management-hero p-4 p-lg-5 mb-4">
                <div class="row g-4 align-items-end">
                    <div class="col-lg-8">
                        <span class="badge rounded-pill text-bg-light text-primary mb-3">Storage RAW</span>
                        <h1 id="raw-files-title" class="display-6 fw-bold mb-3">Arquivos RAW</h1>
                        <p class="lead mb-0">Camada operacional da pipeline CKAN com download físico, controle de duplicidade por hash e base pronta para staging e warehouse.</p>
                    </div>
                    <div class="col-lg-4">
                        <div class="provider-hero-note p-4 h-100">
                            <p class="text-uppercase small fw-semibold mb-2">Diretório padrão</p>
                            <p class="fs-5 fw-bold mb-1">storage/raw/{provider}/{package}/{year}/{month}</p>
                            <p class="mb-0">Organização preparada para versionamento futuro e trilha analítica.</p>
                        </div>
                    </div>
                </div>
            </div>

            <div class="row g-3 mb-4">
                <div class="col-12 col-md-6 col-xl-3">
                    <article class="provider-summary-card h-100 p-4">
                        <p class="text-muted text-uppercase small fw-semibold mb-2">Total RAW</p>
                        <p class="provider-summary-card__value mb-1">{{ summary.total }}</p>
                        <p class="mb-0 text-secondary small">Arquivos e referências persistidas.</p>
                    </article>
                </div>
                <div class="col-12 col-md-6 col-xl-3">
                    <article class="provider-summary-card h-100 p-4">
                        <p class="text-muted text-uppercase small fw-semibold mb-2">Downloads reais</p>
                        <p class="provider-summary-card__value mb-1">{{ summary.downloaded }}</p>
                        <p class="mb-0 text-secondary small">Arquivos físicos gravados no storage.</p>
                    </article>
                </div>
                <div class="col-12 col-md-6 col-xl-3">
                    <article class="provider-summary-card h-100 p-4">
                        <p class="text-muted text-uppercase small fw-semibold mb-2">Duplicidades evitadas</p>
                        <p class="provider-summary-card__value mb-1">{{ summary.duplicates }}</p>
                        <p class="mb-0 text-secondary small">Reuso por SHA256 sem sobrescrita física.</p>
                    </article>
                </div>
                <div class="col-12 col-md-6 col-xl-3">
                    <article class="provider-summary-card h-100 p-4">
                        <p class="text-muted text-uppercase small fw-semibold mb-2">Previewável</p>
                        <p class="provider-summary-card__value mb-1">{{ summary.previewable }}</p>
                        <p class="mb-0 text-secondary small">CSV/XLSX prontos para parser e schema.</p>
                    </article>
                </div>
            </div>

            <div class="data-management-table-card p-3 p-lg-4">
                <div class="d-flex justify-content-between align-items-start gap-3 flex-wrap mb-3">
                    <div>
                        <h2 class="h4 mb-1">Inventário operacional</h2>
                        <p class="text-secondary mb-0">Cada linha representa uma evidência persistida da ingestão real, incluindo arquivos duplicados apontando para o mesmo hash.</p>
                    </div>
                    <div class="d-flex gap-2 flex-wrap">
                        <a class="btn btn-outline-primary" href="{{ path('app_admin_dataset_previews') }}">Preview Dataset</a>
                        <a class="btn btn-light" href="{{ path('app_admin_ingestion_history') }}">Histórico</a>
                    </div>
                </div>

                <div class="table-responsive">
                    <table class="table align-middle mb-0">
                        <thead>
                            <tr>
                                <th>Arquivo</th>
                                <th>Provider</th>
                                <th>Pacote</th>
                                <th>Formato</th>
                                <th>Tamanho</th>
                                <th>Hash</th>
                                <th>Status</th>
                                <th>Download</th>
                                <th class="text-end">Ações</th>
                            </tr>
                        </thead>
                        <tbody>
                            {% for rawFile in rawFiles %}
                                <tr>
                                    <td>
                                        <div class="fw-semibold">{{ rawFile.originalName }}</div>
                                        <div class="small text-secondary raw-file-path">{{ rawFile.localPath }}</div>
                                    </td>
                                    <td>{{ rawFile.dataProvider.name }}</td>
                                    <td>{{ rawFile.providerPackage.displayTitle }}</td>
                                    <td>{{ rawFile.extension ? rawFile.extension|upper : 'N/D' }}</td>
                                    <td>{{ rawFile.fileSize is not null ? rawFile.fileSize|number_format(0, ',', '.') ~ ' bytes' : 'N/D' }}</td>
                                    <td><code>{{ rawFile.fileHash ? rawFile.fileHash|slice(0, 16) ~ '...' : 'N/D' }}</code></td>
                                    <td>
                                        <span class="provider-soft-badge provider-soft-badge--{{ rawFile.downloadStatus == constant('App\\Entity\\Data\\RawFile::STATUS_DOWNLOADED') ? 'success' : (rawFile.downloadStatus == constant('App\\Entity\\Data\\RawFile::STATUS_DUPLICATE') ? 'warning' : 'secondary') }}">
                                            {{ rawFile.downloadStatus == constant('App\\Entity\\Data\\RawFile::STATUS_DOWNLOADED') ? 'Baixado' : (rawFile.downloadStatus == constant('App\\Entity\\Data\\RawFile::STATUS_DUPLICATE') ? 'Duplicado' : rawFile.downloadStatus) }}
                                        </span>
                                    </td>
                                    <td>{{ rawFile.downloadedAt ? rawFile.downloadedAt|date('d/m/Y H:i') : 'N/D' }}</td>
                                    <td>
                                        <div class="d-flex justify-content-end gap-2 flex-wrap">
                                            {% if rawFile.extension in ['csv', 'xlsx'] %}
                                                <a class="btn btn-sm btn-outline-primary" href="{{ path('app_admin_dataset_preview_show', {id: rawFile.id}) }}">Ver preview</a>
                                            {% endif %}
                                            <a class="btn btn-sm btn-outline-secondary" href="{{ path('app_admin_raw_files_download', {id: rawFile.id}) }}">Download</a>
                                            <a class="btn btn-sm btn-outline-secondary" href="{{ path('app_admin_raw_files_metadata', {id: rawFile.id}) }}">Ver metadata</a>
                                            <form method="post" action="{{ path('app_admin_raw_files_reprocess', {id: rawFile.id}) }}">
                                                <button type="submit" class="btn btn-sm btn-outline-primary">Reprocessar</button>
                                            </form>
                                            <form method="post" action="{{ path('app_admin_raw_files_delete', {id: rawFile.id}) }}">
                                                <button type="submit" class="btn btn-sm btn-outline-danger">Excluir</button>
                                            </form>
                                        </div>
                                    </td>
                                </tr>
                            {% else %}
                                <tr>
                                    <td colspan="9" class="text-center py-5 text-secondary">Nenhum arquivo RAW foi registrado ainda. Execute um download ou pipeline a partir dos pacotes CKAN.</td>
                                </tr>
                            {% endfor %}
                        </tbody>
                    </table>
                </div>
            </div>
        </div>
    </section>
{% endblock %}