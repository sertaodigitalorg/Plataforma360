{# Generated by GitHub Copilot #}
{% extends 'base.html.twig' %}

{% block title %}Qualidade de Dados | Plataforma360{% endblock %}

{% block stylesheets %}
    {{ parent() }}
    {% include 'admin/data_providers/_styles.html.twig' %}
{% endblock %}

{% block body %}
    <section class="py-4 py-lg-5" aria-labelledby="quality-title">
        <div class="container">
            {% include 'default/_flash_messages.html.twig' %}

            <div class="data-management-hero p-4 p-lg-5 mb-4">
                <div class="row g-4 align-items-end">
                    <div class="col-lg-8">
                        <span class="badge rounded-pill text-bg-light text-primary mb-3">Qualidade · Fase 3</span>
                        <h1 id="quality-title" class="display-6 fw-bold mb-3">Qualidade de Dados</h1>
                        <p class="lead mb-0">Monitoramento analítico da qualidade dos datasets importados — linhas válidas, inválidas, duplicidades, campos nulos e erros de schema.</p>
                    </div>
                    <div class="col-lg-4">
                        <div class="provider-hero-note p-4 h-100">
                            <p class="text-uppercase small fw-semibold mb-2">Score médio de qualidade</p>
                            <p class="fs-2 fw-bold mb-1">{{ summary.averageScore|number_format(1) }}%</p>
                            <p class="mb-0">{{ summary.withIssues }} dataset(s) com problemas detectados.</p>
                        </div>
                    </div>
                </div>
            </div>

            <div class="row g-3 mb-4">
                <div class="col-12 col-md-6 col-xl-3">
                    <article class="provider-summary-card h-100 p-4">
                        <p class="text-muted text-uppercase small fw-semibold mb-2">Relatórios gerados</p>
                        <p class="provider-summary-card__value mb-1">{{ summary.totalReports }}</p>
                        <p class="mb-0 text-secondary small">Análises de qualidade executadas.</p>
                    </article>
                </div>
                <div class="col-12 col-md-6 col-xl-3">
                    <article class="provider-summary-card h-100 p-4">
                        <p class="text-muted text-uppercase small fw-semibold mb-2">Com problemas</p>
                        <p class="provider-summary-card__value mb-1">{{ summary.withIssues }}</p>
                        <p class="mb-0 text-secondary small">Datasets com linhas inválidas ou duplicadas.</p>
                    </article>
                </div>
                <div class="col-12 col-md-6 col-xl-3">
                    <article class="provider-summary-card h-100 p-4">
                        <p class="text-muted text-uppercase small fw-semibold mb-2">Score médio</p>
                        <p class="provider-summary-card__value mb-1">{{ summary.averageScore|number_format(1) }}%</p>
                        <p class="mb-0 text-secondary small">Percentual global de linhas válidas.</p>
                    </article>
                </div>
                <div class="col-12 col-md-6 col-xl-3">
                    <article class="provider-summary-card h-100 p-4">
                        <p class="text-muted text-uppercase small fw-semibold mb-2">Arquivos analisáveis</p>
                        <p class="provider-summary-card__value mb-1">{{ summary.processableFiles }}</p>
                        <p class="mb-0 text-secondary small">CSV/XLSX disponíveis para análise.</p>
                    </article>
                </div>
            </div>

            <div class="data-management-table-card p-3 p-lg-4">
                <div class="d-flex justify-content-between align-items-start gap-3 flex-wrap mb-3">
                    <div>
                        <h2 class="h4 mb-1">Relatórios recentes</h2>
                        <p class="text-secondary mb-0">Últimas análises de qualidade geradas para arquivos RAW.</p>
                    </div>
                </div>

                {% if reports is empty %}
                    <div class="alert alert-info rounded-3 mb-0">
                        <i class="bi bi-shield-check me-2"></i>
                        Nenhum relatório de qualidade gerado ainda. Acesse um arquivo RAW e clique em "Analisar qualidade".
                    </div>
                {% else %}
                    <div class="table-responsive">
                        <table class="table align-middle mb-0">
                            <thead>
                                <tr>
                                    <th>Arquivo RAW</th>
                                    <th>Provedor</th>
                                    <th>Total linhas</th>
                                    <th>Válidas</th>
                                    <th>Inválidas</th>
                                    <th>Score</th>
                                    <th>Gerado em</th>
                                    <th class="text-end">Ações</th>
                                </tr>
                            </thead>
                            <tbody>
                                {% for report in reports %}
                                    {% set score = report.qualityScore %}
                                    <tr>
                                        <td>
                                            <div class="fw-semibold">{{ report.rawFile.originalName }}</div>
                                            <div class="small text-secondary">ID #{{ report.rawFile.id }}</div>
                                        </td>
                                        <td>{{ report.rawFile.dataProvider.name }}</td>
                                        <td>{{ report.totalRows }}</td>
                                        <td class="text-success fw-semibold">{{ report.validRows }}</td>
                                        <td class="{{ report.invalidRows > 0 ? 'text-danger fw-semibold' : 'text-secondary' }}">{{ report.invalidRows }}</td>
                                        <td>
                                            <div class="d-flex align-items-center gap-2">
                                                <div class="progress flex-grow-1" style="height: 6px; width: 60px;">
                                                    <div class="progress-bar bg-{{ score >= 90 ? 'success' : (score >= 70 ? 'warning' : 'danger') }}"
                                                         role="progressbar" style="width: {{ score }}%"></div>
                                                </div>
                                                <span class="small fw-semibold">{{ score }}%</span>
                                            </div>
                                        </td>
                                        <td class="text-secondary small">{{ report.generatedAt|date('d/m/Y H:i') }}</td>
                                        <td class="text-end">
                                            <a class="btn btn-sm btn-outline-primary" href="{{ path('app_admin_data_quality_report', {id: report.rawFile.id}) }}">
                                                Ver detalhes
                                            </a>
                                        </td>
                                    </tr>
                                {% endfor %}
                            </tbody>
                        </table>
                    </div>
                {% endif %}
            </div>
        </div>
    </section>
{% endblock %}
