{# Generated by GitHub Copilot #}
{% extends 'base.html.twig' %}

{% block title %}Preview Staging – #{{ rawFile.id }} | Plataforma360{% endblock %}

{% block stylesheets %}
    {{ parent() }}
    {% include 'admin/data_providers/_styles.html.twig' %}
    <style>
        .staging-table td, .staging-table th { font-size: 0.82rem; white-space: nowrap; }
        .cell-null { color: #aaa; font-style: italic; }
        .cell-normalized { background: rgba(13, 110, 253, 0.04); }
    </style>
{% endblock %}

{% block body %}
    <section class="py-4 py-lg-5" aria-labelledby="staging-show-title">
        <div class="container-fluid px-4">
            {% include 'default/_flash_messages.html.twig' %}

            <div class="data-management-hero p-4 p-lg-5 mb-4 rounded-4">
                <div class="row g-4 align-items-end">
                    <div class="col-lg-8">
                        <span class="badge rounded-pill text-bg-light text-primary mb-3">Preview Staging</span>
                        <h1 id="staging-show-title" class="display-6 fw-bold mb-2">{{ rawFile.originalName }}</h1>
                        <p class="lead mb-0">{{ rawFile.dataProvider.name }} · {{ rawFile.providerPackage.title ?? rawFile.providerPackage.packageId }}</p>
                    </div>
                    <div class="col-lg-4">
                        <div class="provider-hero-note p-4 h-100">
                            <p class="text-uppercase small fw-semibold mb-2">Status staging</p>
                            <p class="fs-5 fw-bold mb-1">
                                <span class="provider-soft-badge provider-soft-badge--{{ rawFile.transformationStatus == 'done' ? 'success' : (rawFile.transformationStatus == 'failed' ? 'danger' : 'secondary') }}">
                                    {{ rawFile.transformationStatus|capitalize }}
                                </span>
                            </p>
                            {% if rawFile.stagingPath %}
                                <p class="mb-0 font-monospace small opacity-75">{{ rawFile.stagingPath|slice(0, 50) }}</p>
                            {% endif %}
                        </div>
                    </div>
                </div>
            </div>

            <div class="d-flex gap-2 mb-4 flex-wrap">
                <a class="btn btn-light" href="{{ path('app_admin_staging_preview') }}">Voltar</a>
                <a class="btn btn-outline-secondary" href="{{ path('app_admin_data_quality_report', {id: rawFile.id}) }}">Ver qualidade</a>
                <a class="btn btn-outline-secondary" href="{{ path('app_admin_column_mapping_package', {id: rawFile.providerPackage.id}) }}">Mapeamentos</a>
            </div>

            {% if previewError %}
                <div class="alert alert-danger rounded-4">
                    <i class="bi bi-exclamation-triangle me-2"></i>
                    {{ previewError }}
                </div>
            {% elseif not preview or not preview.previewAvailable %}
                <div class="alert alert-warning rounded-4">
                    <i class="bi bi-info-circle me-2"></i>
                    Preview não disponível para este arquivo ({{ preview.fileType ?? 'formato desconhecido' }}).
                </div>
            {% else %}
                {% if normalizedRows is not empty %}
                    <div class="data-management-table-card p-3 p-lg-4 mb-4">
                        <h2 class="h5 fw-semibold mb-3">
                            Dados normalizados
                            <span class="badge bg-primary rounded-pill ms-2">{{ normalizedRows|length }} linhas</span>
                        </h2>
                        <p class="text-secondary small mb-3">Colunas após mapeamento, normalização e conversão de tipos.</p>

                        <div class="table-responsive">
                            <table class="table table-sm table-hover staging-table align-middle mb-0">
                                <thead class="table-light">
                                    <tr>
                                        <th>#</th>
                                        {% for col in normalizedRows[0]|keys %}
                                            <th class="cell-normalized">{{ col }}</th>
                                        {% endfor %}
                                    </tr>
                                </thead>
                                <tbody>
                                    {% for idx, row in normalizedRows %}
                                        <tr>
                                            <td class="text-secondary">{{ idx + 1 }}</td>
                                            {% for val in row %}
                                                <td class="cell-normalized">
                                                    {% if val is null %}
                                                        <span class="cell-null">null</span>
                                                    {% elseif val is same as false %}
                                                        <span class="text-danger">false</span>
                                                    {% elseif val is same as true %}
                                                        <span class="text-success">true</span>
                                                    {% else %}
                                                        {{ val }}
                                                    {% endif %}
                                                </td>
                                            {% endfor %}
                                        </tr>
                                    {% endfor %}
                                </tbody>
                            </table>
                        </div>
                    </div>
                {% endif %}

                <div class="data-management-table-card p-3 p-lg-4">
                    <h2 class="h5 fw-semibold mb-3">
                        Dados RAW originais
                        <span class="badge bg-secondary rounded-pill ms-2">{{ preview.totalRows }} linhas · {{ preview.totalColumns }} colunas</span>
                    </h2>
                    <p class="text-secondary small mb-3">Visualização das primeiras linhas sem normalização.</p>

                    <div class="table-responsive">
                        <table class="table table-sm table-hover staging-table align-middle mb-0">
                            <thead class="table-light">
                                <tr>
                                    <th>#</th>
                                    {% for header in preview.headers %}
                                        <th>{{ header }}</th>
                                    {% endfor %}
                                </tr>
                            </thead>
                            <tbody>
                                {% for idx, row in preview.rows %}
                                    <tr>
                                        <td class="text-secondary">{{ idx + 1 }}</td>
                                        {% for val in row %}
                                            <td>
                                                {% if val is null or val == '' %}
                                                    <span class="cell-null">—</span>
                                                {% else %}
                                                    {{ val }}
                                                {% endif %}
                                            </td>
                                        {% endfor %}
                                    </tr>
                                {% endfor %}
                            </tbody>
                        </table>
                    </div>
                </div>
            {% endif %}
        </div>
    </section>
{% endblock %}
