{# Generated by GitHub Copilot #}
{% extends 'base.html.twig' %}

{% block title %}Catálogo de Dados | Plataforma360{% endblock %}

{% block stylesheets %}
    {{ parent() }}
    {% include 'admin/data_providers/_styles.html.twig' %}
{% endblock %}

{% block body %}
    <section class="py-4 py-lg-5" aria-labelledby="catalog-title">
        <div class="container">
            {% include 'default/_flash_messages.html.twig' %}

            <div class="data-management-hero p-4 p-lg-5 mb-4">
                <div class="row g-4 align-items-end">
                    <div class="col-lg-8">
                        <span class="badge rounded-pill text-bg-light text-primary mb-3">Catálogo · Fase 3</span>
                        <h1 id="catalog-title" class="display-6 fw-bold mb-3">Catálogo de Dados</h1>
                        <p class="lead mb-0">Inventário estruturado dos datasets disponíveis na plataforma — provedor, origem, status de staging, qualidade e total de registros.</p>
                    </div>
                    <div class="col-lg-4">
                        <div class="provider-hero-note p-4 h-100">
                            <p class="text-uppercase small fw-semibold mb-2">Datasets catalogados</p>
                            <p class="fs-2 fw-bold mb-1">{{ summary.totalPackages }}</p>
                            <p class="mb-0">Score médio de qualidade: {{ summary.averageQuality|number_format(1) }}%</p>
                        </div>
                    </div>
                </div>
            </div>

            <div class="row g-3 mb-4">
                <div class="col-12 col-md-6 col-xl-3">
                    <article class="provider-summary-card h-100 p-4">
                        <p class="text-muted text-uppercase small fw-semibold mb-2">Total de datasets</p>
                        <p class="provider-summary-card__value mb-1">{{ summary.totalPackages }}</p>
                        <p class="mb-0 text-secondary small">Pacotes CKAN no inventário.</p>
                    </article>
                </div>
                <div class="col-12 col-md-6 col-xl-3">
                    <article class="provider-summary-card h-100 p-4">
                        <p class="text-muted text-uppercase small fw-semibold mb-2">Provedores ativos</p>
                        <p class="provider-summary-card__value mb-1">{{ summary.totalProviders }}</p>
                        <p class="mb-0 text-secondary small">Fontes de dados conectadas.</p>
                    </article>
                </div>
                <div class="col-12 col-md-6 col-xl-3">
                    <article class="provider-summary-card h-100 p-4">
                        <p class="text-muted text-uppercase small fw-semibold mb-2">Com staging</p>
                        <p class="provider-summary-card__value mb-1">{{ summary.withStaging }}</p>
                        <p class="mb-0 text-secondary small">Datasets normalizados no storage staging.</p>
                    </article>
                </div>
                <div class="col-12 col-md-6 col-xl-3">
                    <article class="provider-summary-card h-100 p-4">
                        <p class="text-muted text-uppercase small fw-semibold mb-2">Qualidade média</p>
                        <p class="provider-summary-card__value mb-1">{{ summary.averageQuality|number_format(1) }}%</p>
                        <p class="mb-0 text-secondary small">Score calculado sobre datasets analisados.</p>
                    </article>
                </div>
            </div>

            <div class="data-management-table-card p-3 p-lg-4">
                <div class="d-flex justify-content-between align-items-start gap-3 flex-wrap mb-3">
                    <div>
                        <h2 class="h4 mb-1">Inventário de datasets</h2>
                        <p class="text-secondary mb-0">Cada linha representa um pacote CKAN catalogado com seu status operacional e indicadores de qualidade.</p>
                    </div>
                </div>

                <div class="table-responsive">
                    <table class="table align-middle mb-0">
                        <thead>
                            <tr>
                                <th>Dataset</th>
                                <th>Provedor</th>
                                <th>Staging</th>
                                <th>Última atualização</th>
                                <th>Qualidade</th>
                                <th>Registros</th>
                                <th class="text-end">Ações</th>
                            </tr>
                        </thead>
                        <tbody>
                            {% for entry in catalogEntries %}
                                {% set package = entry.package %}
                                {% set report = entry.qualityReport %}
                                <tr>
                                    <td>
                                        <div class="fw-semibold">{{ package.title ?? package.packageId }}</div>
                                        <div class="small text-secondary font-monospace">{{ package.packageId }}</div>
                                    </td>
                                    <td>
                                        <div>{{ entry.provider.name }}</div>
                                        <div class="small text-secondary">{{ entry.provider.type }}</div>
                                    </td>
                                    <td>
                                        {% if entry.stagingAvailable %}
                                            <span class="provider-soft-badge provider-soft-badge--success">
                                                <i class="bi bi-check-circle me-1"></i>Disponível
                                            </span>
                                        {% else %}
                                            <span class="provider-soft-badge provider-soft-badge--secondary">Pendente</span>
                                        {% endif %}
                                    </td>
                                    <td class="text-secondary small">
                                        {{ package.updatedAt ? package.updatedAt|date('d/m/Y H:i') : package.createdAt|date('d/m/Y') }}
                                    </td>
                                    <td>
                                        {% if report %}
                                            {% set score = report.qualityScore %}
                                            <div class="d-flex align-items-center gap-2">
                                                <div class="progress" style="height: 6px; width: 50px;">
                                                    <div class="progress-bar bg-{{ score >= 90 ? 'success' : (score >= 70 ? 'warning' : 'danger') }}"
                                                         role="progressbar" style="width: {{ score }}%"></div>
                                                </div>
                                                <span class="small">{{ score }}%</span>
                                            </div>
                                        {% else %}
                                            <span class="text-secondary small">—</span>
                                        {% endif %}
                                    </td>
                                    <td>
                                        {% if report %}
                                            <span class="fw-semibold">{{ report.totalRows }}</span>
                                        {% else %}
                                            <span class="text-secondary">—</span>
                                        {% endif %}
                                    </td>
                                    <td class="text-end">
                                        <div class="d-flex justify-content-end gap-2 flex-wrap">
                                            <a class="btn btn-sm btn-outline-secondary" href="{{ path('app_admin_data_providers_packages', {id: package.dataProvider.id}) }}">Pacotes</a>
                                            {% if entry.rawFile %}
                                                <a class="btn btn-sm btn-outline-primary" href="{{ path('app_admin_data_quality_report', {id: entry.rawFile.id}) }}">Qualidade</a>
                                            {% endif %}
                                        </div>
                                    </td>
                                </tr>
                            {% else %}
                                <tr>
                                    <td colspan="7" class="text-center text-secondary py-4">
                                        Nenhum dataset catalogado. Sincronize provedores CKAN para começar.
                                    </td>
                                </tr>
                            {% endfor %}
                        </tbody>
                    </table>
                </div>
            </div>
        </div>
    </section>
{% endblock %}
