{# Generated by GitHub Copilot #}
{% extends 'base.html.twig' %}

{% block title %}Mapeamento – {{ package.title ?? package.packageId }} | Plataforma360{% endblock %}

{% block stylesheets %}
    {{ parent() }}
    {% include 'admin/data_providers/_styles.html.twig' %}
{% endblock %}

{% block body %}
    <section class="py-4 py-lg-5" aria-labelledby="mapping-pkg-title">
        <div class="container">
            {% include 'default/_flash_messages.html.twig' %}

            <div class="data-management-hero p-4 p-lg-5 mb-4">
                <div class="row g-4 align-items-end">
                    <div class="col-lg-8">
                        <span class="badge rounded-pill text-bg-light text-primary mb-3">Mapeamento de Colunas</span>
                        <h1 id="mapping-pkg-title" class="display-6 fw-bold mb-3">{{ package.title ?? package.packageId }}</h1>
                        <p class="lead mb-0">Configure como cada coluna original do dataset será mapeada para um campo normalizado interno, com tipo de dado e regra de transformação.</p>
                    </div>
                    <div class="col-lg-4">
                        <div class="provider-hero-note p-4 h-100">
                            <p class="text-uppercase small fw-semibold mb-2">Mapeamentos configurados</p>
                            <p class="fs-2 fw-bold mb-1">{{ mappings|length }}</p>
                            <p class="mb-0">{{ package.dataProvider.name }}</p>
                        </div>
                    </div>
                </div>
            </div>

            <div class="data-management-table-card p-3 p-lg-4 mb-4">
                <div class="d-flex justify-content-between align-items-start gap-3 flex-wrap mb-3">
                    <div>
                        <h2 class="h4 mb-1">Mapeamentos configurados</h2>
                        <p class="text-secondary mb-0 font-monospace small">{{ package.packageId }}</p>
                    </div>
                    <div class="d-flex gap-2 flex-wrap">
                        <a class="btn btn-light" href="{{ path('app_admin_column_mapping') }}">Voltar</a>
                        <a class="btn btn-primary" href="{{ path('app_admin_column_mapping_new', {id: package.id}) }}">
                            <i class="bi bi-plus-lg me-1"></i> Adicionar mapeamento
                        </a>
                    </div>
                </div>

                {% if mappings is empty %}
                    <div class="alert alert-info rounded-3 mb-0">
                        <i class="bi bi-diagram-3 me-2"></i>
                        Nenhum mapeamento configurado. Adicione mapeamentos para habilitar a normalização e validação dos dados.
                    </div>
                {% else %}
                    <div class="table-responsive">
                        <table class="table align-middle mb-0">
                            <thead>
                                <tr>
                                    <th>Coluna original</th>
                                    <th>Campo normalizado</th>
                                    <th>Tipo</th>
                                    <th>Regra</th>
                                    <th>Obrigatório</th>
                                    <th>Ativo</th>
                                    <th class="text-end">Ações</th>
                                </tr>
                            </thead>
                            <tbody>
                                {% for mapping in mappings %}
                                    <tr>
                                        <td>
                                            <span class="font-monospace small">{{ mapping.originalColumn }}</span>
                                        </td>
                                        <td>
                                            <span class="font-monospace small text-primary">{{ mapping.normalizedColumn }}</span>
                                        </td>
                                        <td>
                                            <span class="provider-soft-badge provider-soft-badge--info">{{ mapping.targetDataType }}</span>
                                        </td>
                                        <td>
                                            {% if mapping.normalizationRule %}
                                                <span class="provider-soft-badge provider-soft-badge--secondary">{{ mapping.normalizationRule }}</span>
                                            {% else %}
                                                <span class="text-secondary">—</span>
                                            {% endif %}
                                        </td>
                                        <td>
                                            {% if mapping.requiredField %}
                                                <span class="provider-soft-badge provider-soft-badge--danger">Sim</span>
                                            {% else %}
                                                <span class="text-secondary small">Não</span>
                                            {% endif %}
                                        </td>
                                        <td>
                                            {% if mapping.active %}
                                                <span class="provider-soft-badge provider-soft-badge--success">Ativo</span>
                                            {% else %}
                                                <span class="provider-soft-badge provider-soft-badge--secondary">Inativo</span>
                                            {% endif %}
                                        </td>
                                        <td class="text-end">
                                            <div class="d-flex justify-content-end gap-2">
                                                <a class="btn btn-sm btn-outline-secondary" href="{{ path('app_admin_column_mapping_edit', {id: mapping.id}) }}">Editar</a>
                                                <form method="post" action="{{ path('app_admin_column_mapping_delete', {id: mapping.id}) }}" onsubmit="return confirm('Remover mapeamento?')">
                                                    <input type="hidden" name="_token" value="{{ csrf_token('delete_mapping_' ~ mapping.id) }}">
                                                    <button class="btn btn-sm btn-outline-danger">Remover</button>
                                                </form>
                                            </div>
                                        </td>
                                    </tr>
                                {% endfor %}
                            </tbody>
                        </table>
                    </div>
                {% endif %}
            </div>
        </div>
    </section>
{% endblock %}
