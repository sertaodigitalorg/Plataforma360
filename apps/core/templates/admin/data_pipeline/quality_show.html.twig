{# Generated by GitHub Copilot #}
{% extends 'base.html.twig' %}

{% block title %}Relatório de Qualidade – #{{ rawFile.id }} | Plataforma360{% endblock %}

{% block stylesheets %}
    {{ parent() }}
    {% include 'admin/data_providers/_styles.html.twig' %}
{% endblock %}

{% block body %}
    <section class="py-4 py-lg-5" aria-labelledby="quality-show-title">
        <div class="container">
            {% include 'default/_flash_messages.html.twig' %}

            <div class="data-management-hero p-4 p-lg-5 mb-4">
                <div class="row g-4 align-items-end">
                    <div class="col-lg-8">
                        <span class="badge rounded-pill text-bg-light text-primary mb-3">Relatório de Qualidade</span>
                        <h1 id="quality-show-title" class="display-6 fw-bold mb-3">{{ rawFile.originalName }}</h1>
                        <p class="lead mb-0">{{ rawFile.dataProvider.name }} · {{ rawFile.providerPackage.title ?? rawFile.providerPackage.packageId }}</p>
                    </div>
                    <div class="col-lg-4">
                        <div class="provider-hero-note p-4 h-100">
                            {% if report %}
                                <p class="text-uppercase small fw-semibold mb-2">Score de qualidade</p>
                                <p class="fs-2 fw-bold mb-1">{{ report.qualityScore|number_format(1) }}%</p>
                                <p class="mb-0">Gerado em {{ report.generatedAt|date('d/m/Y H:i') }}</p>
                            {% else %}
                                <p class="text-uppercase small fw-semibold mb-2">Qualidade</p>
                                <p class="mb-0 opacity-75">Nenhum relatório gerado ainda.</p>
                            {% endif %}
                        </div>
                    </div>
                </div>
            </div>

            <div class="d-flex gap-2 mb-4 flex-wrap">
                <a class="btn btn-light" href="{{ path('app_admin_data_quality') }}">Voltar</a>
                <form method="post" action="{{ path('app_admin_data_quality_generate', {id: rawFile.id}) }}" class="d-inline">
                    <button class="btn btn-outline-primary">
                        <i class="bi bi-shield-check me-1"></i> Gerar relatório de qualidade
                    </button>
                </form>
                {% if rawFile.downloadStatus == 'downloaded' %}
                    <form method="post" action="{{ path('app_admin_data_transform', {id: rawFile.id}) }}" class="d-inline">
                        <button class="btn btn-primary">
                            <i class="bi bi-arrow-repeat me-1"></i> Executar transformação
                        </button>
                    </form>
                {% endif %}
            </div>

            {% if report %}
                <div class="row g-3 mb-4">
                    <div class="col-6 col-md-4 col-xl-2">
                        <article class="provider-summary-card h-100 p-3 text-center">
                            <p class="text-muted small fw-semibold mb-1">Total</p>
                            <p class="provider-summary-card__value mb-0 fs-3">{{ report.totalRows }}</p>
                        </article>
                    </div>
                    <div class="col-6 col-md-4 col-xl-2">
                        <article class="provider-summary-card h-100 p-3 text-center">
                            <p class="text-success small fw-semibold mb-1">Válidas</p>
                            <p class="provider-summary-card__value mb-0 fs-3 text-success">{{ report.validRows }}</p>
                        </article>
                    </div>
                    <div class="col-6 col-md-4 col-xl-2">
                        <article class="provider-summary-card h-100 p-3 text-center">
                            <p class="text-danger small fw-semibold mb-1">Inválidas</p>
                            <p class="provider-summary-card__value mb-0 fs-3 text-danger">{{ report.invalidRows }}</p>
                        </article>
                    </div>
                    <div class="col-6 col-md-4 col-xl-2">
                        <article class="provider-summary-card h-100 p-3 text-center">
                            <p class="text-warning small fw-semibold mb-1">Duplicadas</p>
                            <p class="provider-summary-card__value mb-0 fs-3 text-warning">{{ report.duplicatedRows }}</p>
                        </article>
                    </div>
                    <div class="col-6 col-md-4 col-xl-2">
                        <article class="provider-summary-card h-100 p-3 text-center">
                            <p class="text-secondary small fw-semibold mb-1">Campos nulos</p>
                            <p class="provider-summary-card__value mb-0 fs-3">{{ report.nullFields }}</p>
                        </article>
                    </div>
                    <div class="col-6 col-md-4 col-xl-2">
                        {% set score = report.qualityScore %}
                        <article class="provider-summary-card h-100 p-3 text-center">
                            <p class="small fw-semibold mb-1">Score</p>
                            <p class="provider-summary-card__value mb-0 fs-3 text-{{ score >= 90 ? 'success' : (score >= 70 ? 'warning' : 'danger') }}">
                                {{ score }}%
                            </p>
                        </article>
                    </div>
                </div>

                {% if report.validationErrors is not empty %}
                    <div class="data-management-table-card p-3 p-lg-4 mb-4">
                        <h2 class="h5 fw-semibold mb-3">Erros de validação (primeiros {{ report.validationErrors|length }} registros)</h2>
                        <div class="table-responsive">
                            <table class="table table-sm align-middle mb-0">
                                <thead class="table-light">
                                    <tr>
                                        <th style="width:80px">Linha</th>
                                        <th>Erros encontrados</th>
                                    </tr>
                                </thead>
                                <tbody>
                                    {% for errorEntry in report.validationErrors %}
                                        <tr>
                                            <td class="text-secondary small font-monospace">{{ errorEntry.row }}</td>
                                            <td>
                                                {% for error in errorEntry.errors %}
                                                    <div class="text-danger small">{{ error }}</div>
                                                {% endfor %}
                                            </td>
                                        </tr>
                                    {% endfor %}
                                </tbody>
                            </table>
                        </div>
                    </div>
                {% endif %}
            {% else %}
                <div class="alert alert-info rounded-4">
                    <i class="bi bi-info-circle me-2"></i>
                    Nenhum relatório de qualidade gerado para este arquivo. Clique em "Gerar relatório de qualidade" para analisar o dataset.
                </div>
            {% endif %}

            <div class="data-management-table-card p-4">
                <h2 class="h5 fw-semibold mb-3">Informações do arquivo</h2>
                <dl class="row mb-0">
                    <dt class="col-sm-3">Nome original</dt>
                    <dd class="col-sm-9 font-monospace">{{ rawFile.originalName }}</dd>
                    <dt class="col-sm-3">Extensão</dt>
                    <dd class="col-sm-9">{{ rawFile.extension|upper }}</dd>
                    <dt class="col-sm-3">Tamanho</dt>
                    <dd class="col-sm-9">{{ rawFile.fileSize ? (rawFile.fileSize / 1024)|number_format(1) ~ ' KB' : '—' }}</dd>
                    <dt class="col-sm-3">Status transformação</dt>
                    <dd class="col-sm-9">
                        <span class="provider-soft-badge provider-soft-badge--{{ rawFile.transformationStatus == 'done' ? 'success' : (rawFile.transformationStatus == 'failed' ? 'danger' : 'secondary') }}">
                            {{ rawFile.transformationStatus|capitalize }}
                        </span>
                    </dd>
                    <dt class="col-sm-3">Staging path</dt>
                    <dd class="col-sm-9 font-monospace small">{{ rawFile.stagingPath ?? '—' }}</dd>
                </dl>
            </div>
        </div>
    </section>
{% endblock %}
