{# Generated by GitHub Copilot #}
{% extends 'base.html.twig' %}

{% block title %}{{ isEdit ? 'Editar ' ~ metadata.singular : 'Novo ' ~ metadata.singular }} | Gestão de Dados{% endblock %}

{% block stylesheets %}
    {{ parent() }}
    {% include 'admin/data_management/_styles.html.twig' %}
{% endblock %}

{% block body %}
    <section class="py-4 py-lg-5">
        <div class="data-management-hero p-4 p-lg-5 mb-4">
            <div class="d-flex justify-content-between align-items-start gap-3 flex-wrap">
                <div>
                    <span class="badge rounded-pill text-bg-light text-primary mb-3">{{ metadata.singular }}</span>
                    <h1 class="display-6 fw-bold mb-3">{{ isEdit ? 'Editar ' ~ metadata.singular : 'Novo ' ~ metadata.singular }}</h1>
                    <p class="lead mb-0">Formulário visual para cadastro, atualização e manutenção manual da base estratégica.</p>
                </div>
                <div class="d-flex gap-2 flex-wrap">
                    <a class="btn btn-light" href="{{ path('app_admin_resource_index', {resource: resource}) }}">Voltar à listagem</a>
                    {% if isEdit %}
                        {% set entityId = attribute(entity, 'id') is defined and attribute(entity, 'id') is not null ? attribute(entity, 'id') : entity.getId() %}
                        <a class="btn btn-outline-light" href="{{ path('app_admin_resource_show', {resource: resource, id: entityId}) }}">Ver detalhes</a>
                    {% endif %}
                </div>
            </div>
        </div>

        <div class="data-management-form-card data-management-panel p-4">
            {{ form_start(form) }}
                {{ form_widget(form) }}
                <div class="d-flex gap-2 flex-wrap mt-4">
                    <button type="submit" class="btn btn-primary">Salvar</button>
                    <a class="btn btn-outline-secondary" href="{{ path('app_admin_resource_index', {resource: resource}) }}">Cancelar</a>
                </div>
            {{ form_end(form) }}
        </div>
    </section>
{% endblock %}