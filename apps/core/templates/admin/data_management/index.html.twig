{# Generated by GitHub Copilot #}
{% extends 'base.html.twig' %}

{% block title %}Gestão de Dados | Plataforma360{% endblock %}

{% block stylesheets %}
    {{ parent() }}
    {% include 'admin/data_management/_styles.html.twig' %}
{% endblock %}

{% block body %}
    <section class="py-4 py-lg-5" aria-labelledby="data-management-title">
        <div class="data-management-hero p-4 p-lg-5 mb-4">
            <div class="row align-items-center g-4">
                <div class="col-lg-8">
                    <span class="badge rounded-pill text-bg-light text-primary mb-3">Governança Humana de Dados</span>
                    <h1 id="data-management-title" class="display-6 fw-bold mb-3">Gestão de Dados</h1>
                    <p class="lead mb-3">Manutenção manual, revisão e higienização das bases estratégicas da Plataforma360.</p>
                    <p class="mb-0 opacity-75">Esta camada deixa explícito que a plataforma opera com governança humana, curadoria institucional e correções editoriais além das rotinas automatizadas e das APIs.</p>
                </div>
                <div class="col-lg-4">
                    <div class="data-management-panel p-4 h-100">
                        <p class="text-uppercase small fw-semibold text-primary mb-2">Função estratégica</p>
                        <p class="mb-2 text-secondary">Cadastre, edite, exclua, revise e higienize as principais entidades turísticas em uma interface administrativa visual.</p>
                        <div class="d-flex flex-wrap gap-2">
                            <a class="btn btn-primary" href="{{ path('app_admin_resource_index', {resource: 'organizations'}) }}">Abrir entidades</a>
                            <a class="btn btn-outline-primary" href="{{ path('app_batch_monitor') }}">Ver integrações</a>
                        </div>
                    </div>
                </div>
            </div>
        </div>

        <div class="row g-4 mb-4" aria-label="Entidades administráveis">
            {% for item in resources %}
                <div class="col-12 col-md-6 col-xl-3">
                    <article class="data-management-card p-4">
                        <div class="d-flex justify-content-between align-items-start gap-3 mb-3">
                            <div class="data-management-icon">
                                <twig:ux:icon name="{{ item.icon }}" />
                            </div>
                            <span class="badge rounded-pill text-bg-light text-primary">{{ item.singular }}</span>
                        </div>
                        <h2 class="h4 mb-2">{{ item.label }}</h2>
                        <p class="text-secondary small mb-4">{{ item.description }}</p>
                        <p class="data-management-card__total mb-1">{{ item.total }}</p>
                        <p class="text-secondary small mb-3">{{ item.needsReview }} registros com necessidade de revisão{% if item.inactive > 0 %} e {{ item.inactive }} inativos{% endif %}.</p>
                        <a class="btn btn-outline-primary w-100" href="{{ path('app_admin_resource_index', {resource: item.resource}) }}">Gerenciar</a>
                    </article>
                </div>
            {% endfor %}
        </div>

        <div class="row g-4">
            <div class="col-lg-8">
                <div class="data-management-panel p-4 h-100">
                    <span class="badge rounded-pill text-bg-light text-primary mb-2">Modelo operacional</span>
                    <h2 class="h3 mb-3">Governança humana articulada com automação</h2>
                    <div class="row g-3">
                        <div class="col-md-6">
                            <div class="data-management-stat p-3 h-100">
                                <div class="d-flex align-items-center gap-3 mb-3">
                                    <div class="data-management-stat__icon"><twig:ux:icon name="tabler:edit" /></div>
                                    <div>
                                        <p class="small text-uppercase fw-semibold text-muted mb-1">CRUD administrativo</p>
                                        <p class="mb-0 fw-semibold">Manutenção manual confiável</p>
                                    </div>
                                </div>
                                <p class="text-secondary mb-0">Ajustes finos, curadoria editorial, correção de cadastros e exclusão segura em interface visual baseada em Symfony, Twig e Doctrine.</p>
                            </div>
                        </div>
                        <div class="col-md-6">
                            <div class="data-management-stat p-3 h-100">
                                <div class="d-flex align-items-center gap-3 mb-3">
                                    <div class="data-management-stat__icon"><twig:ux:icon name="tabler:sparkles" /></div>
                                    <div>
                                        <p class="small text-uppercase fw-semibold text-muted mb-1">Higienização</p>
                                        <p class="mb-0 fw-semibold">Qualidade operacional visível</p>
                                    </div>
                                </div>
                                <p class="text-secondary mb-0">Indicadores e badges evidenciam registros incompletos, sem fonte, sem geolocalização ou com necessidade de revisão.</p>
                            </div>
                        </div>
                        <div class="col-md-6">
                            <div class="data-management-stat p-3 h-100">
                                <div class="d-flex align-items-center gap-3 mb-3">
                                    <div class="data-management-stat__icon"><twig:ux:icon name="tabler:api" /></div>
                                    <div>
                                        <p class="small text-uppercase fw-semibold text-muted mb-1">API interna</p>
                                        <p class="mb-0 fw-semibold">Integração e automação</p>
                                    </div>
                                </div>
                                <p class="text-secondary mb-0">A API interna continua dedicada a integrações e operações sistêmicas, sem substituir a manutenção humana das bases turísticas.</p>
                            </div>
                        </div>
                        <div class="col-md-6">
                            <div class="data-management-stat p-3 h-100">
                                <div class="d-flex align-items-center gap-3 mb-3">
                                    <div class="data-management-stat__icon"><twig:ux:icon name="tabler:world-code" /></div>
                                    <div>
                                        <p class="small text-uppercase fw-semibold text-muted mb-1">API pública</p>
                                        <p class="mb-0 fw-semibold">Dados abertos somente leitura</p>
                                    </div>
                                </div>
                                <p class="text-secondary mb-0">A camada pública permanece voltada à transparência e ao consumo externo, restrita a leitura e sem funções de cadastro ou revisão editorial.</p>
                            </div>
                        </div>
                    </div>
                </div>
            </div>
            <div class="col-lg-4">
                <div class="data-management-panel p-4 h-100">
                    <span class="badge rounded-pill text-bg-light text-primary mb-2">Ações rápidas</span>
                    <h2 class="h3 mb-3">Ações rápidas</h2>
                    <p class="text-secondary mb-4">Atalhos para o fluxo operacional mais frequente da curadoria e manutenção manual.</p>
                    <div class="d-grid gap-2">
                        {% for action in quickActions %}
                            <a class="btn btn-{{ action.tone }} text-start" href="{{ path(action.route, action.params) }}">
                                <twig:ux:icon name="{{ action.icon }}" /> {{ action.label }}
                            </a>
                        {% endfor %}
                    </div>
                </div>
            </div>
        </div>
    </section>
{% endblock %}