{# Generated by GitHub Copilot #}
{% extends 'base.html.twig' %}

{% block title %}{{ registry.getDisplayTitle(entity, metadata) }} | Gestão de Dados{% endblock %}

{% block stylesheets %}
    {{ parent() }}
    {% include 'admin/data_management/_styles.html.twig' %}
{% endblock %}

{% block body %}
    <section class="py-4 py-lg-5">
        {% set statusBadge = registry.getStatusBadge(entity, metadata) %}
        {% set qualityBadges = registry.getQualityBadges(entity, metadata) %}
        {% set entityId = attribute(entity, 'id') is defined and attribute(entity, 'id') is not null ? attribute(entity, 'id') : entity.getId() %}

        <div class="data-management-hero p-4 p-lg-5 mb-4">
            <div class="d-flex justify-content-between align-items-start gap-3 flex-wrap">
                <div>
                    <span class="badge rounded-pill text-bg-light text-primary mb-3">{{ metadata.singular }}</span>
                    <h1 class="display-6 fw-bold mb-3">{{ registry.getDisplayTitle(entity, metadata) }}</h1>
                    <p class="lead mb-3">{{ registry.getSummary(entity, metadata) }}</p>
                    <div class="d-flex flex-wrap gap-2 align-items-center">
                        {% if statusBadge %}
                            <span class="data-management-quality-badge data-management-quality-badge--{{ statusBadge.tone }}">{{ statusBadge.label }}</span>
                        {% endif %}
                        {% include 'admin/data_management/_quality_badges.html.twig' with {badges: qualityBadges} only %}
                    </div>
                </div>
                <div class="d-flex gap-2 flex-wrap">
                    <a class="btn btn-light" href="{{ path('app_admin_resource_index', {resource: resource}) }}">Voltar à listagem</a>
                    <a class="btn btn-primary" href="{{ path('app_admin_resource_edit', {resource: resource, id: entityId}) }}">Editar</a>
                </div>
            </div>
        </div>

        <div class="row g-4">
            <div class="col-lg-8">
                <div class="data-management-panel p-4 h-100">
                    <span class="badge rounded-pill text-bg-light text-primary mb-2">Detalhes do registro</span>
                    <h2 class="h3 mb-4">Informações completas</h2>
                    <dl class="data-management-detail-grid mb-0">
                        {% for row in detailRows %}
                            <div class="data-management-detail-item">
                                <dt>{{ row.label }}</dt>
                                <dd>{{ row.value }}</dd>
                            </div>
                        {% endfor %}
                    </dl>
                </div>
            </div>
            <div class="col-lg-4">
                <div class="data-management-panel p-4 h-100">
                    <span class="badge rounded-pill text-bg-light text-primary mb-2">Ações</span>
                    <h2 class="h3 mb-3">Fluxo operacional</h2>
                    <div class="d-grid gap-2 mb-4">
                        <a class="btn btn-primary" href="{{ path('app_admin_resource_edit', {resource: resource, id: entityId}) }}">Editar registro</a>
                        <a class="btn btn-outline-primary" href="{{ path('app_admin_resource_new', {resource: resource}) }}">Novo {{ metadata.singular|lower }}</a>
                    </div>
                    <form method="post" action="{{ path('app_admin_resource_delete', {resource: resource, id: entityId}) }}" onsubmit="return confirm('Confirma a exclusão deste registro?');">
                        <input type="hidden" name="_token" value="{{ csrf_token('delete_' ~ resource ~ '_' ~ entityId) }}">
                        <button type="submit" class="btn btn-outline-danger w-100">Excluir registro</button>
                    </form>
                </div>
            </div>
        </div>
    </section>
{% endblock %}