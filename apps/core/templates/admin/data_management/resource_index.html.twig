{# Generated by GitHub Copilot #}
{% extends 'base.html.twig' %}

{% block title %}{{ metadata.label }} | Gestão de Dados{% endblock %}

{% block stylesheets %}
    {{ parent() }}
    {% include 'admin/data_management/_styles.html.twig' %}
{% endblock %}

{% block body %}
    <section class="py-4 py-lg-5">
        <div class="data-management-hero p-4 p-lg-5 mb-4">
            <div class="d-flex justify-content-between align-items-start gap-3 flex-wrap">
                <div>
                    <span class="badge rounded-pill text-bg-light text-primary mb-3">{{ metadata.singular }}</span>
                    <h1 class="display-6 fw-bold mb-3">{{ metadata.label }}</h1>
                    <p class="lead mb-0">Listagem administrativa para manutenção manual, revisão editorial e higienização da base.</p>
                </div>
                <div class="d-flex gap-2 flex-wrap">
                    <a class="btn btn-light" href="{{ path('app_admin_data_management') }}">Voltar ao painel</a>
                    <a class="btn btn-primary" href="{{ path('app_admin_resource_new', {resource: resource}) }}">Novo</a>
                </div>
            </div>
        </div>

        <div class="data-management-panel p-4 mb-4">
            <form method="get" class="row g-3 align-items-end">
                <div class="col-md-6 col-xl-5">
                    <label class="form-label" for="q">Busca simples</label>
                    <input id="q" name="q" type="search" class="form-control" value="{{ search }}" placeholder="Pesquisar por nome, título ou texto associado">
                </div>
                {% if registry.supportsActiveFilter(metadata) %}
                    <div class="col-md-3 col-xl-2">
                        <label class="form-label" for="status">Status</label>
                        <select id="status" name="status" class="form-select">
                            <option value="">Todos</option>
                            <option value="active" {{ status == 'active' ? 'selected' }}>Ativos</option>
                            <option value="inactive" {{ status == 'inactive' ? 'selected' }}>Inativos</option>
                        </select>
                    </div>
                {% endif %}
                <div class="col-md-3 col-xl-2">
                    <label class="form-label" for="quality">Higienização</label>
                    <select id="quality" name="quality" class="form-select">
                        <option value="">Todos</option>
                        {% for key, label in qualityFilters %}
                            <option value="{{ key }}" {{ quality == key ? 'selected' }}>{{ label }}</option>
                        {% endfor %}
                    </select>
                </div>
                <div class="col-md-12 col-xl-3 d-flex gap-2">
                    <button type="submit" class="btn btn-primary flex-grow-1">Filtrar</button>
                    <a class="btn btn-outline-secondary" href="{{ path('app_admin_resource_index', {resource: resource}) }}">Limpar</a>
                </div>
            </form>
        </div>

        <div class="d-flex flex-wrap gap-2 mb-4" aria-label="Indicadores de higienização">
            {% for key, label in qualityFilters %}
                <a class="btn btn-sm {{ quality == key ? 'btn-primary' : 'btn-outline-primary' }} data-management-filter-pill" href="{{ path('app_admin_resource_index', {resource: resource, q: search, status: status, quality: key}) }}">{{ label }} <span class="badge text-bg-light ms-1">{{ attribute(qualityCounts, key)|default(0) }}</span></a>
            {% endfor %}
        </div>

        <div class="data-management-table-card p-3 p-lg-4">
            <div class="table-responsive">
                <table class="table align-middle mb-0">
                    <thead>
                        <tr>
                            <th scope="col">Registro</th>
                            <th scope="col">Resumo</th>
                            <th scope="col">Status</th>
                            <th scope="col">Higienização</th>
                            <th scope="col" class="text-end">Ações</th>
                        </tr>
                    </thead>
                    <tbody>
                        {% for entity in paginator.results %}
                            {% set statusBadge = registry.getStatusBadge(entity, metadata) %}
                            {% set qualityBadges = registry.getQualityBadges(entity, metadata) %}
                            {% set entityId = attribute(entity, 'id') is defined and attribute(entity, 'id') is not null ? attribute(entity, 'id') : entity.getId() %}
                            <tr>
                                <td>
                                    <div class="fw-semibold">{{ registry.getDisplayTitle(entity, metadata) }}</div>
                                    <div class="small text-secondary">ID #{{ entityId }}</div>
                                </td>
                                <td class="text-secondary">{{ registry.getSummary(entity, metadata) }}</td>
                                <td>
                                    {% if statusBadge %}
                                        <span class="data-management-quality-badge data-management-quality-badge--{{ statusBadge.tone }}">{{ statusBadge.label }}</span>
                                    {% else %}
                                        <span class="text-muted small">Sem status específico</span>
                                    {% endif %}
                                </td>
                                <td>{% include 'admin/data_management/_quality_badges.html.twig' with {badges: qualityBadges} only %}</td>
                                <td>
                                    <div class="d-flex justify-content-end gap-2 flex-wrap">
                                        <a class="btn btn-sm btn-outline-primary" href="{{ path('app_admin_resource_show', {resource: resource, id: entityId}) }}">Ver detalhes</a>
                                        <a class="btn btn-sm btn-outline-secondary" href="{{ path('app_admin_resource_edit', {resource: resource, id: entityId}) }}">Editar</a>
                                        <form method="post" action="{{ path('app_admin_resource_delete', {resource: resource, id: entityId}) }}" onsubmit="return confirm('Confirma a exclusão deste registro?');">
                                            <input type="hidden" name="_token" value="{{ csrf_token('delete_' ~ resource ~ '_' ~ entityId) }}">
                                            <button type="submit" class="btn btn-sm btn-outline-danger">Excluir</button>
                                        </form>
                                    </div>
                                </td>
                            </tr>
                        {% else %}
                            <tr>
                                <td colspan="5" class="text-center py-5 text-secondary">Nenhum registro encontrado para os filtros selecionados.</td>
                            </tr>
                        {% endfor %}
                    </tbody>
                </table>
            </div>

            {% if paginator.hasToPaginate %}
                <nav class="mt-4" aria-label="Paginação da listagem">
                    <ul class="pagination mb-0 justify-content-end">
                        <li class="page-item {{ not paginator.hasPreviousPage ? 'disabled' }}">
                            <a class="page-link" href="{{ path('app_admin_resource_index', {resource: resource, q: search, status: status, quality: quality, page: paginator.previousPage}) }}">Anterior</a>
                        </li>
                        <li class="page-item disabled"><span class="page-link">Página {{ paginator.currentPage }} de {{ paginator.lastPage }}</span></li>
                        <li class="page-item {{ not paginator.hasNextPage ? 'disabled' }}">
                            <a class="page-link" href="{{ path('app_admin_resource_index', {resource: resource, q: search, status: status, quality: quality, page: paginator.nextPage}) }}">Próxima</a>
                        </li>
                    </ul>
                </nav>
            {% endif %}
        </div>
    </section>
{% endblock %}