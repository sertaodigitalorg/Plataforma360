{% extends 'base.html.twig' %}
{% block title %}Prompts de IA — Plataforma360{% endblock %}
{% block body %}
<div class="container-fluid py-4">
    <div class="row align-items-center mb-4">
        <div class="col">
            <h1 class="h3 fw-bold mb-1"><i class="bi bi-chat-quote text-teal me-2"></i>Registro de Prompts</h1>
            <p class="text-muted small mb-0">Templates de prompts reutilizáveis para as funcionalidades de IA</p>
        </div>
        <div class="col-auto">
            <a href="{{ path('app_admin_ai_prompts_new') }}" class="btn btn-sm btn-primary"><i class="bi bi-plus me-1"></i>Novo Prompt</a>
        </div>
    </div>

    {% for msg in app.flashes('success') %}
        <div class="alert alert-success alert-dismissible fade show"><i class="bi bi-check-circle me-2"></i>{{ msg }}<button type="button" class="btn-close" data-bs-dismiss="alert"></button></div>
    {% endfor %}

    <div class="card border-0 shadow-sm rounded-3">
        <div class="table-responsive">
            <table class="table table-hover mb-0 align-middle">
                <thead class="table-light">
                    <tr>
                        <th class="ps-4">Nome</th>
                        <th>Purpose</th>
                        <th>Contexto</th>
                        <th>Versão</th>
                        <th>Status</th>
                        <th class="pe-4">Ações</th>
                    </tr>
                </thead>
                <tbody>
                {% if prompts is empty %}
                    <tr><td colspan="6" class="text-center py-5 text-muted">
                        <i class="bi bi-chat-quote fs-2 d-block mb-2"></i>Nenhum prompt cadastrado.
                    </td></tr>
                {% else %}
                    {% for prompt in prompts %}
                    <tr>
                        <td class="ps-4">
                            <div class="fw-semibold small">{{ prompt.name }}</div>
                            <small class="text-muted">{{ prompt.slug }}</small>
                        </td>
                        <td><span class="badge bg-light text-dark border small">{{ prompt.purpose }}</span></td>
                        <td class="small text-muted">{{ prompt.contextType ?? '—' }}</td>
                        <td><span class="badge bg-secondary">v{{ prompt.version }}</span></td>
                        <td><span class="badge {% if prompt.isActive %}bg-success{% else %}bg-secondary{% endif %}">{{ prompt.isActive ? 'Ativo' : 'Inativo' }}</span></td>
                        <td class="pe-4">
                            <div class="d-flex gap-1">
                                <a href="{{ path('app_admin_ai_prompts_edit', {id: prompt.id}) }}" class="btn btn-sm btn-outline-primary"><i class="bi bi-pencil"></i></a>
                                <form method="post" action="{{ path('app_admin_ai_prompts_delete', {id: prompt.id}) }}" class="d-inline" onsubmit="return confirm('Remover prompt?')">
                                    <button class="btn btn-sm btn-outline-danger"><i class="bi bi-trash"></i></button>
                                </form>
                            </div>
                        </td>
                    </tr>
                    {% endfor %}
                {% endif %}
                </tbody>
            </table>
        </div>
    </div>
</div>
{% endblock %}
