{% extends 'base.html.twig' %}
{% block title %}{{ mode == 'new' ? 'Novo Prompt' : 'Editar Prompt' }} — IA — Plataforma360{% endblock %}
{% block body %}
<div class="container-fluid py-4">
    <nav aria-label="breadcrumb" class="mb-3">
        <ol class="breadcrumb small">
            <li class="breadcrumb-item"><a href="{{ path('app_admin_ai_prompts') }}">Prompts</a></li>
            <li class="breadcrumb-item active">{{ mode == 'new' ? 'Novo' : 'Editar' }}</li>
        </ol>
    </nav>
    <h1 class="h4 fw-bold mb-4"><i class="bi bi-chat-quote me-2 text-teal"></i>{{ mode == 'new' ? 'Novo Prompt' : 'Editar: ' ~ prompt.name }}</h1>
    <div class="row"><div class="col-lg-9">
        <div class="card border-0 shadow-sm rounded-3">
            <div class="card-body p-4">
                <form method="post">
                    <div class="row g-3">
                        <div class="col-md-6">
                            <label class="fw-semibold small mb-1">Nome *</label>
                            <input type="text" name="name" class="form-control rounded-3" value="{{ prompt.name }}" required>
                        </div>
                        <div class="col-md-6">
                            <label class="fw-semibold small mb-1">Slug *</label>
                            <input type="text" name="slug" class="form-control rounded-3" value="{{ prompt.slug }}" required>
                        </div>
                        <div class="col-md-6">
                            <label class="fw-semibold small mb-1">Purpose</label>
                            <select name="purpose" class="form-select rounded-3">
                                {% set purposes = ['indicator_analysis','report_generation','dataset_explanation','executive_summary','territorial_comparison','data_quality_diagnosis','general_assistant','nl_to_sql'] %}
                                {% for p in purposes %}
                                <option value="{{ p }}" {% if prompt.purpose == p %}selected{% endif %}>{{ p }}</option>
                                {% endfor %}
                            </select>
                        </div>
                        <div class="col-md-3">
                            <label class="fw-semibold small mb-1">Contexto</label>
                            <input type="text" name="context_type" class="form-control rounded-3" value="{{ prompt.contextType }}">
                        </div>
                        <div class="col-md-3">
                            <label class="fw-semibold small mb-1">Versão</label>
                            <input type="number" name="version" class="form-control rounded-3" value="{{ prompt.version ?? 1 }}" min="1">
                        </div>
                        <div class="col-12">
                            <label class="fw-semibold small mb-1">Template do Prompt *</label>
                            <textarea name="prompt_template" class="form-control rounded-3 font-monospace" rows="10" required>{{ prompt.promptTemplate }}</textarea>
                            <div class="form-text">Use <code>{{ '{{variavel}}' }}</code> para placeholders dinâmicos.</div>
                        </div>
                        <div class="col-md-4">
                            <div class="form-check form-switch mt-2">
                                <input class="form-check-input" type="checkbox" name="is_active" value="1" {% if prompt.isActive %}checked{% endif %}>
                                <label class="form-check-label small">Ativo</label>
                            </div>
                        </div>
                    </div>
                    <div class="d-flex gap-2 mt-4">
                        <button type="submit" class="btn btn-primary"><i class="bi bi-check-lg me-1"></i>{{ mode == 'new' ? 'Criar' : 'Salvar' }}</button>
                        <a href="{{ path('app_admin_ai_prompts') }}" class="btn btn-outline-secondary">Cancelar</a>
                    </div>
                </form>
            </div>
        </div>
    </div></div>
</div>
{% endblock %}
