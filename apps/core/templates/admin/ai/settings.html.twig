{% extends 'base.html.twig' %}
{% block title %}Configurações de IA — Plataforma360{% endblock %}
{% block body %}
<div class="container-fluid py-4">
    <h1 class="h3 fw-bold mb-4"><i class="bi bi-gear text-teal me-2"></i>Configurações de Inteligência Artificial</h1>

    <div class="row g-4">
        <div class="col-lg-4">
            <div class="card border-0 shadow-sm rounded-3">
                <div class="card-header bg-transparent border-0 pb-0 pt-3 px-4">
                    <h6 class="fw-semibold"><i class="bi bi-hdd-network me-1 text-success"></i>Ollama (Local)</h6>
                </div>
                <div class="card-body px-4 pb-4">
                    <div class="d-flex align-items-center gap-2 mb-3">
                        <span class="badge {% if ollama_available %}bg-success{% else %}bg-danger{% endif %} fs-7">
                            {{ ollama_available ? 'Online' : 'Offline' }}
                        </span>
                        <span class="small text-muted">http://ollama:11434</span>
                    </div>
                    {% if ollama_available %}
                        <p class="small text-success mb-2"><i class="bi bi-check-circle me-1"></i>Ollama acessível</p>
                        {% if ollama_models is not empty %}
                        <p class="fw-semibold small mb-1">Modelos instalados:</p>
                        <ul class="list-unstyled small">
                            {% for m in ollama_models %}<li><code>{{ m }}</code></li>{% endfor %}
                        </ul>
                        {% else %}
                        <p class="small text-muted">Nenhum modelo instalado. Execute:<br><code>docker compose exec ollama ollama pull llama3</code></p>
                        {% endif %}
                    {% else %}
                        <p class="small text-muted mb-2">Ollama não está acessível. Inicie com:</p>
                        <code class="small d-block">docker compose up -d ollama</code>
                    {% endif %}
                </div>
            </div>
        </div>
        <div class="col-lg-8">
            <div class="card border-0 shadow-sm rounded-3">
                <div class="card-header bg-transparent border-0 pb-0 pt-3 px-4">
                    <h6 class="fw-semibold"><i class="bi bi-speedometer2 me-1 text-primary"></i>Resumo da Configuração</h6>
                </div>
                <div class="card-body px-4 pb-4">
                    <div class="row g-3">
                        <div class="col-sm-3 text-center">
                            <div class="fs-3 fw-bold text-primary">{{ models|length }}</div>
                            <div class="small text-muted">Modelos</div>
                        </div>
                        <div class="col-sm-3 text-center">
                            <div class="fs-3 fw-bold text-success">{{ stats.total|number_format }}</div>
                            <div class="small text-muted">Consultas</div>
                        </div>
                        <div class="col-sm-3 text-center">
                            <div class="fs-3 fw-bold text-warning">{{ stats.external|number_format }}</div>
                            <div class="small text-muted">Externas</div>
                        </div>
                        <div class="col-sm-3 text-center">
                            <div class="fs-3 fw-bold">{{ stats.total_tokens|number_format }}</div>
                            <div class="small text-muted">Tokens</div>
                        </div>
                    </div>
                    <hr>
                    <div class="d-flex flex-wrap gap-2">
                        <a href="{{ path('app_admin_ai_models') }}" class="btn btn-sm btn-outline-primary"><i class="bi bi-cpu me-1"></i>Gerenciar Modelos</a>
                        <a href="{{ path('app_admin_ai_prompts') }}" class="btn btn-sm btn-outline-secondary"><i class="bi bi-chat-quote me-1"></i>Prompts</a>
                        <a href="{{ path('app_admin_ai_contexts') }}" class="btn btn-sm btn-outline-secondary"><i class="bi bi-layers me-1"></i>Contextos</a>
                        <a href="{{ path('app_admin_ai_agents') }}" class="btn btn-sm btn-outline-secondary"><i class="bi bi-person-gear me-1"></i>Agentes</a>
                        <a href="{{ path('app_admin_ai_logs') }}" class="btn btn-sm btn-outline-secondary"><i class="bi bi-clock-history me-1"></i>Logs</a>
                    </div>
                </div>
            </div>
        </div>
    </div>
</div>
{% endblock %}
