{% extends 'base.html.twig' %}
{% block title %}Execuções de Pipelines{% endblock %}
{% block body %}
<div class="container-fluid py-4">
  <div class="d-flex justify-content-between align-items-center mb-4">
    <h1 class="h3 fw-bold mb-0"><i class="bi bi-clock-history text-teal me-2"></i>Execuções de Pipelines</h1>
    <a href="{{ path('app_admin_operations_overview') }}" class="btn btn-outline-secondary btn-sm">← Operações</a>
  </div>

  <div class="card border-0 shadow-sm rounded-3">
    <div class="card-body p-0">
      <table class="table table-hover mb-0 align-middle">
        <thead class="table-light">
          <tr><th>#</th><th>Pipeline</th><th>Status</th><th>Trigger</th><th>Iniciado por</th><th>Início</th><th>Duração</th><th></th></tr>
        </thead>
        <tbody>
        {% for exec in executions %}
        <tr>
          <td><small class="text-muted font-monospace">{{ exec.id }}</small></td>
          <td><small>{{ exec.pipeline ? exec.pipeline.name : '—' }}</small></td>
          <td>
            <span class="badge bg-{% if exec.status == 'SUCCESS' %}success{% elseif exec.status == 'FAILED' %}danger{% elseif exec.status == 'RUNNING' %}primary{% elseif exec.status == 'CANCELLED' %}secondary{% else %}info text-dark{% endif %}">
              {{ exec.status }}
            </span>
          </td>
          <td><span class="badge bg-secondary">{{ exec.triggerType }}</span></td>
          <td><small>{{ exec.triggeredBy ?? '—' }}</small></td>
          <td><small class="text-muted">{{ exec.startedAt ? exec.startedAt|date('d/m/Y H:i') : '—' }}</small></td>
          <td><small>{{ exec.durationMs ? (exec.durationMs / 1000)|number_format(1) ~ 's' : '—' }}</small></td>
          <td>
            <a href="{{ path('app_admin_operations_execution_detail', {id: exec.id}) }}" class="btn btn-sm btn-outline-secondary">
              <i class="bi bi-eye"></i>
            </a>
          </td>
        </tr>
        {% else %}
        <tr><td colspan="8" class="text-center py-4 text-muted">Nenhuma execução registrada.</td></tr>
        {% endfor %}
        </tbody>
      </table>
    </div>
    {% if total > limit %}
    <div class="card-footer bg-white border-0 py-3 d-flex justify-content-between align-items-center">
      <small class="text-muted">{{ total }} execuções · página {{ page }}</small>
      <div class="btn-group btn-group-sm">
        {% if page > 1 %}<a href="?page={{ page - 1 }}" class="btn btn-outline-secondary">← Anterior</a>{% endif %}
        {% if (page * limit) < total %}<a href="?page={{ page + 1 }}" class="btn btn-outline-secondary">Próxima →</a>{% endif %}
      </div>
    </div>
    {% endif %}
  </div>
</div>
{% endblock %}
