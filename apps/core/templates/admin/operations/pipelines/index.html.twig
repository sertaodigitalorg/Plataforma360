{% extends 'base.html.twig' %}
{% block title %}Pipelines{% endblock %}
{% block content %}
<div class="container-fluid py-4">
  <div class="d-flex align-items-center justify-content-between mb-4">
    <div>
      <h1 class="h3 fw-bold mb-1"><i class="bi bi-diagram-3 text-teal me-2"></i>Pipelines</h1>
      <p class="text-muted mb-0">Orquestração de fluxos de dados via Kestra</p>
    </div>
    <a href="{{ path('app_admin_operations_pipelines_new') }}" class="btn btn-teal">
      <i class="bi bi-plus-circle me-1"></i>Novo Pipeline
    </a>
  </div>

  {% for msg in app.flashes('success') %}<div class="alert alert-success alert-dismissible fade show"><i class="bi bi-check-circle me-2"></i>{{ msg }}<button type="button" class="btn-close" data-bs-dismiss="alert"></button></div>{% endfor %}
  {% for msg in app.flashes('warning') %}<div class="alert alert-warning alert-dismissible fade show">{{ msg }}<button type="button" class="btn-close" data-bs-dismiss="alert"></button></div>{% endfor %}

  <div class="card border-0 shadow-sm rounded-3">
    <div class="card-body p-0">
      <table class="table table-hover mb-0 align-middle">
        <thead class="table-light">
          <tr>
            <th>Nome</th><th>Tipo</th><th>Trigger</th><th>Status</th><th>Última Execução</th><th>Falhas</th><th>Ações</th>
          </tr>
        </thead>
        <tbody>
        {% for pipeline in pipelines %}
        <tr>
          <td>
            <div class="fw-semibold">{{ pipeline.name }}</div>
            <small class="text-muted font-monospace">{{ pipeline.slug }}</small>
          </td>
          <td><span class="badge bg-secondary">{{ pipeline.type }}</span></td>
          <td><span class="badge bg-info text-dark">{{ pipeline.triggerType }}</span></td>
          <td>
            {% if pipeline.isActive %}
              <span class="badge bg-success">Ativo</span>
            {% else %}
              <span class="badge bg-warning text-dark">Pausado</span>
            {% endif %}
            {% if pipeline.lastExecutionStatus %}
              <span class="badge bg-{% if pipeline.lastExecutionStatus == 'SUCCESS' %}success{% elseif pipeline.lastExecutionStatus == 'FAILED' %}danger{% else %}secondary{% endif %} ms-1">
                {{ pipeline.lastExecutionStatus }}
              </span>
            {% endif %}
          </td>
          <td><small class="text-muted">{{ pipeline.lastExecutedAt ? pipeline.lastExecutedAt|date('d/m/Y H:i') : 'Nunca' }}</small></td>
          <td>
            {% if pipeline.failureCount > 0 %}
              <span class="badge bg-danger">{{ pipeline.failureCount }}</span>
            {% else %}
              <span class="text-muted">0</span>
            {% endif %}
          </td>
          <td>
            <div class="btn-group btn-group-sm">
              <form method="post" action="{{ path('app_admin_operations_pipelines_trigger', {id: pipeline.id}) }}" class="d-inline">
                <button class="btn btn-success btn-sm" title="Executar agora" onclick="return confirm('Executar pipeline agora?')">
                  <i class="bi bi-play-fill"></i>
                </button>
              </form>
              <a href="{{ path('app_admin_operations_pipelines_edit', {id: pipeline.id}) }}" class="btn btn-outline-secondary btn-sm"><i class="bi bi-pencil"></i></a>
              <a href="{{ path('app_admin_operations_pipelines_yaml', {id: pipeline.id}) }}" class="btn btn-outline-secondary btn-sm" title="YAML"><i class="bi bi-code-slash"></i></a>
              <form method="post" action="{{ path('app_admin_operations_pipelines_pause', {id: pipeline.id}) }}" class="d-inline">
                <button class="btn btn-{% if pipeline.isActive %}warning{% else %}secondary{% endif %} btn-sm" title="{% if pipeline.isActive %}Pausar{% else %}Reativar{% endif %}">
                  <i class="bi bi-{% if pipeline.isActive %}pause-fill{% else %}play-fill{% endif %}"></i>
                </button>
              </form>
              <form method="post" action="{{ path('app_admin_operations_pipelines_delete', {id: pipeline.id}) }}" class="d-inline">
                <button class="btn btn-outline-danger btn-sm" onclick="return confirm('Remover pipeline?')"><i class="bi bi-trash"></i></button>
              </form>
            </div>
          </td>
        </tr>
        {% else %}
        <tr><td colspan="7" class="text-center py-4 text-muted">Nenhum pipeline cadastrado ainda.</td></tr>
        {% endfor %}
        </tbody>
      </table>
    </div>
  </div>
</div>
{% endblock %}
