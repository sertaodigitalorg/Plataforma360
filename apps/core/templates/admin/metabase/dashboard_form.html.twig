{# Generated by GitHub Copilot #}
{% extends 'base.html.twig' %}

{% block title %}{{ dashboard ? 'Editar' : 'Registrar' }} Dashboard · Metabase · Plataforma360{% endblock %}

{% block main %}
<div class="mb-4">
    <nav aria-label="breadcrumb">
        <ol class="breadcrumb small mb-1">
            <li class="breadcrumb-item"><a href="{{ path('app_admin_metabase_dashboards') }}" class="text-decoration-none">Dashboards</a></li>
            <li class="breadcrumb-item active">{{ dashboard ? 'Editar' : 'Registrar' }}</li>
        </ol>
    </nav>
    <h1 class="h3 fw-bold mb-0" style="color:#0b3c5d;">{{ dashboard ? 'Editar Dashboard' : 'Registrar Dashboard' }}</h1>
</div>

<div class="row g-4">
    <div class="col-lg-8">
        <div class="card border-0 rounded-4 shadow-sm">
            <div class="card-body p-4">
                <form method="post">
                    <div class="row g-3">
                        <div class="col-12">
                            <label class="form-label fw-semibold small" for="name">Nome <span class="text-danger">*</span></label>
                            <input type="text" class="form-control rounded-3" id="name" name="name"
                                   value="{{ dashboard ? dashboard.name : '' }}" required
                                   placeholder="Ex: Agências de Turismo por Estado">
                        </div>
                        <div class="col-12">
                            <label class="form-label fw-semibold small" for="description">Descrição</label>
                            <textarea class="form-control rounded-3" id="description" name="description" rows="2"
                                      placeholder="Descreva o conteúdo deste dashboard">{{ dashboard ? dashboard.description : '' }}</textarea>
                        </div>
                        <div class="col-md-6">
                            <label class="form-label fw-semibold small" for="type">Tipo</label>
                            <select class="form-select rounded-3" id="type" name="type">
                                {% for t in types %}
                                    <option value="{{ t }}" {{ dashboard and dashboard.type == t ? 'selected' : '' }}>
                                        {{ t == 'dashboard' ? 'Dashboard' : 'Pergunta/Question' }}
                                    </option>
                                {% endfor %}
                            </select>
                        </div>
                        <div class="col-md-6">
                            <label class="form-label fw-semibold small" for="metabase_id">ID no Metabase</label>
                            <input type="number" class="form-control rounded-3" id="metabase_id" name="metabase_id"
                                   value="{{ dashboard ? dashboard.metabaseId : '' }}"
                                   placeholder="Ex: 42">
                        </div>
                        <div class="col-12">
                            <label class="form-label fw-semibold small" for="embed_url">URL de Embed</label>
                            <input type="url" class="form-control rounded-3" id="embed_url" name="embed_url"
                                   value="{{ dashboard ? dashboard.embedUrl : '' }}"
                                   placeholder="https://metabase.suaorg.gov.br/public/dashboard/...">
                            <div class="form-text">URL completa para incorporação via iframe, ou use o UUID público abaixo.</div>
                        </div>
                        <div class="col-md-6">
                            <label class="form-label fw-semibold small" for="public_uuid">UUID Público (Embed)</label>
                            <input type="text" class="form-control rounded-3" id="public_uuid" name="public_uuid"
                                   value="{{ dashboard ? dashboard.publicUuid : '' }}"
                                   placeholder="xxxxxxxx-xxxx-xxxx-xxxx-xxxxxxxxxxxx">
                        </div>
                        <div class="col-md-6">
                            <label class="form-label fw-semibold small" for="dataset">Dataset</label>
                            <input type="text" class="form-control rounded-3" id="dataset" name="dataset"
                                   value="{{ dashboard ? dashboard.dataset : '' }}"
                                   placeholder="Ex: warehouse.dw_turismo_agencias">
                        </div>
                        <div class="col-md-6">
                            <label class="form-label fw-semibold small" for="origin">Origem dos dados</label>
                            <input type="text" class="form-control rounded-3" id="origin" name="origin"
                                   value="{{ dashboard ? dashboard.origin : '' }}"
                                   placeholder="Ex: Cadastur / MTUR">
                        </div>
                        <div class="col-md-6 d-flex align-items-end">
                            <div class="w-100">
                                <div class="form-check form-switch">
                                    <input class="form-check-input" type="checkbox" id="allow_embed" name="allow_embed"
                                           {{ dashboard and dashboard.allowEmbed ? 'checked' : '' }}>
                                    <label class="form-check-label fw-semibold small" for="allow_embed">Permitir incorporação (iframe)</label>
                                </div>
                                {% if dashboard %}
                                    <div class="form-check form-switch mt-2">
                                        <input class="form-check-input" type="checkbox" id="is_active" name="is_active"
                                               {{ dashboard.active ? 'checked' : '' }}>
                                        <label class="form-check-label fw-semibold small" for="is_active">Dashboard ativo</label>
                                    </div>
                                {% endif %}
                            </div>
                        </div>
                    </div>

                    <div class="d-flex gap-2 mt-4">
                        <button type="submit" class="btn btn-primary rounded-3">
                            <i class="bi bi-check-lg me-1"></i> {{ dashboard ? 'Salvar alterações' : 'Registrar dashboard' }}
                        </button>
                        <a href="{{ path('app_admin_metabase_dashboards') }}" class="btn btn-outline-secondary rounded-3">Cancelar</a>
                    </div>
                </form>
            </div>
        </div>
    </div>

    <div class="col-lg-4">
        <div class="card border-0 rounded-4" style="background:linear-gradient(135deg,#fdf4ff,#fae8ff);">
            <div class="card-body p-4">
                <h6 class="fw-bold mb-3" style="color:#0b3c5d;"><i class="bi bi-code-slash me-2"></i>Como obter a URL de embed</h6>
                <ol class="text-muted small ps-3 mb-0">
                    <li class="mb-2">No Metabase, abra o dashboard</li>
                    <li class="mb-2">Clique em <strong>Compartilhar → Incorporar</strong></li>
                    <li class="mb-2">Copie a URL do iframe gerado</li>
                    <li class="mb-2">Cole no campo <strong>URL de Embed</strong> acima</li>
                    <li>Ou use o <strong>UUID público</strong> se disponível</li>
                </ol>
            </div>
        </div>
    </div>
</div>
{% endblock %}
