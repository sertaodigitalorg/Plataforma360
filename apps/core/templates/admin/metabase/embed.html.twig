{# Generated by GitHub Copilot #}
{% extends 'base.html.twig' %}

{% block title %}{{ dashboard.name }} · Dashboards · Plataforma360{% endblock %}

{% block main %}
<div class="d-flex align-items-center justify-content-between mb-4 flex-wrap gap-3">
    <div>
        <nav aria-label="breadcrumb">
            <ol class="breadcrumb small mb-1">
                <li class="breadcrumb-item"><a href="{{ path('app_admin_metabase_dashboards') }}" class="text-decoration-none">Dashboards</a></li>
                <li class="breadcrumb-item active">{{ dashboard.name }}</li>
            </ol>
        </nav>
        <h1 class="h4 fw-bold mb-0" style="color:#0b3c5d;">{{ dashboard.name }}</h1>
        {% if dashboard.description %}
            <p class="text-muted mb-0 small">{{ dashboard.description }}</p>
        {% endif %}
    </div>
    <div class="d-flex gap-2">
        <a href="{{ path('app_admin_metabase_dashboards_edit', {id: dashboard.id}) }}" class="btn btn-outline-secondary btn-sm rounded-3">
            <i class="bi bi-pencil me-1"></i> Editar
        </a>
        {% if embedUrl %}
            <a href="{{ embedUrl }}" target="_blank" class="btn btn-outline-primary btn-sm rounded-3">
                <i class="bi bi-box-arrow-up-right me-1"></i> Abrir no Metabase
            </a>
        {% endif %}
    </div>
</div>

{% if embedUrl %}
    <div class="card border-0 rounded-4 shadow-sm mb-4">
        <div class="card-body p-0 overflow-hidden rounded-4">
            <div class="d-flex align-items-center gap-3 p-3 border-bottom" style="background:#f8fafc;">
                <i class="bi bi-bar-chart-line text-primary"></i>
                <span class="fw-semibold small" style="color:#0b3c5d;">{{ dashboard.name }}</span>
                {% if dashboard.dataset %}
                    <span class="badge text-bg-light text-dark rounded-pill ms-auto small">{{ dashboard.dataset }}</span>
                {% endif %}
            </div>
            <div style="position:relative;overflow:hidden;">
                <iframe
                    src="{{ embedUrl }}"
                    frameborder="0"
                    allowtransparency="true"
                    style="width:100%;height:70vh;min-height:520px;border:0;"
                    title="{{ dashboard.name }}"
                    loading="lazy"
                ></iframe>
            </div>
        </div>
    </div>

    {# Metadata sidebar row #}
    <div class="row g-3">
        <div class="col-md-3">
            <div class="card border-0 rounded-4 p-3 text-center" style="background:linear-gradient(135deg,#fdf4ff,#fae8ff);">
                <div class="text-muted small mb-1">Tipo</div>
                <div class="fw-semibold small" style="color:#0b3c5d;">{{ dashboard.type == 'dashboard' ? 'Dashboard' : 'Pergunta' }}</div>
            </div>
        </div>
        <div class="col-md-3">
            <div class="card border-0 rounded-4 p-3 text-center" style="background:linear-gradient(135deg,#eff7fb,#e4f7f4);">
                <div class="text-muted small mb-1">Dataset</div>
                <div class="fw-semibold small" style="color:#0b3c5d;">{{ dashboard.dataset ?? '—' }}</div>
            </div>
        </div>
        <div class="col-md-3">
            <div class="card border-0 rounded-4 p-3 text-center" style="background:linear-gradient(135deg,#f0fdf4,#dcfce7);">
                <div class="text-muted small mb-1">Origem</div>
                <div class="fw-semibold small" style="color:#0b3c5d;">{{ dashboard.origin ?? '—' }}</div>
            </div>
        </div>
        <div class="col-md-3">
            <div class="card border-0 rounded-4 p-3 text-center" style="background:linear-gradient(135deg,#fefce8,#fef9c3);">
                <div class="text-muted small mb-1">Status</div>
                <div class="fw-semibold small {% if dashboard.status == 'active' %}text-success{% else %}text-muted{% endif %}">
                    {{ dashboard.status|capitalize }}
                </div>
            </div>
        </div>
    </div>

{% else %}
    <div class="card border-0 rounded-4 shadow-sm">
        <div class="card-body text-center py-5">
            <i class="bi bi-link-45deg fs-1 text-muted"></i>
            <h5 class="mt-3 mb-2" style="color:#0b3c5d;">URL de incorporação não configurada</h5>
            <p class="text-muted mb-4">
                Este dashboard não possui URL de embed ou UUID público.<br>
                Configure a URL no Metabase e atualize o cadastro.
            </p>
            <a href="{{ path('app_admin_metabase_dashboards_edit', {id: dashboard.id}) }}" class="btn btn-primary rounded-3">
                <i class="bi bi-pencil me-1"></i> Editar e adicionar URL
            </a>
        </div>
    </div>
{% endif %}
{% endblock %}
