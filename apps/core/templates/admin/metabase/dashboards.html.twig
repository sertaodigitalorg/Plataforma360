{# Generated by GitHub Copilot #}
{% extends 'base.html.twig' %}

{% block title %}Dashboards BI · Metabase · Plataforma360{% endblock %}

{% block main %}
<div class="data-management-hero p-4 p-lg-5 mb-4 rounded-4" style="background: linear-gradient(135deg, rgba(147,51,234,0.05) 0%, rgba(168,85,247,0.08) 100%); border: 1px solid rgba(147,51,234,0.12);">
    <div class="d-flex align-items-start gap-3 flex-wrap">
        <div class="flex-grow-1">
            <div class="d-flex align-items-center gap-2 mb-2">
                <span class="badge rounded-pill px-3 py-2" style="background:rgba(147,51,234,0.15);color:#9333ea;font-size:0.72rem;letter-spacing:0.06em;">BI & DASHBOARDS · METABASE</span>
            </div>
            <h1 class="h3 fw-bold mb-1" style="color:#0b3c5d;">Dashboards & BI</h1>
            <p class="text-muted mb-0" style="max-width:62ch;">Central de dashboards Metabase incorporados na plataforma de inteligência territorial.</p>
        </div>
        <div class="d-flex gap-2 flex-wrap">
            <a href="{{ path('app_admin_metabase_dashboards_new') }}" class="btn btn-primary rounded-3">
                <i class="bi bi-plus-lg me-1"></i> Registrar Dashboard
            </a>
            {% if config %}
                <form method="post" action="{{ path('app_admin_metabase_sync') }}">
                    <input type="hidden" name="_token" value="{{ csrf_token('metabase-sync') }}">
                    <button type="submit" class="btn btn-outline-secondary rounded-3">
                        <i class="bi bi-arrow-repeat me-1"></i> Sincronizar
                    </button>
                </form>
            {% endif %}
            <a href="{{ path('app_admin_metabase_config') }}" class="btn btn-outline-secondary rounded-3">
                <i class="bi bi-gear me-1"></i> Configurar
            </a>
        </div>
    </div>
</div>

{# Summary #}
<div class="row g-3 mb-4">
    <div class="col-4">
        <div class="card border-0 rounded-4 text-center py-3" style="background:linear-gradient(135deg,#fdf4ff,#fae8ff);">
            <div class="fw-bold fs-4" style="color:#0b3c5d;">{{ summary.total }}</div>
            <div class="text-muted small">Total</div>
        </div>
    </div>
    <div class="col-4">
        <div class="card border-0 rounded-4 text-center py-3" style="background:linear-gradient(135deg,#f0fdf4,#dcfce7);">
            <div class="fw-bold fs-4 text-success">{{ summary.active }}</div>
            <div class="text-muted small">Ativos</div>
        </div>
    </div>
    <div class="col-4">
        <div class="card border-0 rounded-4 text-center py-3" style="background:linear-gradient(135deg,#eff6ff,#dbeafe);">
            <div class="fw-bold fs-4 text-primary">{{ summary.embeddable }}</div>
            <div class="text-muted small">Com Embed</div>
        </div>
    </div>
</div>

{% if not config %}
    <div class="alert alert-warning rounded-4 mb-4">
        <i class="bi bi-exclamation-triangle me-2"></i>
        Metabase não configurado. <a href="{{ path('app_admin_metabase_config') }}" class="alert-link">Configure a conexão</a> antes de registrar dashboards.
    </div>
{% endif %}

{% if dashboards is empty %}
    <div class="card border-0 rounded-4 shadow-sm">
        <div class="card-body text-center py-5">
            <i class="bi bi-bar-chart-line fs-1 text-muted"></i>
            <h5 class="mt-3 mb-2" style="color:#0b3c5d;">Nenhum dashboard cadastrado</h5>
            <p class="text-muted mb-4">Registre dashboards do Metabase para incorporá-los na plataforma.</p>
            <a href="{{ path('app_admin_metabase_dashboards_new') }}" class="btn btn-primary rounded-3">
                <i class="bi bi-plus-lg me-1"></i> Registrar primeiro dashboard
            </a>
        </div>
    </div>
{% else %}
    <div class="card border-0 rounded-4 shadow-sm">
        <div class="card-body p-0">
            <div class="table-responsive">
                <table class="table table-hover align-middle mb-0">
                    <thead>
                        <tr class="text-muted small border-bottom" style="background:#f8fafc;">
                            <th class="px-4 py-3">Dashboard</th>
                            <th>Dataset</th>
                            <th>Origem</th>
                            <th>Tipo</th>
                            <th>Status</th>
                            <th>Embed</th>
                            <th>Atualizado</th>
                            <th>Ações</th>
                        </tr>
                    </thead>
                    <tbody>
                        {% for dashboard in dashboards %}
                        <tr>
                            <td class="px-4 py-3">
                                <div class="fw-semibold" style="color:#0b3c5d;">{{ dashboard.name }}</div>
                                <div class="text-muted small">{{ dashboard.description|default('')|slice(0,60) }}</div>
                            </td>
                            <td class="text-muted small">{{ dashboard.dataset ?? '—' }}</td>
                            <td class="text-muted small">{{ dashboard.origin ?? '—' }}</td>
                            <td>
                                <span class="badge text-bg-light text-dark rounded-pill">
                                    {{ dashboard.type == 'dashboard' ? 'Dashboard' : 'Pergunta' }}
                                </span>
                            </td>
                            <td>
                                {% if dashboard.status == 'active' %}
                                    <span class="badge text-bg-success rounded-pill">Ativo</span>
                                {% elseif dashboard.status == 'inactive' %}
                                    <span class="badge text-bg-secondary rounded-pill">Inativo</span>
                                {% else %}
                                    <span class="badge text-bg-warning text-dark rounded-pill">{{ dashboard.status }}</span>
                                {% endif %}
                            </td>
                            <td>
                                {% if dashboard.allowEmbed %}
                                    <span class="badge text-bg-primary rounded-pill"><i class="bi bi-code-slash me-1"></i>Sim</span>
                                {% else %}
                                    <span class="text-muted small">—</span>
                                {% endif %}
                            </td>
                            <td class="text-muted small">
                                {{ dashboard.metabaseUpdatedAt ? dashboard.metabaseUpdatedAt|date('d/m H:i') : (dashboard.updatedAt ? dashboard.updatedAt|date('d/m H:i') : '—') }}
                            </td>
                            <td>
                                <div class="d-flex gap-1 flex-wrap">
                                    {% if dashboard.embedUrl or dashboard.publicUuid %}
                                        <a href="{{ path('app_admin_metabase_dashboards_embed', {id: dashboard.id}) }}"
                                           class="btn btn-sm btn-primary rounded-3" title="Abrir dashboard incorporado">
                                            <i class="bi bi-eye-fill"></i>
                                        </a>
                                    {% endif %}
                                    <a href="{{ path('app_admin_metabase_dashboards_edit', {id: dashboard.id}) }}"
                                       class="btn btn-sm btn-outline-secondary rounded-3" title="Editar">
                                        <i class="bi bi-pencil"></i>
                                    </a>
                                    <form method="post" action="{{ path('app_admin_metabase_dashboards_delete', {id: dashboard.id}) }}"
                                          onsubmit="return confirm('Remover dashboard {{ dashboard.name }}?')">
                                        <input type="hidden" name="_token" value="{{ csrf_token('delete-dashboard-' ~ dashboard.id) }}">
                                        <button type="submit" class="btn btn-sm btn-outline-danger rounded-3" title="Remover">
                                            <i class="bi bi-trash3"></i>
                                        </button>
                                    </form>
                                </div>
                            </td>
                        </tr>
                        {% endfor %}
                    </tbody>
                </table>
            </div>
        </div>
    </div>
{% endif %}
{% endblock %}
