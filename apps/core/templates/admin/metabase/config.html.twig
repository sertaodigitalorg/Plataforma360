{# Generated by GitHub Copilot #}
{% extends 'base.html.twig' %}

{% block title %}Configuração Metabase · Integrações · Plataforma360{% endblock %}

{% block main %}
<div class="data-management-hero p-4 p-lg-5 mb-4 rounded-4" style="background: linear-gradient(135deg, rgba(147,51,234,0.05) 0%, rgba(168,85,247,0.08) 100%); border: 1px solid rgba(147,51,234,0.12);">
    <div class="d-flex align-items-start gap-3 flex-wrap">
        <div class="flex-grow-1">
            <div class="d-flex align-items-center gap-2 mb-2">
                <span class="badge rounded-pill px-3 py-2" style="background:rgba(147,51,234,0.15);color:#9333ea;font-size:0.72rem;letter-spacing:0.06em;">METABASE · INTEGRAÇÃO BI</span>
                {% if config and config.id %}
                    <span class="badge rounded-pill px-3 py-2 {% if config.connectionStatus == 'connected' %}text-bg-success{% elseif config.connectionStatus == 'failed' %}text-bg-danger{% else %}text-bg-secondary{% endif %}">
                        {{ config.connectionStatus == 'connected' ? 'Conectado' : (config.connectionStatus == 'failed' ? 'Falhou' : 'Não testado') }}
                    </span>
                {% endif %}
            </div>
            <h1 class="h3 fw-bold mb-1" style="color:#0b3c5d;">Configuração Metabase</h1>
            <p class="text-muted mb-0" style="max-width:62ch;">Configure a conexão com o Metabase para incorporar dashboards analíticos diretamente na Plataforma360.</p>
        </div>
        <div class="d-flex gap-2 flex-wrap">
            {% if config and config.id %}
                <form method="post" action="{{ path('app_admin_metabase_test_connection') }}" class="d-inline">
                    <input type="hidden" name="_token" value="{{ csrf_token('metabase-test') }}">
                    <button type="submit" class="btn btn-outline-primary rounded-3">
                        <i class="bi bi-wifi me-1"></i> Testar Conexão
                    </button>
                </form>
                <a href="{{ path('app_admin_metabase_dashboards') }}" class="btn btn-outline-secondary rounded-3">
                    <i class="bi bi-bar-chart-line me-1"></i> Ver Dashboards
                </a>
            {% endif %}
        </div>
    </div>
</div>

<div class="row g-4">
    <div class="col-lg-8">
        <div class="card border-0 rounded-4 shadow-sm">
            <div class="card-header bg-white border-0 rounded-top-4 pt-4 px-4 pb-2">
                <h5 class="fw-bold mb-0" style="color:#0b3c5d;"><i class="bi bi-gear me-2"></i>Configurações de Conexão</h5>
            </div>
            <div class="card-body p-4">
                <form method="post">
                    <div class="row g-3">
                        <div class="col-12">
                            <label class="form-label fw-semibold small" for="name">Nome da Instância</label>
                            <input type="text" class="form-control rounded-3" id="name" name="name"
                                   value="{{ config ? config.name : 'Metabase Principal' }}"
                                   placeholder="Ex: Metabase Produção">
                        </div>
                        <div class="col-12">
                            <label class="form-label fw-semibold small" for="base_url">URL Base do Metabase <span class="text-danger">*</span></label>
                            <input type="url" class="form-control rounded-3" id="base_url" name="base_url"
                                   value="{{ config ? config.baseUrl : '' }}"
                                   required placeholder="https://metabase.suaorg.gov.br">
                            <div class="form-text">Endereço completo da sua instância Metabase, sem barra final.</div>
                        </div>
                        <div class="col-md-6">
                            <label class="form-label fw-semibold small" for="database_name">Nome do Banco de Dados</label>
                            <input type="text" class="form-control rounded-3" id="database_name" name="database_name"
                                   value="{{ config ? config.databaseName : '' }}"
                                   placeholder="plataforma360_db">
                            <div class="form-text">Nome como cadastrado no Metabase.</div>
                        </div>
                        <div class="col-md-6">
                            <label class="form-label fw-semibold small" for="username">Usuário de Acesso</label>
                            <input type="text" class="form-control rounded-3" id="username" name="username"
                                   value="{{ config ? config.username : '' }}"
                                   placeholder="admin@example.com">
                        </div>
                        <div class="col-md-6">
                            <label class="form-label fw-semibold small" for="password">Senha <span class="text-muted small">(deixe vazio para manter)</span></label>
                            <input type="password" class="form-control rounded-3" id="password" name="password"
                                   autocomplete="new-password"
                                   placeholder="{% if config and config.passwordEncrypted %}••••••••{% else %}Senha do Metabase{% endif %}">
                        </div>
                        <div class="col-md-6">
                            <label class="form-label fw-semibold small" for="secret_key">Secret Key (Embed)</label>
                            <input type="password" class="form-control rounded-3" id="secret_key" name="secret_key"
                                   value="{{ config ? config.secretKey : '' }}"
                                   autocomplete="off"
                                   placeholder="Chave para embedding de dashboards públicos">
                            <div class="form-text">Necessária para incorporar dashboards via iframe.</div>
                        </div>
                        <div class="col-12">
                            <label class="form-label fw-semibold small" for="notes">Notas</label>
                            <textarea class="form-control rounded-3" id="notes" name="notes" rows="2"
                                      placeholder="Observações sobre esta configuração">{{ config ? config.notes : '' }}</textarea>
                        </div>
                    </div>

                    {% if config and config.lastTestedAt %}
                        <div class="alert alert-light rounded-3 mt-3 mb-0 small">
                            <i class="bi bi-info-circle me-1"></i>
                            Último teste: {{ config.lastTestedAt|date('d/m/Y H:i') }} ·
                            Status: <strong>{{ config.connectionStatus }}</strong>
                        </div>
                    {% endif %}

                    <div class="d-flex gap-2 mt-4">
                        <button type="submit" class="btn btn-primary rounded-3">
                            <i class="bi bi-check-lg me-1"></i> Salvar Configuração
                        </button>
                    </div>
                </form>
            </div>
        </div>
    </div>

    <div class="col-lg-4">
        <div class="card border-0 rounded-4" style="background:linear-gradient(135deg,#fdf4ff,#fae8ff);">
            <div class="card-body p-4">
                <h6 class="fw-bold mb-3" style="color:#0b3c5d;"><i class="bi bi-diagram-3 me-2"></i>Arquitetura</h6>
                <div class="d-flex flex-column gap-2">
                    {% for step in [
                        {icon: 'database-fill', label: 'PostgreSQL Warehouse', desc: 'schema warehouse.*'},
                        {icon: 'arrow-down', label: '', desc: ''},
                        {icon: 'bar-chart-line', label: 'Metabase', desc: 'Conexão direta ao banco'},
                        {icon: 'arrow-down', label: '', desc: ''},
                        {icon: 'buildings', label: 'Plataforma360', desc: 'Dashboards incorporados'},
                    ] %}
                        {% if step.icon == 'arrow-down' %}
                            <div class="text-center text-muted">↓</div>
                        {% else %}
                            <div class="d-flex align-items-center gap-2 p-2 rounded-3 bg-white bg-opacity-75">
                                <i class="bi bi-{{ step.icon }}" style="color:#9333ea;"></i>
                                <div>
                                    <div class="fw-semibold small" style="color:#0b3c5d;">{{ step.label }}</div>
                                    <div class="text-muted" style="font-size:0.75rem;">{{ step.desc }}</div>
                                </div>
                            </div>
                        {% endif %}
                    {% endfor %}
                </div>
            </div>
        </div>

        <div class="card border-0 rounded-4 mt-3" style="background:#f0fdf4;">
            <div class="card-body p-4">
                <h6 class="fw-bold mb-2" style="color:#14532d;"><i class="bi bi-lightbulb me-2"></i>Próximos passos</h6>
                <ol class="text-muted small ps-3 mb-0">
                    <li class="mb-1">Configure a URL e credenciais</li>
                    <li class="mb-1">Teste a conexão</li>
                    <li class="mb-1">Cadastre dashboards em <strong>Dashboards</strong></li>
                    <li>Incorpore via iframe nas páginas</li>
                </ol>
            </div>
        </div>
    </div>
</div>
{% endblock %}
