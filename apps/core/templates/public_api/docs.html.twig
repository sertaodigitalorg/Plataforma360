{# Generated by GitHub Copilot #}
{% extends 'base.html.twig' %}

{% block title %}API Pública | Olinda 360{% endblock %}

{% block stylesheets %}
    <style>
        .public-api-hero {
            background: linear-gradient(135deg, #083d3b 0%, #0f766e 55%, #ecfdf5 100%);
            border-radius: 1.5rem;
            color: #fff;
        }

        .public-api-card {
            background: #fff;
            border: 1px solid rgba(8, 61, 59, 0.08);
            border-radius: 1.25rem;
            box-shadow: 0 1rem 2rem rgba(8, 61, 59, 0.06);
        }

        .public-api-table thead th {
            background: #ecfdf5;
            color: #14532d;
            font-size: 0.82rem;
            letter-spacing: 0.03em;
            text-transform: uppercase;
        }

        .public-api-code {
            background: #0f172a;
            border-radius: 1rem;
            color: #e2e8f0;
            display: block;
            padding: 1rem 1.25rem;
        }
    </style>
{% endblock %}

{% block body %}
    <section class="py-4 py-lg-5" aria-labelledby="public-api-docs-title">
        <div class="public-api-hero p-4 p-lg-5 mb-4">
            <div class="row g-4 align-items-end">
                <div class="col-lg-8">
                    <span class="badge rounded-pill text-bg-light text-success mb-3">Dados Abertos</span>
                    <h1 id="public-api-docs-title" class="display-6 fw-bold mb-3">API Pública de Dados Abertos</h1>
                    <p class="lead mb-0">Camada pública e somente leitura do Olinda360 para aplicativos, pesquisadores, universidades, órgãos públicos, empreendedores e sociedade civil.</p>
                </div>
                <div class="col-lg-4 text-lg-end">
                    <div class="d-flex justify-content-lg-end gap-2 flex-wrap">
                        <a class="btn btn-light" href="/public-api/v1/status">Ver status</a>
                        <a class="btn btn-outline-light" href="/public-api/v1/openapi.json">OpenAPI JSON</a>
                    </div>
                </div>
            </div>
        </div>

        <div class="row g-4 mb-4">
            <div class="col-lg-8">
                <div class="public-api-card p-4 h-100">
                    <h2 class="h4 mb-3">Endpoints disponíveis</h2>
                    <div class="table-responsive">
                        <table class="table public-api-table align-middle mb-0">
                            <thead>
                                <tr>
                                    <th>Método</th>
                                    <th>Endpoint</th>
                                    <th>Descrição</th>
                                </tr>
                            </thead>
                            <tbody>
                                {% for endpoint in endpoints %}
                                    <tr>
                                        <td><span class="badge text-bg-success">{{ endpoint.method }}</span></td>
                                        <td><strong>{{ endpoint.path }}</strong></td>
                                        <td>{{ endpoint.description }}</td>
                                    </tr>
                                {% endfor %}
                            </tbody>
                        </table>
                    </div>
                </div>
            </div>
            <div class="col-lg-4">
                <div class="public-api-card p-4 mb-4">
                    <h2 class="h5 mb-3">Política de uso</h2>
                    <p class="text-secondary mb-0">Os dados são disponibilizados para uso público, com foco em transparência, inovação e pesquisa. A API pública é somente leitura e não expõe contatos privados, dados pessoais ou informações administrativas internas.</p>
                </div>
                <div class="public-api-card p-4">
                    <h2 class="h5 mb-3">Versionamento</h2>
                    <p class="text-secondary mb-0">Use sempre o prefixo <strong>/public-api/v1</strong>. Novas mudanças incompatíveis devem gerar uma nova versão, preservando estabilidade para consumidores externos.</p>
                </div>
            </div>
        </div>

        <div class="public-api-card p-4 mb-4">
            <div class="d-flex justify-content-between align-items-start gap-3 flex-wrap">
                <div>
                    <h2 class="h4 mb-2">Especificação OpenAPI</h2>
                    <p class="text-secondary mb-0">Uma especificação simplificada e separada da API pública está disponível em JSON para integração com portais, clientes HTTP e catálogos de dados abertos.</p>
                </div>
                <code class="public-api-code mb-0">GET /public-api/v1/openapi.json</code>
            </div>
        </div>

        <div class="row g-4">
            <div class="col-lg-6">
                <div class="public-api-card p-4 h-100">
                    <h2 class="h4 mb-3">Parâmetros aceitos</h2>
                    <ul class="list-group list-group-flush">
                        {% for parameter in parameters %}
                            <li class="list-group-item px-0 d-flex justify-content-between gap-3 flex-wrap">
                                <strong>{{ parameter.name }}</strong>
                                <span class="text-secondary text-end">{{ parameter.description }}</span>
                            </li>
                        {% endfor %}
                    </ul>
                </div>
            </div>
            <div class="col-lg-6">
                <div class="public-api-card p-4 h-100">
                    <h2 class="h4 mb-3">Exemplos de uso</h2>
                    {% for example in examples %}
                        <code class="public-api-code mb-3">GET {{ example }}</code>
                    {% endfor %}
                    <code class="public-api-code mb-0">GET /public-api/v1/openapi.json</code>
                </div>
            </div>
        </div>
    </section>
{% endblock %}