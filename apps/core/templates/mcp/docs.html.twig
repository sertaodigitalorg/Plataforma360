{# Generated by GitHub Copilot #}
{% extends 'base.html.twig' %}

{% block title %}MCP / IA | Olinda 360{% endblock %}

{% block stylesheets %}
    <style>
        .mcp-hero {
            background: linear-gradient(135deg, #1f2937 0%, #0f766e 48%, #ecfeff 100%);
            border-radius: 1.5rem;
            color: #fff;
            overflow: hidden;
            position: relative;
        }

        .mcp-hero::after {
            background: radial-gradient(circle at top right, rgba(255, 255, 255, 0.2), transparent 36%);
            content: '';
            inset: 0;
            position: absolute;
        }

        .mcp-hero > * {
            position: relative;
            z-index: 1;
        }

        .mcp-card {
            background: #fff;
            border: 1px solid rgba(15, 118, 110, 0.08);
            border-radius: 1.25rem;
            box-shadow: 0 1rem 2rem rgba(15, 23, 42, 0.06);
        }

        .mcp-code {
            background: #0f172a;
            border-radius: 1rem;
            color: #e2e8f0;
            display: block;
            padding: 1rem 1.25rem;
            white-space: pre-wrap;
        }

        .mcp-table thead th {
            background: #ecfeff;
            color: #0f766e;
            font-size: 0.82rem;
            letter-spacing: 0.03em;
            text-transform: uppercase;
        }
    </style>
{% endblock %}

{% block body %}
    <section class="py-4 py-lg-5" aria-labelledby="mcp-docs-title">
        <div class="mcp-hero p-4 p-lg-5 mb-4">
            <div class="row g-4 align-items-end">
                <div class="col-lg-8">
                    <span class="badge rounded-pill text-bg-light text-success mb-3">AI-Ready Architecture</span>
                    <h1 id="mcp-docs-title" class="display-6 fw-bold mb-3">MCP / IA</h1>
                    <p class="lead mb-0">Gateway de contexto e ferramentas do Olinda360, preparado para LLMs, agentes inteligentes e assistentes turísticos urbanos com interoperabilidade orientada a contexto.</p>
                </div>
                <div class="col-lg-4 text-lg-end">
                    <div class="d-flex justify-content-lg-end gap-2 flex-wrap">
                        <a class="btn btn-light" href="/mcp/v1">Ver home JSON</a>
                        <a class="btn btn-outline-light" href="/mcp/v1/context/tourism">Contexto turístico</a>
                    </div>
                </div>
            </div>
        </div>

        <div class="row g-4 mb-4">
            <div class="col-lg-8">
                <div class="mcp-card p-4 h-100">
                    <h2 class="h4 mb-3">Recursos MCP</h2>
                    <div class="table-responsive">
                        <table class="table mcp-table align-middle mb-0">
                            <thead>
                                <tr>
                                    <th>Recurso</th>
                                    <th>Endpoint</th>
                                    <th>Descrição</th>
                                </tr>
                            </thead>
                            <tbody>
                                {% for resource in resources %}
                                    <tr>
                                        <td><strong>{{ resource.name }}</strong></td>
                                        <td>{{ resource.path }}</td>
                                        <td>{{ resource.description }}</td>
                                    </tr>
                                {% endfor %}
                            </tbody>
                        </table>
                    </div>
                </div>
            </div>
            <div class="col-lg-4">
                <div class="mcp-card p-4 mb-4">
                    <h2 class="h5 mb-3">Objetivo estratégico</h2>
                    <p class="text-secondary mb-0">A camada MCP posiciona o Olinda360 como plataforma AI-ready, capaz de fornecer contexto confiável, recursos públicos controlados e ferramentas invocáveis por agentes e assistentes urbanos.</p>
                </div>
                <div class="mcp-card p-4">
                    <h2 class="h5 mb-3">Uso futuro</h2>
                    <p class="text-secondary mb-0">A arquitetura está preparada para copilotos institucionais, agentes de atendimento turístico, recomendações inteligentes e fluxos interativos de apoio à gestão territorial.</p>
                </div>
            </div>
        </div>

        <div class="row g-4 mb-4">
            <div class="col-lg-7">
                <div class="mcp-card p-4 h-100">
                    <h2 class="h4 mb-3">Ferramentas disponíveis</h2>
                    <div class="table-responsive">
                        <table class="table mcp-table align-middle mb-0">
                            <thead>
                                <tr>
                                    <th>Método</th>
                                    <th>Ferramenta</th>
                                    <th>Descrição</th>
                                </tr>
                            </thead>
                            <tbody>
                                {% for tool in tools %}
                                    <tr>
                                        <td><span class="badge text-bg-success">{{ tool.method }}</span></td>
                                        <td><strong>{{ tool.path }}</strong></td>
                                        <td>{{ tool.description }}</td>
                                    </tr>
                                {% endfor %}
                            </tbody>
                        </table>
                    </div>
                </div>
            </div>
            <div class="col-lg-5">
                <div class="mcp-card p-4 h-100">
                    <h2 class="h4 mb-3">Contextos expostos</h2>
                    <ul class="list-group list-group-flush">
                        {% for context in contexts %}
                            <li class="list-group-item px-0 d-flex justify-content-between gap-3 flex-wrap">
                                <strong>{{ context.context }}</strong>
                                <span class="text-secondary text-end">{{ context.description }}</span>
                            </li>
                        {% endfor %}
                    </ul>
                </div>
            </div>
        </div>

        <div class="mcp-card p-4 mb-4">
            <div class="d-flex justify-content-between align-items-start gap-3 flex-wrap">
                <div>
                    <h2 class="h4 mb-2">Resposta padrão</h2>
                    <p class="text-secondary mb-0">Todos os endpoints MCP respondem com um envelope previsível para facilitar o consumo por modelos, agentes e orquestradores.</p>
                </div>
                <code class="mcp-code mb-0">{{ responseExample|json_encode(constant('JSON_PRETTY_PRINT')) }}</code>
            </div>
        </div>

        <div class="mcp-card p-4">
            <h2 class="h4 mb-3">Exemplos rápidos</h2>
            {% for example in examples %}
                <code class="mcp-code mb-3">{{ example }}</code>
            {% endfor %}
        </div>
    </section>
{% endblock %}