{% macro dropdown_item(label, description, icon, href, active, badge, badgeTone, disabled, planned) %}
    <li>
        <a class="dropdown-item {{ active ? 'active' }} {{ disabled ? 'disabled' }} {{ planned or badge ? 'app-navbar__dropdown-item--planned' : 'app-navbar__dropdown-item--operational' }}" href="{{ href }}" {% if disabled %}aria-disabled="true"{% endif %}>
            <span class="app-navbar__dropdown-line">
                <span class="app-navbar__dropdown-icon"><i class="bi bi-{{ icon }}"></i></span>
                <span class="app-navbar__dropdown-text">
                    <span class="app-navbar__dropdown-title">
                        <span>{{ label }}</span>
                        {% if badge %}
                            <span class="badge text-bg-{{ badgeTone|default('secondary') }}">{{ badge }}</span>
                        {% endif %}
                    </span>
                    <span class="app-navbar__dropdown-description">{{ description }}</span>
                </span>
            </span>
        </a>
    </li>
{% endmacro %}

