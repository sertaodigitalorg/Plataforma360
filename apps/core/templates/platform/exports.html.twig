{# Generated by GitHub Copilot #}
{% extends 'base.html.twig' %}

{% block title %}Exportações CSV | Olinda 360{% endblock %}

{% block stylesheets %}
    <style>
        .exports-hero {
            background: linear-gradient(135deg, #083d3b 0%, #0f766e 52%, #effcf8 100%);
            border-radius: 1.5rem;
            color: #fff;
        }

        .exports-card {
            background: #fff;
            border: 1px solid rgba(8, 61, 59, 0.08);
            border-radius: 1.25rem;
            box-shadow: 0 1rem 2rem rgba(8, 61, 59, 0.06);
            height: 100%;
        }

        .exports-icon {
            align-items: center;
            background: #ecfdf5;
            border-radius: 0.9rem;
            color: #0f766e;
            display: inline-flex;
            font-size: 1.15rem;
            height: 3rem;
            justify-content: center;
            width: 3rem;
        }
    </style>
{% endblock %}

{% block body %}
    <section class="py-4 py-lg-5">
        <div class="exports-hero p-4 p-lg-5 mb-4">
            <div class="row g-4 align-items-end">
                <div class="col-lg-8">
                    <span class="badge rounded-pill text-bg-light text-success mb-3">Dados</span>
                    <h1 class="display-6 fw-bold mb-3">Exportações CSV</h1>
                    <p class="lead mb-0">Central institucional para extração rápida dos principais conjuntos de dados operacionais do Olinda360.</p>
                </div>
            </div>
        </div>

        <div class="row g-4">
            {% for item in exports %}
                <div class="col-12 col-md-6 col-xl-4">
                    <article class="exports-card p-4">
                        <div class="exports-icon mb-3"><i class="bi {{ item.icon }}"></i></div>
                        <h2 class="h4 mb-2">{{ item.title }}</h2>
                        <p class="text-secondary mb-4">{{ item.description }}</p>
                        <a class="btn btn-outline-success w-100" href="{{ path(item.route) }}">Baixar CSV</a>
                    </article>
                </div>
            {% endfor %}
        </div>
    </section>
{% endblock %}