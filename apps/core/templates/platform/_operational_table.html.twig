{# Generated by GitHub Copilot #}
<div class="analytics-section-card p-4 mb-4">
    <div class="d-flex justify-content-between align-items-start gap-3 flex-wrap mb-4">
        <div>
            <span class="badge rounded-pill text-bg-light text-primary mb-2">Indicadores Operacionais</span>
            <h2 class="h3 mb-1">Saude das fontes e integracoes analiticas</h2>
            <p class="text-secondary mb-0">Tabela moderna para acompanhamento de sincronizacao, cobertura, integridade, qualidade e status operacional das bases estrategicas.</p>
        </div>
    </div>
    <div class="table-responsive">
        <table class="table analytics-operational-table align-middle mb-0">
            <thead>
                <tr>
                    <th>Fonte</th>
                    <th>Ultima sincronizacao</th>
                    <th>Cobertura</th>
                    <th>Integridade</th>
                    <th>Qualidade</th>
                    <th>Registros processados</th>
                    <th>Status operacional</th>
                </tr>
            </thead>
            <tbody>
                {% for row in operationalIndicators %}
                    <tr>
                        <td class="fw-semibold">{{ row.source }}</td>
                        <td>{{ row.updatedAt }}</td>
                        <td>{{ row.coverage }}</td>
                        <td>{{ row.integrity }}</td>
                        <td>{{ row.quality }}</td>
                        <td>{{ row.processed }}</td>
                        <td><span class="analytics-status-badge analytics-status-badge--{{ row.tone }}">{{ row.status }}</span></td>
                    </tr>
                {% endfor %}
            </tbody>
        </table>
    </div>
</div>