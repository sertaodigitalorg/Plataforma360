{# Generated by GitHub Copilot #}
<div class="indicators-section-card p-4 mb-4">
    <div class="d-flex justify-content-between align-items-start gap-3 flex-wrap mb-4">
        <div>
            <span class="badge rounded-pill text-bg-light text-primary mb-2">Indicadores Executivos</span>
            <h2 class="h3 mb-1">Leitura de desempenho territorial</h2>
            <p class="text-secondary mb-0">Métricas sintéticas para visão executiva de turismo inteligente, dinamismo cultural e atividade territorial.</p>
        </div>
    </div>
    <div class="indicators-kpi-grid">
        {% for item in executiveIndicators %}
            <article class="indicators-surface-card p-4 h-100">
                <div class="d-flex justify-content-between align-items-start gap-3 mb-3">
                    <div>
                        <p class="text-muted text-uppercase small fw-semibold mb-2">{{ item.title }}</p>
                        <p class="display-6 fw-bold text-primary mb-1">{{ item.value }}</p>
                    </div>
                    <div class="d-inline-flex align-items-center justify-content-center rounded-4 bg-light fs-4 text-{{ item.tone == 'teal' ? 'success' : item.tone == 'amber' ? 'warning' : item.tone == 'rose' ? 'danger' : 'primary' }}" style="width: 3rem; height: 3rem;">
                        <i class="bi bi-{{ item.icon }}"></i>
                    </div>
                </div>
                <div class="d-flex justify-content-between align-items-center gap-3 mb-3">
                    <span class="indicators-status-badge indicators-status-badge--{{ item.trend == 'up' ? 'success' : item.trend == 'down' ? 'danger' : 'primary' }}">
                        <i class="bi bi-{{ item.trend == 'up' ? 'arrow-up-right' : item.trend == 'down' ? 'arrow-down-right' : 'dash-lg' }} me-1"></i>{{ item.variation }}
                    </span>
                    <span class="small text-secondary">Tendência {{ item.trend == 'steady' ? 'estável' : item.trend == 'up' ? 'positiva' : 'de queda' }}</span>
                </div>
                <p class="text-secondary small mb-3">{{ item.description }}</p>
                <div class="d-flex align-items-end gap-2" aria-hidden="true" style="height: 3rem;">
                    {% for bar in item.sparkBars %}
                        <span class="rounded-3 flex-fill" style="background: linear-gradient(180deg, rgba(19, 103, 138, 0.28), rgba(15, 118, 110, 0.85)); height: {{ bar }}%; min-height: 0.45rem;"></span>
                    {% endfor %}
                </div>
            </article>
        {% endfor %}
    </div>
</div>