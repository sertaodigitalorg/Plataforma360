{# Generated by GitHub Copilot #}
<div class="analytics-section-card p-4 h-100">
    <div class="d-flex justify-content-between align-items-start gap-3 flex-wrap mb-4">
        <div>
            <span class="badge rounded-pill text-bg-light text-primary mb-2">Mapa de Inteligencia Territorial</span>
            <h2 class="h3 mb-1">Hotspots, concentracao de eventos e fluxo territorial</h2>
            <p class="text-secondary mb-0">Leitura espacial com zonas quentes, concentracao cultural e areas de maior movimentacao do ecossistema turistico.</p>
        </div>
    </div>
    <div class="analytics-map-card mb-4">
        {% for hotspot in territorialHotspots %}
            <div class="analytics-map-hotspot" style="top: {{ hotspot.top }}; left: {{ hotspot.left }};">
                <div class="analytics-map-hotspot-dot" style="width: {{ 1.2 + (hotspot.intensity / 60) }}rem; height: {{ 1.2 + (hotspot.intensity / 60) }}rem;"></div>
                <div class="analytics-map-hotspot-card">
                    <div class="d-flex justify-content-between align-items-start gap-2 mb-2">
                        <strong class="text-primary">{{ hotspot.name }}</strong>
                        <span class="analytics-status-badge analytics-status-badge--primary">{{ hotspot.intensity }}/100</span>
                    </div>
                    <p class="small text-secondary mb-2">{{ hotspot.description }}</p>
                    <div class="small text-secondary d-grid gap-1">
                        <span>Fluxo: {{ hotspot.flow }}</span>
                        <span>Eventos: {{ hotspot.events }}</span>
                        <span>{{ hotspot.status }}</span>
                    </div>
                </div>
            </div>
        {% endfor %}
    </div>
    <div class="row g-3">
        {% for hotspot in territorialHotspots %}
            <div class="col-md-6 col-xl-4">
                <div class="analytics-surface-card p-3 h-100">
                    <div class="d-flex justify-content-between align-items-start gap-2 mb-2">
                        <strong>{{ hotspot.name }}</strong>
                        <span class="analytics-chip">{{ hotspot.status }}</span>
                    </div>
                    <div class="progress mb-2" style="height: 0.65rem;">
                        <div class="progress-bar bg-info" role="progressbar" style="width: {{ hotspot.intensity }}%;"></div>
                    </div>
                    <p class="small text-secondary mb-0">Fluxo {{ hotspot.flow }} • {{ hotspot.events }} eventos • Intensidade {{ hotspot.intensity }}/100</p>
                </div>
            </div>
        {% endfor %}
    </div>
</div>