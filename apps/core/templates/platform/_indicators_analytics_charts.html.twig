{# Generated by GitHub Copilot #}
{% set monthlyVisitors = analyticsCharts.monthlyVisitors %}
{% set tourismOccupancy = analyticsCharts.tourismOccupancy %}

<div class="indicators-section-card p-4 mb-4">
    <div class="d-flex justify-content-between align-items-start gap-3 flex-wrap mb-4">
        <div>
            <span class="badge rounded-pill text-bg-light text-primary mb-2">Análise Comparativa</span>
            <h2 class="h3 mb-1">Evolução, sazonalidade e comparativos territoriais</h2>
            <p class="text-secondary mb-0">Gráficos mockados para apresentação institucional do BI territorial e da capacidade analítica futura do Olinda360.</p>
        </div>
    </div>
    <div class="row g-4">
        <div class="col-lg-8">
            <div class="indicators-surface-card p-4 h-100">
                <h3 class="h5 mb-3">Evolução mensal de visitantes</h3>
                <div id="monthlyVisitorsChart" class="indicators-chart-shell" role="img" aria-label="Gráfico da evolução mensal de visitantes">
                    <svg viewBox="0 0 520 220" class="indicators-svg-chart" aria-hidden="true">
                        <line x1="30" y1="185" x2="490" y2="185" class="indicators-chart-grid"></line>
                        <line x1="30" y1="135" x2="490" y2="135" class="indicators-chart-grid"></line>
                        <line x1="30" y1="85" x2="490" y2="85" class="indicators-chart-grid"></line>
                        <line x1="30" y1="35" x2="490" y2="35" class="indicators-chart-grid"></line>
                        <polygon points="40,185 {{ monthlyVisitors.points|join(' ') }} 420,185" class="indicators-chart-area"></polygon>
                        <polyline points="{{ monthlyVisitors.points|join(' ') }}" class="indicators-chart-line"></polyline>
                        {% for label in monthlyVisitors.labels %}
                            <text x="{{ 40 + (loop.index0 * 76) }}" y="208" text-anchor="middle">{{ label }}</text>
                        {% endfor %}
                    </svg>
                </div>
            </div>
        </div>
        <div class="col-lg-4">
            <div class="indicators-surface-card p-4 h-100">
                <h3 class="h5 mb-3">Crescimento de eventos</h3>
                <div id="eventGrowthChart" class="indicators-bars-chart" role="img" aria-label="Gráfico de barras do crescimento de eventos">
                    {% for value in analyticsCharts.eventGrowth.values %}
                        <div class="indicators-bar-column">
                            <span class="indicators-bar-value">{{ value }}</span>
                            <div class="indicators-bar-track">
                                <div class="indicators-bar-fill" style="height: {{ (value / analyticsCharts.eventGrowth.max) * 100 }}%;"></div>
                            </div>
                            <span class="indicators-bar-label">{{ analyticsCharts.eventGrowth.labels[loop.index0] }}</span>
                        </div>
                    {% endfor %}
                </div>
            </div>
        </div>
        <div class="col-lg-4">
            <div class="indicators-surface-card p-4 h-100">
                <h3 class="h5 mb-3">Ocupação turística</h3>
                <div id="tourismOccupancyChart" class="indicators-chart-shell" role="img" aria-label="Gráfico da ocupação turística semanal">
                    <svg viewBox="0 0 420 220" class="indicators-svg-chart" aria-hidden="true">
                        <line x1="25" y1="185" x2="395" y2="185" class="indicators-chart-grid"></line>
                        <line x1="25" y1="135" x2="395" y2="135" class="indicators-chart-grid"></line>
                        <line x1="25" y1="85" x2="395" y2="85" class="indicators-chart-grid"></line>
                        <line x1="25" y1="35" x2="395" y2="35" class="indicators-chart-grid"></line>
                        <polygon points="35,185 {{ tourismOccupancy.points|join(' ') }} 383,185" class="indicators-chart-area indicators-chart-area--blue"></polygon>
                        <polyline points="{{ tourismOccupancy.points|join(' ') }}" class="indicators-chart-line indicators-chart-line--blue"></polyline>
                        {% for label in tourismOccupancy.labels %}
                            <text x="{{ 35 + (loop.index0 * 58) }}" y="208" text-anchor="middle">{{ label }}</text>
                        {% endfor %}
                    </svg>
                </div>
            </div>
        </div>
        <div class="col-lg-4">
            <div class="indicators-surface-card p-4 h-100">
                <h3 class="h5 mb-3">Sazonalidade</h3>
                <div id="seasonalityChart" class="indicators-donut-chart" role="img" aria-label="Distribuição percentual de sazonalidade">
                    <div class="indicators-donut">
                        <span class="indicators-donut-center">100%</span>
                    </div>
                    <div class="indicators-donut-legend">
                        {% set donutColors = ['#0f766e', '#14b8a6', '#99f6e4'] %}
                        {% for value in analyticsCharts.seasonality.values %}
                            <div class="indicators-donut-legend-item">
                                <span class="indicators-donut-swatch" style="background: {{ donutColors[loop.index0] }};"></span>
                                <span>{{ analyticsCharts.seasonality.labels[loop.index0] }} {{ value }}%</span>
                            </div>
                        {% endfor %}
                    </div>
                </div>
            </div>
        </div>
        <div class="col-lg-4">
            <div class="indicators-surface-card p-4 h-100">
                <h3 class="h5 mb-3">Comparativo bairros</h3>
                <div id="districtComparisonChart" class="indicators-compare-list" role="img" aria-label="Comparativo de desempenho entre bairros">
                    {% for value in analyticsCharts.districtComparison.values %}
                        <div class="indicators-compare-row">
                            <div class="indicators-compare-meta">
                                <span>{{ analyticsCharts.districtComparison.labels[loop.index0] }}</span>
                                <span>{{ value }}</span>
                            </div>
                            <div class="indicators-compare-track">
                                <div class="indicators-compare-fill" style="width: {{ (value / analyticsCharts.districtComparison.max) * 100 }}%;"></div>
                            </div>
                        </div>
                    {% endfor %}
                </div>
            </div>
        </div>
    </div>
</div>