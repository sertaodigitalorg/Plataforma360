{# Generated by GitHub Copilot #}
<div class="analytics-section-card p-4 mb-4">
    <div class="d-flex justify-content-between align-items-start gap-3 flex-wrap mb-4">
        <div>
            <span class="badge rounded-pill text-bg-light text-primary mb-2">Analise Preditiva</span>
            <h2 class="h3 mb-1">Cenarios futuros para turismo inteligente</h2>
            <p class="text-secondary mb-0">Cartoes com linguagem futurista e IA-like para projecoes de fluxo, ocupacao, agenda e dinamica economica.</p>
        </div>
    </div>
    <div class="analytics-predictive-grid">
        {% for card in predictiveCards %}
            <article class="analytics-surface-card p-4 h-100">
                <div class="d-flex justify-content-between align-items-start gap-3 mb-3">
                    <div class="d-inline-flex align-items-center justify-content-center rounded-4 bg-light analytics-tone-{{ card.tone }} fs-4" style="width: 3rem; height: 3rem;">
                        <i class="bi bi-{{ card.icon }}"></i>
                    </div>
                    <span class="analytics-chip">{{ card.confidence }}</span>
                </div>
                <h3 class="h5 mb-2">{{ card.title }}</h3>
                <p class="display-6 fw-bold text-primary mb-1">{{ card.projection }}</p>
                <p class="text-secondary small mb-2">{{ card.horizon }}</p>
                <p class="text-secondary mb-0">{{ card.description }}</p>
            </article>
        {% endfor %}
    </div>
</div>