{# Generated by GitHub Copilot #}
{% extends 'base.html.twig' %}

{% block title %}Indicadores Estratégicos | Olinda 360{% endblock %}

{% block stylesheets %}
    <style>
        .indicators-hero {
            background: linear-gradient(135deg, #0b3c5d 0%, #13678a 48%, #eff7fb 100%);
            border-radius: 1.5rem;
            color: #fff;
            overflow: hidden;
            position: relative;
        }

        .indicators-hero::after {
            background: radial-gradient(circle at top right, rgba(255, 255, 255, 0.3), transparent 42%);
            content: '';
            inset: 0;
            position: absolute;
        }

        .indicators-hero > * {
            position: relative;
            z-index: 1;
        }

        .indicators-glass-card,
        .indicators-section-card,
        .indicators-surface-card {
            background: #fff;
            border: 1px solid rgba(11, 60, 93, 0.08);
            border-radius: 1.5rem;
            box-shadow: 0 1rem 2rem rgba(11, 60, 93, 0.06);
            transition: transform 0.2s ease, box-shadow 0.2s ease, border-color 0.2s ease;
        }

        .indicators-glass-card {
            backdrop-filter: blur(12px);
            background: rgba(255, 255, 255, 0.12);
            border: 1px solid rgba(255, 255, 255, 0.18);
            box-shadow: 0 1rem 2rem rgba(11, 60, 93, 0.12);
            color: #fff;
        }

        .indicators-section-card:hover,
        .indicators-surface-card:hover {
            border-color: rgba(19, 103, 138, 0.18);
            box-shadow: 0 1.35rem 2.4rem rgba(11, 60, 93, 0.1);
            transform: translateY(-4px);
        }

        .indicators-kpi-grid,
        .indicators-governance-grid,
        .indicators-insights-grid,
        .indicators-layers-grid {
            display: grid;
            gap: 1rem;
        }

        .indicators-kpi-grid,
        .indicators-governance-grid,
        .indicators-insights-grid {
            grid-template-columns: repeat(auto-fit, minmax(220px, 1fr));
        }

        .indicators-layers-grid {
            grid-template-columns: repeat(auto-fit, minmax(160px, 1fr));
        }

        .indicators-status-badge {
            border-radius: 999px;
            display: inline-flex;
            font-size: 0.76rem;
            font-weight: 700;
            padding: 0.3rem 0.7rem;
        }

        .indicators-status-badge--success {
            background: rgba(25, 135, 84, 0.12);
            color: #146c43;
        }

        .indicators-status-badge--warning {
            background: rgba(255, 193, 7, 0.18);
            color: #8a6b00;
        }

        .indicators-status-badge--secondary {
            background: rgba(108, 117, 125, 0.15);
            color: #495057;
        }

        .indicators-status-badge--primary,
        .indicators-status-badge--info {
            background: rgba(13, 110, 253, 0.12);
            color: #0a58ca;
        }

        .indicators-table thead th {
            background: #eef6f8;
            color: #0b3c5d;
            font-size: 0.8rem;
            letter-spacing: 0.03em;
            text-transform: uppercase;
        }

        .indicators-chart-shell {
            min-height: 18rem;
        }

        .indicators-svg-chart {
            display: block;
            height: 16rem;
            width: 100%;
        }

        .indicators-svg-chart text {
            fill: #5f7482;
            font-size: 11px;
        }

        .indicators-chart-grid {
            stroke: rgba(11, 60, 93, 0.08);
            stroke-width: 1;
        }

        .indicators-chart-line {
            fill: none;
            stroke: #0f766e;
            stroke-linecap: round;
            stroke-linejoin: round;
            stroke-width: 3;
        }

        .indicators-chart-area {
            fill: rgba(15, 118, 110, 0.14);
        }

        .indicators-chart-line--blue {
            stroke: #13678a;
        }

        .indicators-chart-area--blue {
            fill: rgba(19, 103, 138, 0.14);
        }

        .indicators-bars-chart {
            align-items: end;
            display: grid;
            gap: 0.75rem;
            grid-template-columns: repeat(auto-fit, minmax(2.4rem, 1fr));
            min-height: 16rem;
        }

        .indicators-bar-column {
            align-items: center;
            display: flex;
            flex-direction: column;
            gap: 0.6rem;
            justify-content: end;
        }

        .indicators-bar-track {
            align-items: end;
            background: linear-gradient(180deg, rgba(19, 103, 138, 0.08), rgba(19, 103, 138, 0.02));
            border-radius: 999px;
            display: flex;
            height: 13rem;
            padding: 0.25rem;
            width: 100%;
        }

        .indicators-bar-fill {
            background: linear-gradient(180deg, #2dd4bf 0%, #13678a 100%);
            border-radius: 999px;
            width: 100%;
        }

        .indicators-bar-label {
            color: #5f7482;
            font-size: 0.78rem;
            font-weight: 600;
        }

        .indicators-bar-value {
            color: #0b3c5d;
            font-size: 0.78rem;
            font-weight: 700;
        }

        .indicators-donut-chart {
            align-items: center;
            display: flex;
            flex-direction: column;
            gap: 1.25rem;
            justify-content: center;
            min-height: 16rem;
        }

        .indicators-donut {
            align-items: center;
            background: conic-gradient(#0f766e 0 48%, #14b8a6 48% 82%, #99f6e4 82% 100%);
            border-radius: 50%;
            display: inline-flex;
            height: 11rem;
            justify-content: center;
            position: relative;
            width: 11rem;
        }

        .indicators-donut::after {
            background: #fff;
            border-radius: 50%;
            content: '';
            height: 6rem;
            position: absolute;
            width: 6rem;
        }

        .indicators-donut-center {
            color: #0b3c5d;
            font-size: 1.3rem;
            font-weight: 800;
            position: relative;
            z-index: 1;
        }

        .indicators-donut-legend {
            display: grid;
            gap: 0.75rem;
            grid-template-columns: repeat(3, minmax(0, 1fr));
            width: 100%;
        }

        .indicators-donut-legend-item {
            align-items: center;
            color: #5f7482;
            display: flex;
            font-size: 0.84rem;
            gap: 0.5rem;
            justify-content: center;
        }

        .indicators-donut-swatch {
            border-radius: 999px;
            display: inline-block;
            height: 0.75rem;
            width: 0.75rem;
        }

        .indicators-compare-list {
            display: grid;
            gap: 1rem;
        }

        .indicators-compare-row {
            display: grid;
            gap: 0.6rem;
        }

        .indicators-compare-meta {
            color: #5f7482;
            display: flex;
            font-size: 0.84rem;
            font-weight: 600;
            justify-content: space-between;
        }

        .indicators-compare-track {
            background: rgba(19, 103, 138, 0.08);
            border-radius: 999px;
            height: 0.8rem;
            overflow: hidden;
        }

        .indicators-compare-fill {
            background: linear-gradient(90deg, #7c3aed 0%, #13678a 100%);
            border-radius: 999px;
            height: 100%;
        }

        .indicators-action-button {
            align-items: center;
            display: inline-flex;
            gap: 0.55rem;
        }

        .indicators-section-card a:focus-visible,
        .indicators-surface-card a:focus-visible,
        .indicators-action-button:focus-visible {
            outline: 3px solid #ffbf47;
            outline-offset: 2px;
        }

        @media (max-width: 991.98px) {
            .indicators-bars-chart {
                grid-template-columns: repeat(6, minmax(2rem, 1fr));
            }

            .indicators-donut-legend {
                grid-template-columns: 1fr;
            }
        }
    </style>
{% endblock %}

{% block body %}
    <section class="py-4 py-lg-5" aria-labelledby="indicators-title">
        <div class="indicators-hero p-4 p-lg-5 mb-4">
            <div class="row g-4 align-items-end">
                <div class="col-lg-8">
                    <span class="badge rounded-pill text-bg-light text-primary mb-3">{{ hero.badge }}</span>
                    <h1 id="indicators-title" class="display-6 fw-bold mb-3">{{ hero.title }}</h1>
                    <p class="lead mb-0">{{ hero.subtitle }}</p>
                </div>
                <div class="col-lg-4">
                    <div class="indicators-glass-card p-4 text-lg-end">
                        <p class="text-uppercase small fw-semibold mb-2">Disponibilidade Analítica</p>
                        <p class="display-6 fw-bold mb-2">{{ hero.availability }}</p>
                        <p class="mb-0 opacity-75">{{ hero.availabilityDescription }}</p>
                    </div>
                </div>
            </div>
        </div>

        {% include 'platform/_indicator_cards.html.twig' with {executiveIndicators: executiveIndicators} only %}

        <div class="row g-4 mb-4">
            <div class="col-lg-8">
                {% include 'platform/_territorial_map.html.twig' with {territorialZones: territorialZones} only %}
            </div>
            <div class="col-lg-4">
                <div class="indicators-section-card p-4 h-100">
                    <span class="badge rounded-pill text-bg-light text-primary mb-2">Insights Territoriais</span>
                    <h2 class="h3 mb-3">Leitura espacial prioritária</h2>
                    <div class="d-grid gap-3">
                        {% for zone in territorialZones %}
                            <div class="indicators-surface-card p-3">
                                <div class="d-flex justify-content-between align-items-start gap-3 mb-2">
                                    <div>
                                        <h3 class="h6 mb-1">{{ zone.name }}</h3>
                                        <p class="text-secondary small mb-0">Fluxo {{ zone.flow }} visitantes</p>
                                    </div>
                                    <span class="indicators-status-badge indicators-status-badge--primary">{{ zone.occupancy }}</span>
                                </div>
                                <div class="small text-secondary d-flex justify-content-between gap-2 flex-wrap">
                                    <span>{{ zone.events }} eventos</span>
                                    <span>{{ zone.economicActivity }}</span>
                                </div>
                            </div>
                        {% endfor %}
                    </div>
                </div>
            </div>
        </div>

        <div class="indicators-section-card p-4 mb-4">
            <div class="d-flex justify-content-between align-items-start gap-3 flex-wrap mb-4">
                <div>
                    <span class="badge rounded-pill text-bg-light text-primary mb-2">Indicadores Operacionais</span>
                    <h2 class="h3 mb-1">Saúde das fontes estratégicas</h2>
                    <p class="text-secondary mb-0">Camada operacional para rastrear atualização, cobertura territorial e qualidade dos insumos usados no BI executivo.</p>
                </div>
            </div>
            <div class="table-responsive">
                <table class="table indicators-table align-middle mb-0">
                    <thead>
                        <tr>
                            <th>Fonte de Dados</th>
                            <th>Última atualização</th>
                            <th>Status</th>
                            <th>Registros processados</th>
                            <th>Cobertura territorial</th>
                            <th>Qualidade dos dados</th>
                        </tr>
                    </thead>
                    <tbody>
                        {% for row in operationalIndicators %}
                            <tr>
                                <td class="fw-semibold">{{ row.source }}</td>
                                <td>{{ row.updatedAt }}</td>
                                <td><span class="indicators-status-badge indicators-status-badge--{{ row.statusTone }}">{{ row.status }}</span></td>
                                <td>{{ row.processed }}</td>
                                <td>{{ row.coverage }}</td>
                                <td>{{ row.quality }}</td>
                            </tr>
                        {% endfor %}
                    </tbody>
                </table>
            </div>
        </div>

        {% include 'platform/_governance_cards.html.twig' with {governanceCards: governanceCards} only %}

        {% include 'platform/_indicators_analytics_charts.html.twig' with {analyticsCharts: analyticsCharts} only %}

        {% include 'platform/_strategic_insights.html.twig' with {strategicInsights: strategicInsights} only %}

        <div class="indicators-section-card p-4 mb-4">
            <div class="d-flex justify-content-between align-items-start gap-3 flex-wrap mb-4">
                <div>
                    <span class="badge rounded-pill text-bg-light text-primary mb-2">Camadas Analíticas</span>
                    <h2 class="h3 mb-1">Fluxo de inteligência territorial</h2>
                    <p class="text-secondary mb-0">Arquitetura executiva que demonstra como o Olinda360 transforma sinais territoriais em apoio à decisão pública.</p>
                </div>
            </div>
            <div class="indicators-layers-grid">
                {% for layer in analyticalLayers %}
                    <article class="indicators-surface-card p-4 position-relative">
                        <div class="d-inline-flex align-items-center justify-content-center rounded-4 bg-light text-primary fs-4 mb-3" style="width: 3rem; height: 3rem;">
                            <i class="bi bi-{{ layer.icon }}"></i>
                        </div>
                        <h3 class="h5 mb-2">{{ layer.title }}</h3>
                        <p class="text-secondary small mb-0">{{ layer.description }}</p>
                    </article>
                {% endfor %}
            </div>
        </div>

        <div class="indicators-section-card p-4">
            <span class="badge rounded-pill text-bg-light text-primary mb-2">Ações Estratégicas</span>
            <h2 class="h3 mb-3">Atalhos para operação executiva</h2>
            <p class="text-secondary mb-4">Navegação direta para exportação, observabilidade, dados abertos e superfícies estratégicas do ecossistema Olinda360.</p>
            <div class="d-flex flex-wrap gap-2">
                {% for action in strategicActions %}
                    <a class="btn btn-{{ action.variant }} indicators-action-button" href="{{ path(action.path) }}">
                        <i class="bi bi-{{ action.icon }}"></i>
                        <span>{{ action.label }}</span>
                    </a>
                {% endfor %}
            </div>
        </div>
    </section>
{% endblock %}