{# Generated by GitHub Copilot #}
<div class="analytics-section-card p-4 mb-4">
    <div class="d-flex justify-content-between align-items-start gap-3 flex-wrap mb-4">
        <div>
            <span class="badge rounded-pill text-bg-light text-primary mb-2">Painel Analitico Comparativo</span>
            <h2 class="h3 mb-1">Leitura cruzada para suporte avancado a decisao</h2>
            <p class="text-secondary mb-0">Leitura cruzada de fluxo turistico, eventos, hospedagem, sazonalidade e atividade economica para apoio a decisao da Secretaria.</p>
        </div>
    </div>
    <div class="row g-4">
        {% for panel in comparativePanels %}
            <div class="col-12 col-lg-6">
                <article class="analytics-surface-card p-4 h-100">
                    <div class="d-flex justify-content-between align-items-start gap-3 mb-3 flex-wrap">
                        <div>
                            <h3 class="h5 mb-1">{{ panel.title }}</h3>
                            <p class="text-secondary small mb-0">{{ panel.description }}</p>
                        </div>
                        <div class="d-flex flex-column align-items-start align-items-lg-end gap-2">
                            <span class="analytics-status-badge analytics-status-badge--{{ panel.statusTone }}">{{ panel.status }}</span>
                            <span class="analytics-chip">{{ panel.chartType }}</span>
                        </div>
                    </div>
                    <div class="analytics-chart-shell mb-3">
                        <canvas id="{{ panel.chartId }}" class="analytics-chart-canvas"></canvas>
                    </div>
                    <div class="analytics-comparative-insight">
                        <p class="text-uppercase small fw-semibold text-primary mb-1">Insight automatico</p>
                        <p class="text-secondary small mb-0">{{ panel.insight }}</p>
                    </div>
                </article>
            </div>
        {% endfor %}
    </div>

    <div class="analytics-comparative-summary p-4 mt-4">
        <div class="d-flex justify-content-between align-items-start gap-3 flex-wrap mb-4">
            <div>
                <span class="badge rounded-pill text-bg-light text-primary mb-2">Leituras Prioritarias</span>
                <h3 class="h4 mb-1">Insights comparativos para a Secretaria</h3>
                <p class="mb-0 text-white-50">Sinais sintetizados a partir do cruzamento entre demanda, oferta, maturidade e dinamica economica.</p>
            </div>
        </div>
        <div class="analytics-comparative-summary-grid">
            {% for insight in comparativeInsights %}
                <article class="analytics-comparative-summary-card h-100">
                    <div class="d-flex gap-3 align-items-start">
                        <i class="bi bi-stars fs-4 text-info"></i>
                        <p class="mb-0 text-white-50">{{ insight }}</p>
                    </div>
                </article>
            {% endfor %}
        </div>
    </div>
</div>