{# Generated by GitHub Copilot #}
<div class="indicators-section-card p-4 mb-4">
    <div class="d-flex justify-content-between align-items-start gap-3 flex-wrap mb-4">
        <div>
            <span class="badge rounded-pill text-bg-light text-primary mb-2">Indicadores de Governança</span>
            <h2 class="h3 mb-1">Maturidade operacional e confiabilidade institucional</h2>
            <p class="text-secondary mb-0">Sinais executivos que demonstram disponibilidade, integridade, atualização e prontidão da plataforma para apoiar decisões públicas.</p>
        </div>
    </div>
    <div class="indicators-governance-grid">
        {% for card in governanceCards %}
            <article class="indicators-surface-card p-4 h-100">
                <div class="d-flex justify-content-between gap-3 mb-3">
                    <div>
                        <p class="text-muted text-uppercase small fw-semibold mb-2">{{ card.title }}</p>
                        <p class="display-6 fw-bold text-primary mb-0">{{ card.value }}</p>
                    </div>
                    <div class="d-inline-flex align-items-center justify-content-center rounded-4 bg-light fs-4 text-{{ card.tone == 'teal' ? 'success' : card.tone == 'amber' ? 'warning' : card.tone == 'rose' ? 'danger' : 'primary' }}" style="width: 3rem; height: 3rem;">
                        <i class="bi bi-{{ card.icon }}"></i>
                    </div>
                </div>
                <p class="text-secondary small mb-0">{{ card.detail }}</p>
            </article>
        {% endfor %}
    </div>
</div>