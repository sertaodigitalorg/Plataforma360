{# Generated by GitHub Copilot #}
{% extends 'base.html.twig' %}

{% block title %}Analytics Territorial e Turistico | Olinda 360{% endblock %}

{% block stylesheets %}
    <style>
        .analytics-hero {
            background: linear-gradient(135deg, #06263d 0%, #0f5f7a 45%, #e9f7fb 100%);
            border-radius: 1.75rem;
            color: #fff;
            overflow: hidden;
            position: relative;
        }

        .analytics-hero::before {
            background: radial-gradient(circle at top right, rgba(255, 255, 255, 0.28), transparent 40%);
            content: '';
            inset: 0;
            position: absolute;
        }

        .analytics-hero > * {
            position: relative;
            z-index: 1;
        }

        .analytics-glass-card,
        .analytics-section-card,
        .analytics-surface-card {
            backdrop-filter: blur(12px);
            background: rgba(255, 255, 255, 0.88);
            border: 1px solid rgba(6, 38, 61, 0.08);
            border-radius: 1.5rem;
            box-shadow: 0 1.2rem 2.4rem rgba(6, 38, 61, 0.08);
            transition: transform 0.24s ease, box-shadow 0.24s ease, border-color 0.24s ease;
        }

        .analytics-glass-card {
            background: rgba(255, 255, 255, 0.14);
            border-color: rgba(255, 255, 255, 0.18);
            color: #fff;
        }

        .analytics-section-card:hover,
        .analytics-surface-card:hover {
            border-color: rgba(15, 95, 122, 0.18);
            box-shadow: 0 1.45rem 2.7rem rgba(6, 38, 61, 0.12);
            transform: translateY(-4px);
        }

        .analytics-overview-grid,
        .analytics-insights-grid,
        .analytics-predictive-grid,
        .analytics-widget-grid,
            .analytics-comparative-summary-grid,
        .analytics-actions-grid,
        .analytics-flow-grid {
            display: grid;
            gap: 1rem;
        }

        .analytics-insights-grid,
        .analytics-predictive-grid,
        .analytics-widget-grid {
            grid-template-columns: repeat(auto-fit, minmax(220px, 1fr));
        }

            .analytics-comparative-summary-grid {
                grid-template-columns: repeat(auto-fit, minmax(220px, 1fr));
            }

        .analytics-actions-grid {
            grid-template-columns: repeat(auto-fit, minmax(180px, 1fr));
        }

        .analytics-flow-grid {
            grid-template-columns: repeat(auto-fit, minmax(160px, 1fr));
            position: relative;
        }

        .analytics-flow-grid::before {
            background: linear-gradient(90deg, rgba(15, 95, 122, 0.28), rgba(15, 95, 122, 0.06));
            content: '';
            height: 3px;
            left: 3rem;
            position: absolute;
            right: 3rem;
            top: 4.25rem;
            z-index: 0;
        }

        .analytics-status-badge {
            border-radius: 999px;
            display: inline-flex;
            font-size: 0.76rem;
            font-weight: 700;
            padding: 0.32rem 0.72rem;
        }

        .analytics-status-badge--success {
            background: rgba(25, 135, 84, 0.12);
            color: #146c43;
        }

        .analytics-status-badge--warning {
            background: rgba(255, 193, 7, 0.18);
            color: #8a6b00;
        }

        .analytics-status-badge--primary,
        .analytics-status-badge--info {
            background: rgba(13, 110, 253, 0.12);
            color: #0a58ca;
        }

        .analytics-status-badge--secondary {
            background: rgba(108, 117, 125, 0.16);
            color: #495057;
        }

        .analytics-status-badge--dark {
            background: rgba(33, 37, 41, 0.12);
            color: #212529;
        }

        .analytics-chart-shell {
            min-height: 19rem;
            position: relative;
        }

        .analytics-chart-canvas {
            height: 18rem !important;
            width: 100% !important;
        }

        .analytics-heatmap-grid {
            grid-template-columns: 8rem repeat(5, minmax(0, 1fr));
        }

        .analytics-heatmap-cell,
        .analytics-heatmap-label {
            align-items: center;
            border-radius: 1rem;
            display: flex;
            justify-content: center;
            min-height: 3.25rem;

        .analytics-comparative-insight {
            background: linear-gradient(135deg, rgba(15, 118, 110, 0.08), rgba(14, 116, 144, 0.08));
            border: 1px solid rgba(15, 95, 122, 0.08);
            border-radius: 1rem;
            padding: 0.95rem 1rem;
        }

        .analytics-comparative-summary {
            background: linear-gradient(135deg, rgba(6, 38, 61, 0.96), rgba(15, 95, 122, 0.92));
            border-radius: 1.4rem;
            color: #fff;
        }

        .analytics-comparative-summary-card {
            background: rgba(255, 255, 255, 0.08);
            border: 1px solid rgba(255, 255, 255, 0.12);
            border-radius: 1rem;
            padding: 1rem;
        }
            text-align: center;
        }

        .analytics-heatmap-label {
            background: #eef6f8;
            color: #06263d;
            font-size: 0.82rem;
            font-weight: 700;
            padding: 0.85rem;
        }

        .analytics-heatmap-cell {
            color: #06263d;
            font-size: 0.85rem;
            font-weight: 700;
        }

        .analytics-geo-map {
            background: linear-gradient(180deg, rgba(15, 95, 122, 0.08), rgba(15, 95, 122, 0.02));
            border-radius: 1.25rem;
            min-height: 17rem;
            overflow: hidden;
            position: relative;
        }

        .analytics-geo-map::before {
            background-image: linear-gradient(rgba(6, 38, 61, 0.05) 1px, transparent 1px), linear-gradient(90deg, rgba(6, 38, 61, 0.05) 1px, transparent 1px);
            background-size: 26px 26px;
            content: '';
            inset: 0;
            position: absolute;
        }

        .analytics-geo-bubble {
            align-items: center;
            background: rgba(15, 95, 122, 0.16);
            border: 5px solid rgba(15, 95, 122, 0.12);
            border-radius: 999px;
            color: #06263d;
            display: inline-flex;
            font-size: 0.78rem;
            font-weight: 800;
            justify-content: center;
            position: absolute;
            transform: translate(-50%, -50%);
            z-index: 1;
        }

        .analytics-geo-legend {
            display: grid;
            gap: 0.85rem;
        }

        .analytics-map-card {
            background: linear-gradient(145deg, #ecf7fb 0%, #f7fbfd 100%);
            border-radius: 1.5rem;
            min-height: 28rem;
            overflow: hidden;
            position: relative;
        }

        .analytics-map-card::before {
            background-image: radial-gradient(circle at 30% 20%, rgba(20, 184, 166, 0.22), transparent 24%), radial-gradient(circle at 70% 65%, rgba(14, 116, 144, 0.18), transparent 22%), linear-gradient(rgba(6, 38, 61, 0.05) 1px, transparent 1px), linear-gradient(90deg, rgba(6, 38, 61, 0.05) 1px, transparent 1px);
            background-size: auto, auto, 30px 30px, 30px 30px;
            content: '';
            inset: 0;
            position: absolute;
        }

        .analytics-map-hotspot {
            position: absolute;
            transform: translate(-50%, -50%);
            z-index: 2;
        }

        .analytics-map-hotspot-dot {
            background: rgba(15, 95, 122, 0.2);
            border: 7px solid rgba(15, 95, 122, 0.12);
            border-radius: 999px;
            box-shadow: 0 0 0 10px rgba(15, 95, 122, 0.04);
        }

        .analytics-map-hotspot-card {
            background: rgba(255, 255, 255, 0.92);
            border: 1px solid rgba(6, 38, 61, 0.08);
            border-radius: 1rem;
            box-shadow: 0 0.8rem 1.8rem rgba(6, 38, 61, 0.08);
            padding: 0.9rem;
            position: absolute;
            top: 1.45rem;
            width: 12rem;
        }

        .analytics-operational-table thead th {
            background: #eef6f8;
            color: #06263d;
            font-size: 0.78rem;
            letter-spacing: 0.04em;
            text-transform: uppercase;
        }

        .analytics-action-button {
            align-items: center;
            display: inline-flex;
            gap: 0.55rem;
            justify-content: center;
            min-height: 3rem;
        }

        .analytics-section-card a:focus-visible,
        .analytics-surface-card a:focus-visible,
        .analytics-action-button:focus-visible {
            outline: 3px solid #ffbf47;
            outline-offset: 2px;
        }

        .analytics-mini-bars {
            display: flex;
            gap: 0.35rem;
            height: 3rem;
        }

        .analytics-mini-bars span {
            background: linear-gradient(180deg, rgba(15, 95, 122, 0.28), rgba(20, 184, 166, 0.88));
            border-radius: 999px;
            flex: 1;
        }

        .analytics-tone-teal { color: #0f766e; }
        .analytics-tone-cyan { color: #0e7490; }
        .analytics-tone-amber { color: #b45309; }
        .analytics-tone-blue { color: #13678a; }
        .analytics-tone-emerald { color: #047857; }
        .analytics-tone-purple { color: #7c3aed; }
        .analytics-tone-rose { color: #e11d48; }
        .analytics-tone-slate { color: #475569; }

        .analytics-chip {
            background: rgba(15, 95, 122, 0.08);
            border-radius: 999px;
            color: #0f5f7a;
            display: inline-flex;
            font-size: 0.8rem;
            font-weight: 700;
            padding: 0.35rem 0.75rem;
        }

        @media (max-width: 991.98px) {
            .analytics-flow-grid::before {
                display: none;
            }

            .analytics-heatmap-grid {
                grid-template-columns: repeat(2, minmax(0, 1fr));
            }

            .analytics-map-hotspot-card {
                position: static;
                transform: none;
                width: 100%;
            }

            .analytics-map-hotspot {
                position: static;
                transform: none;
            }

            .analytics-map-card {
                display: grid;
                gap: 1rem;
                padding: 1rem;
            }
        }
    </style>
{% endblock %}

{% block body %}
    <section class="py-4 py-lg-5" aria-labelledby="analytics-title">
        <div class="analytics-hero p-4 p-lg-5 mb-4">
            <div class="row g-4 align-items-end">
                <div class="col-lg-8">
                    <span class="badge rounded-pill text-bg-light text-primary mb-3">{{ hero.badge }}</span>
                    <h1 id="analytics-title" class="display-6 fw-bold mb-3">{{ hero.title }}</h1>
                    <p class="lead mb-0">{{ hero.subtitle }}</p>
                </div>
                <div class="col-lg-4">
                    <div class="analytics-glass-card p-4 text-lg-end">
                        <p class="text-uppercase small fw-semibold mb-2">Precisao Analitica</p>
                        <p class="display-6 fw-bold mb-2">{{ hero.accuracy }}</p>
                        <p class="mb-0 opacity-75">{{ hero.accuracyDescription }}</p>
                    </div>
                </div>
            </div>
        </div>

        {% include 'platform/_analytics_charts.html.twig' with {chartPayloads: chartPayloads, comparativePanels: comparativePanels, comparativeInsights: comparativeInsights} only %}

        <div class="row g-4 mb-4">
            <div class="col-lg-8">
                {% include 'platform/_territorial_heatmap.html.twig' with {territorialHotspots: territorialHotspots} only %}
            </div>
            <div class="col-lg-4">
                <div class="analytics-section-card p-4 h-100">
                    <span class="badge rounded-pill text-bg-light text-primary mb-2">Painel Executivo</span>
                    <h2 class="h3 mb-3">Sinais rapidos de maturidade</h2>
                    <p class="text-secondary mb-4">Widgets de leitura imediata para disponibilidade, cobertura, integracoes e operacao analitica.</p>
                    <div class="analytics-widget-grid">
                        {% for widget in executiveWidgets %}
                            <article class="analytics-surface-card p-3 h-100">
                                <div class="d-flex justify-content-between align-items-start gap-3 mb-2">
                                    <div>
                                        <p class="text-muted text-uppercase small fw-semibold mb-1">{{ widget.title }}</p>
                                        <p class="h3 mb-0 fw-bold text-primary">{{ widget.value }}</p>
                                    </div>
                                    <i class="bi bi-{{ widget.icon }} fs-4 analytics-tone-{{ widget.tone }}"></i>
                                </div>
                            </article>
                        {% endfor %}
                    </div>
                </div>
            </div>
        </div>

        {% include 'platform/_executive_insights.html.twig' with {executiveInsights: executiveInsights} only %}
        {% include 'platform/_operational_table.html.twig' with {operationalIndicators: operationalIndicators} only %}

        <div class="analytics-section-card p-4 mb-4">
            <div class="d-flex justify-content-between align-items-start gap-3 flex-wrap mb-4">
                <div>
                    <span class="badge rounded-pill text-bg-light text-primary mb-2">Camadas Analiticas</span>
                    <h2 class="h3 mb-1">Pipeline de inteligencia para decisao publica</h2>
                    <p class="text-secondary mb-0">Fluxo visual que demonstra coleta, integracao, processamento e ativacao do conhecimento executivo no ecossistema Olinda360.</p>
                </div>
            </div>
            <div class="analytics-flow-grid">
                {% for layer in analyticalLayers %}
                    <article class="analytics-surface-card p-4 position-relative z-1">
                        <div class="d-inline-flex align-items-center justify-content-center rounded-4 bg-light text-primary fs-4 mb-3" style="width: 3rem; height: 3rem;">
                            <i class="bi bi-{{ layer.icon }}"></i>
                        </div>
                        <h3 class="h5 mb-2">{{ layer.title }}</h3>
                        <p class="text-secondary small mb-0">{{ layer.description }}</p>
                    </article>
                {% endfor %}
            </div>
        </div>

        {% include 'platform/_predictive_cards.html.twig' with {predictiveCards: predictiveCards} only %}

        <div class="analytics-section-card p-4">
            <span class="badge rounded-pill text-bg-light text-primary mb-2">Acoes Estrategicas</span>
            <h2 class="h3 mb-3">Atalhos para operacao, exportacao e decisao</h2>
            <p class="text-secondary mb-4">Entradas diretas para exportacao, relatorios, integracoes e visoes complementares da plataforma institucional.</p>
            <div class="analytics-actions-grid">
                {% for action in strategicActions %}
                    <a class="btn btn-{{ action.variant }} analytics-action-button" href="{{ path(action.route) }}">
                        <i class="bi bi-{{ action.icon }}"></i>
                        <span>{{ action.label }}</span>
                    </a>
                {% endfor %}
            </div>
        </div>
    </section>
{% endblock %}

{% block javascripts %}
    {{ parent() }}
    <script src="https://cdn.jsdelivr.net/npm/chart.js@4.4.3/dist/chart.umd.min.js"></script>
    <script>
        // Generated by GitHub Copilot
        document.addEventListener('DOMContentLoaded', function () {
            if (typeof window.Chart === 'undefined') {
                return;
            }

            const payloads = {{ chartPayloads|json_encode|raw }};
            const commonGridColor = 'rgba(6, 38, 61, 0.08)';
            const commonTickColor = '#5f7482';
            const chartOptions = {
                maintainAspectRatio: false,
                plugins: {
                    legend: {
                        display: false,
                    },
                },
                scales: {
                    x: {
                        grid: {
                            display: false,
                        },
                        ticks: {
                            color: commonTickColor,
                        },
                    },
                    y: {
                        border: {
                            display: false,
                        },
                        grid: {
                            color: commonGridColor,
                        },
                        ticks: {
                            color: commonTickColor,
                        },
                    },
                },
            };

            const tourismFlowElement = document.getElementById('analyticsTourismFlowChart');
            if (tourismFlowElement) {
                new Chart(tourismFlowElement, {
                    type: 'line',
                    data: {
                        labels: payloads.tourismFlow.labels,
                        datasets: [{
                            data: payloads.tourismFlow.values,
                            borderColor: '#0f766e',
                            backgroundColor: 'rgba(15, 118, 110, 0.16)',
                            fill: true,
                            tension: 0.35,
                            pointRadius: 4,
                            pointBackgroundColor: '#0f766e',
                        }],
                    },
                    options: chartOptions,
                });
            }

            const eventsRegionElement = document.getElementById('analyticsEventsRegionChart');
            if (eventsRegionElement) {
                new Chart(eventsRegionElement, {
                    type: 'bar',
                    data: {
                        labels: payloads.eventsByRegion.labels,
                        datasets: [{
                            data: payloads.eventsByRegion.values,
                            backgroundColor: ['#06263d', '#13678a', '#0f766e', '#14b8a6', '#7c3aed'],
                            borderRadius: 12,
                        }],
                    },
                    options: chartOptions,
                });
            }

            const visitorMotivationElement = document.getElementById('analyticsVisitorMotivationChart');
            if (visitorMotivationElement) {
                new Chart(visitorMotivationElement, {
                    type: 'doughnut',
                    data: {
                        labels: payloads.visitorMotivation.labels,
                        datasets: [{
                            data: payloads.visitorMotivation.values,
                            backgroundColor: ['#0f766e', '#13678a', '#14b8a6', '#f59e0b', '#7c3aed'],
                            borderWidth: 0,
                        }],
                    },
                    options: {
                        maintainAspectRatio: false,
                        plugins: {
                            legend: {
                                position: 'bottom',
                                labels: {
                                    color: commonTickColor,
                                    usePointStyle: true,
                                },
                            },
                        },
                    },
                });
            }

            const hotelOccupancyElement = document.getElementById('analyticsHotelOccupancyChart');
            if (hotelOccupancyElement) {
                new Chart(hotelOccupancyElement, {
                    type: 'line',
                    data: {
                        labels: payloads.hotelOccupancy.labels,
                        datasets: [{
                            data: payloads.hotelOccupancy.values,
                            borderColor: '#13678a',
                            backgroundColor: 'rgba(19, 103, 138, 0.18)',
                            fill: true,
                            tension: 0.35,
                            pointRadius: 4,
                            pointBackgroundColor: '#13678a',
                        }],
                    },
                    options: chartOptions,
                });
            }

            const economicActivityElement = document.getElementById('analyticsEconomicActivityChart');
            if (economicActivityElement) {
                new Chart(economicActivityElement, {
                    type: 'bar',
                    data: {
                        labels: payloads.economicActivity.labels,
                        datasets: [{
                            data: payloads.economicActivity.values,
                            backgroundColor: ['#0f766e', '#13678a', '#14b8a6', '#0e7490', '#7c3aed'],
                            borderRadius: 12,
                        }],
                    },
                    options: {
                        ...chartOptions,
                        indexAxis: 'y',
                    },
                });
            }

            const maturityRadarElement = document.getElementById('analyticsMaturityRadarChart');
            if (maturityRadarElement) {
                new Chart(maturityRadarElement, {
                    type: 'radar',
                    data: {
                        labels: payloads.tourismMaturity.labels,
                        datasets: [{
                            data: payloads.tourismMaturity.values,
                            borderColor: '#0f766e',
                            backgroundColor: 'rgba(15, 118, 110, 0.18)',
                            pointBackgroundColor: '#0f766e',
                            pointRadius: 4,
                        }],
                    },
                    options: {
                        maintainAspectRatio: false,
                        plugins: {
                            legend: {
                                display: false,
                            },
                        },
                        scales: {
                            r: {
                                angleLines: {
                                    color: commonGridColor,
                                },
                                grid: {
                                    color: commonGridColor,
                                },
                                pointLabels: {
                                    color: commonTickColor,
                                    font: {
                                        size: 12,
                                    },
                                },
                                ticks: {
                                    backdropColor: 'transparent',
                                    color: commonTickColor,
                                    stepSize: 20,
                                },
                                suggestedMin: 0,
                                suggestedMax: 100,
                            },
                        },
                    },
                });
            }
        });
    </script>
{% endblock %}