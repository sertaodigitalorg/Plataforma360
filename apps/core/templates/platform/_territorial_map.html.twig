{# Generated by GitHub Copilot #}
<div class="indicators-section-card p-4 h-100">
    <div class="d-flex justify-content-between align-items-start gap-3 flex-wrap mb-4">
        <div>
            <span class="badge rounded-pill text-bg-light text-primary mb-2">Mapa de Inteligência Territorial</span>
            <h2 class="h3 mb-1">Hotspots turísticos e pressão territorial</h2>
            <p class="text-secondary mb-0">Simulação visual da camada territorial com zonas críticas, intensidade de fluxo e atividade econômica associada.</p>
        </div>
    </div>
    <div class="position-relative rounded-4 overflow-hidden mb-4" style="min-height: 27rem; background: radial-gradient(circle at 30% 20%, rgba(20, 184, 166, 0.28), transparent 24%), radial-gradient(circle at 70% 55%, rgba(14, 116, 144, 0.24), transparent 22%), linear-gradient(135deg, #e8f6fb 0%, #d8eef4 48%, #effcf8 100%); border: 1px solid rgba(11, 60, 93, 0.08);">
        <div class="position-absolute top-0 start-0 w-100 h-100" style="background-image: linear-gradient(rgba(11, 60, 93, 0.05) 1px, transparent 1px), linear-gradient(90deg, rgba(11, 60, 93, 0.05) 1px, transparent 1px); background-size: 28px 28px;"></div>
        {% for zone in territorialZones %}
            <div class="position-absolute translate-middle" style="top: {{ zone.top }}; left: {{ zone.left }}; z-index: 2;">
                <div class="rounded-circle shadow" style="width: {{ 1.1 + (zone.intensity / 90) }}rem; height: {{ 1.1 + (zone.intensity / 90) }}rem; background: rgba(15, 118, 110, {{ 0.28 + (zone.intensity / 170) }}); border: 6px solid rgba(15, 118, 110, 0.12);"></div>
            </div>
            <div class="position-absolute p-3 rounded-4 shadow-sm bg-white" style="top: calc({{ zone.top }} + 1.4rem); left: calc({{ zone.left }} - 2rem); width: 13rem; z-index: 3; border: 1px solid rgba(11, 60, 93, 0.08);">
                <div class="d-flex justify-content-between align-items-start gap-2 mb-2">
                    <strong class="text-primary">{{ zone.name }}</strong>
                    <span class="indicators-status-badge indicators-status-badge--primary">{{ zone.occupancy }}</span>
                </div>
                <div class="small text-secondary d-grid gap-1">
                    <span>Fluxo turístico: {{ zone.flow }}</span>
                    <span>Eventos: {{ zone.events }}</span>
                    <span>Atividade econômica: {{ zone.economicActivity }}</span>
                </div>
            </div>
        {% endfor %}
    </div>
    <div class="row g-3">
        {% for zone in territorialZones %}
            <div class="col-md-6 col-xl-4">
                <div class="indicators-surface-card p-3 h-100">
                    <div class="d-flex justify-content-between align-items-center gap-3 mb-2">
                        <strong>{{ zone.name }}</strong>
                        <span class="small text-secondary">Intensidade {{ zone.intensity }}/100</span>
                    </div>
                    <div class="progress mb-2" style="height: 0.6rem;">
                        <div class="progress-bar bg-info" role="progressbar" style="width: {{ zone.intensity }}%;"></div>
                    </div>
                    <p class="small text-secondary mb-0">Ocupação {{ zone.occupancy }} • {{ zone.events }} eventos • {{ zone.economicActivity }}</p>
                </div>
            </div>
        {% endfor %}
    </div>
</div>