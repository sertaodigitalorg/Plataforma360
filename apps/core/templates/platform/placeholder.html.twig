{# Generated by GitHub Copilot #}
{% extends 'base.html.twig' %}

{% block title %}{{ title }} | Olinda 360{% endblock %}

{% block stylesheets %}
    <style>
        .platform-placeholder-hero {
            background: linear-gradient(135deg, #0b3c5d 0%, #13678a 52%, #eff7fb 100%);
            border-radius: 1.5rem;
            color: #fff;
            overflow: hidden;
            position: relative;
        }

        .platform-placeholder-hero::after {
            background: radial-gradient(circle at top right, rgba(255, 255, 255, 0.28), transparent 40%);
            content: '';
            inset: 0;
            position: absolute;
        }

        .platform-placeholder-hero > * {
            position: relative;
            z-index: 1;
        }

        .platform-placeholder-card {
            background: #fff;
            border: 1px solid rgba(11, 60, 93, 0.08);
            border-radius: 1.25rem;
            box-shadow: 0 1rem 2rem rgba(11, 60, 93, 0.06);
        }

        .platform-placeholder-icon {
            align-items: center;
            background: rgba(255, 255, 255, 0.14);
            border: 1px solid rgba(255, 255, 255, 0.18);
            border-radius: 1rem;
            display: inline-flex;
            font-size: 1.5rem;
            height: 3.5rem;
            justify-content: center;
            width: 3.5rem;
        }
    </style>
{% endblock %}

{% block body %}
    <section class="py-4 py-lg-5">
        <div class="platform-placeholder-hero p-4 p-lg-5 mb-4">
            <div class="row align-items-center g-4">
                <div class="col-lg-8">
                    <span class="badge rounded-pill text-bg-light text-primary mb-3">{{ section }}</span>
                    <h1 class="display-6 fw-bold mb-3">{{ title }}</h1>
                    <p class="lead mb-0">{{ description }}</p>
                </div>
                <div class="col-lg-4 text-lg-end">
                    <span class="platform-placeholder-icon"><i class="bi bi-{{ icon }}"></i></span>
                </div>
            </div>
        </div>

        <div class="row g-4">
            <div class="col-lg-8">
                <div class="platform-placeholder-card p-4 h-100">
                    <span class="badge text-bg-{{ badgeTone }} mb-3">{{ badge }}</span>
                    <h2 class="h4 mb-3">Capacidade em planejamento institucional</h2>
                    <p class="text-secondary mb-0">Esta seção já faz parte da arquitetura de navegação do Olinda360 para sustentar crescimento futuro com menor poluição visual. O espaço foi reservado para evolução progressiva da plataforma, preservando hierarquia, consistência e experiência de console govtech.</p>
                </div>
            </div>
            <div class="col-lg-4">
                <div class="platform-placeholder-card p-4 h-100">
                    <h2 class="h5 mb-3">Próximo estágio</h2>
                    <p class="text-secondary mb-0">Quando esta capacidade for implementada, a rota e o slot visual já estarão integrados à navegação principal sem exigir nova reestruturação global da navbar.</p>
                </div>
            </div>
        </div>
    </section>
{% endblock %}