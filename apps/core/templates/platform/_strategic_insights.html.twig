{# Generated by GitHub Copilot #}
<div class="indicators-section-card p-4 mb-4">
    <div class="d-flex justify-content-between align-items-start gap-3 flex-wrap mb-4">
        <div>
            <span class="badge rounded-pill text-bg-light text-primary mb-2">Insights Estratégicos</span>
            <h2 class="h3 mb-1">Leituras executivas assistidas por inteligência analítica</h2>
            <p class="text-secondary mb-0">Cartões institucionais no estilo AI-like para apoiar priorização, narrativa executiva e apresentações estratégicas.</p>
        </div>
    </div>
    <div class="indicators-insights-grid">
        {% for insight in strategicInsights %}
            <article class="indicators-surface-card p-4 h-100">
                <div class="d-flex justify-content-between align-items-start gap-3 mb-3">
                    <div class="d-inline-flex align-items-center justify-content-center rounded-4 bg-light text-primary fs-4" style="width: 3rem; height: 3rem;">
                        <i class="bi bi-{{ insight.icon }}"></i>
                    </div>
                    <span class="badge text-bg-{{ insight.badgeTone }}">{{ insight.badge }}</span>
                </div>
                <h3 class="h5 mb-2">{{ insight.title }}</h3>
                <p class="text-secondary mb-0">{{ insight.description }}</p>
            </article>
        {% endfor %}
    </div>
</div>