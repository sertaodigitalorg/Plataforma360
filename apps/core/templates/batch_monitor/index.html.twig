{# Generated by GitHub Copilot #}
{% extends 'base.html.twig' %}

{% block title %}Monitoramento Batch | Olinda 360{% endblock %}

{% block stylesheets %}
    <style>
        .batch-hero {
            background: linear-gradient(135deg, #0b3c5d 0%, #13678a 48%, #f2f7fb 100%);
            border-radius: 1.5rem;
            color: #fff;
            overflow: hidden;
            position: relative;
        }

        .batch-hero::after {
            background: radial-gradient(circle at top right, rgba(255, 255, 255, 0.28), transparent 45%);
            content: '';
            inset: 0;
            position: absolute;
        }

        .batch-hero__content,
        .batch-card,
        .batch-table-card {
            position: relative;
            z-index: 1;
        }

        .batch-summary-card {
            background: #fff;
            border: 1px solid rgba(11, 60, 93, 0.08);
            border-radius: 1.25rem;
            box-shadow: 0 1rem 2rem rgba(11, 60, 93, 0.08);
        }

        .batch-summary-card__value {
            color: #0b3c5d;
            font-size: clamp(1.75rem, 3vw, 2.5rem);
            font-weight: 700;
        }

        .batch-status {
            align-items: center;
            border-radius: 999px;
            display: inline-flex;
            font-size: 0.875rem;
            font-weight: 600;
            gap: 0.5rem;
            padding: 0.375rem 0.75rem;
        }

        .batch-status__dot {
            border-radius: 50%;
            display: inline-block;
            height: 0.625rem;
            width: 0.625rem;
        }

        .batch-status__dot--pulse {
            animation: batch-pulse 1.6s infinite;
        }

        .batch-status--success {
            background: rgba(25, 135, 84, 0.12);
            color: #146c43;
        }

        .batch-status--success .batch-status__dot {
            background: #198754;
        }

        .batch-status--running {
            background: rgba(13, 110, 253, 0.12);
            color: #0a58ca;
        }

        .batch-status--running .batch-status__dot {
            background: #0d6efd;
        }

        .batch-status--warning {
            background: rgba(255, 193, 7, 0.18);
            color: #997404;
        }

        .batch-status--warning .batch-status__dot {
            background: #ffc107;
        }

        .batch-status--failed {
            background: rgba(220, 53, 69, 0.12);
            color: #b02a37;
        }

        .batch-status--failed .batch-status__dot {
            background: #dc3545;
        }

        .batch-status--pending {
            background: rgba(108, 117, 125, 0.14);
            color: #495057;
        }

        .batch-status--pending .batch-status__dot {
            background: #6c757d;
        }

        .batch-status--disabled {
            background: rgba(33, 37, 41, 0.12);
            color: #212529;
        }

        .batch-status--disabled .batch-status__dot {
            background: #212529;
        }

        .batch-table-card {
            background: #fff;
            border: 1px solid rgba(11, 60, 93, 0.08);
            border-radius: 1.5rem;
            box-shadow: 0 1.25rem 2rem rgba(11, 60, 93, 0.06);
        }

        .batch-table thead th {
            background: #eef5f8;
            border-bottom-width: 1px;
            color: #35566d;
            font-size: 0.82rem;
            letter-spacing: 0.03em;
            text-transform: uppercase;
            white-space: nowrap;
        }

        .batch-table tbody tr:hover {
            background: rgba(19, 103, 138, 0.04);
        }

        .batch-actions {
            display: flex;
            flex-wrap: wrap;
            gap: 0.5rem;
        }

        .batch-pill {
            background: #eaf3f8;
            border-radius: 999px;
            color: #35566d;
            display: inline-block;
            font-size: 0.8rem;
            font-weight: 600;
            padding: 0.3rem 0.7rem;
        }

        .batch-table a:focus-visible,
        .batch-hero a:focus-visible {
            outline: 3px solid #ffbf47;
            outline-offset: 2px;
        }

        @keyframes batch-pulse {
            0% { box-shadow: 0 0 0 0 rgba(13, 110, 253, 0.45); }
            70% { box-shadow: 0 0 0 10px rgba(13, 110, 253, 0); }
            100% { box-shadow: 0 0 0 0 rgba(13, 110, 253, 0); }
        }
    </style>
{% endblock %}

{% block body %}
    <section class="py-4 py-lg-5" aria-labelledby="batch-monitor-title">
        <div class="batch-hero p-4 p-lg-5 mb-4">
            <div class="batch-hero__content row g-4 align-items-end">
                <div class="col-lg-8">
                    <span class="badge rounded-pill text-bg-light text-primary mb-3">Observabilidade de Dados</span>
                    <h1 id="batch-monitor-title" class="display-6 fw-bold mb-3">Monitoramento Batch</h1>
                    <p class="lead mb-0">Acompanhamento das rotinas automatizadas de coleta de dados turísticos do Olinda 360.</p>
                </div>
                <div class="col-lg-4">
                    <div class="batch-card bg-white bg-opacity-10 border border-white border-opacity-25 rounded-4 p-4">
                        <p class="text-uppercase small fw-semibold mb-2">Indicador operacional</p>
                        <p class="fs-2 fw-bold mb-1">{{ summary.averageExecutionTime|number_format(1, ',', '.') }}s</p>
                        <p class="mb-0 text-white-50">Tempo médio das últimas execuções registradas.</p>
                    </div>
                </div>
            </div>
        </div>

        <div class="row g-3 mb-4" aria-label="Resumo operacional das rotinas batch">
            <div class="col-12 col-md-6 col-xl-2">
                <article class="batch-summary-card h-100 p-4">
                    <p class="text-muted text-uppercase small fw-semibold mb-2">Total de Rotinas</p>
                    <p class="batch-summary-card__value mb-1">{{ summary.total }}</p>
                    <p class="mb-0 text-secondary small">Cobertura atual do monitoramento.</p>
                </article>
            </div>
            <div class="col-12 col-md-6 col-xl-2">
                <article class="batch-summary-card h-100 p-4">
                    <p class="text-muted text-uppercase small fw-semibold mb-2">Executadas com Sucesso</p>
                    <p class="batch-summary-card__value mb-1">{{ summary.success }}</p>
                    <p class="mb-0 text-secondary small">Fluxos concluídos sem intervenção.</p>
                </article>
            </div>
            <div class="col-12 col-md-6 col-xl-2">
                <article class="batch-summary-card h-100 p-4">
                    <p class="text-muted text-uppercase small fw-semibold mb-2">Em Execução</p>
                    <p class="batch-summary-card__value mb-1">{{ summary.running }}</p>
                    <p class="mb-0 text-secondary small">Rotinas ativas na janela noturna.</p>
                </article>
            </div>
            <div class="col-12 col-md-6 col-xl-2">
                <article class="batch-summary-card h-100 p-4">
                    <p class="text-muted text-uppercase small fw-semibold mb-2">Com Alertas</p>
                    <p class="batch-summary-card__value mb-1">{{ summary.warning }}</p>
                    <p class="mb-0 text-secondary small">Execuções que exigem revisão de dados.</p>
                </article>
            </div>
            <div class="col-12 col-md-6 col-xl-2">
                <article class="batch-summary-card h-100 p-4">
                    <p class="text-muted text-uppercase small fw-semibold mb-2">Com Falha</p>
                    <p class="batch-summary-card__value mb-1">{{ summary.failed }}</p>
                    <p class="mb-0 text-secondary small">Ocorrências que pedem investigação imediata.</p>
                </article>
            </div>
            <div class="col-12 col-md-6 col-xl-2">
                <article class="batch-summary-card h-100 p-4">
                    <p class="text-muted text-uppercase small fw-semibold mb-2">Registros Processados</p>
                    <p class="batch-summary-card__value mb-1">{{ summary.processed }}</p>
                    <p class="mb-0 text-secondary small">Volume consolidado nas últimas execuções.</p>
                </article>
            </div>
        </div>

        <div class="batch-table-card p-3 p-lg-4">
            <div class="d-flex justify-content-between align-items-start gap-3 flex-wrap mb-3">
                <div>
                    <h2 class="h4 mb-1">Painel de rotinas automatizadas</h2>
                    <p class="text-secondary mb-0">Governança operacional, rastreabilidade de coletas e prontidão para integrações futuras com comandos Symfony e cron.</p>
                </div>
                <div class="d-flex gap-2 flex-wrap">
                    <a class="btn btn-primary" href="{{ path('app_batch_monitor_export_csv') }}">Exportar CSV</a>
                    <a class="btn btn-outline-secondary" href="{{ path('dashboard') }}">Voltar ao Dashboard</a>
                </div>
            </div>

            <div class="table-responsive">
                <table class="table align-middle batch-table mb-0">
                    <thead>
                        <tr>
                            <th scope="col">Status</th>
                            <th scope="col">Rotina</th>
                            <th scope="col">Fonte</th>
                            <th scope="col">Tipo</th>
                            <th scope="col">Agendamento</th>
                            <th scope="col">Ultima execucao</th>
                            <th scope="col">Proxima execucao</th>
                            <th scope="col">Processados</th>
                            <th scope="col">Criados</th>
                            <th scope="col">Atualizados</th>
                            <th scope="col">Erros</th>
                            <th scope="col">Tempo</th>
                            <th scope="col">Acoes</th>
                        </tr>
                    </thead>
                    <tbody>
                        {% for routine in routines %}
                            <tr id="routine-{{ routine.id }}">
                                <td>{% include 'batch_monitor/_status_badge.html.twig' with {status: routine.status, statusPresentation: statusPresentation} only %}</td>
                                <td>
                                    <div class="fw-semibold">{{ routine.name }}</div>
                                    <div class="text-secondary small">{{ routine.description|default('Rotina pronta para futura integracao.') }}</div>
                                </td>
                                <td>
                                    <div>{{ routine.sourceName }}</div>
                                    {% if routine.apiUrl %}
                                        <a class="small" href="{{ routine.apiUrl }}" rel="noopener noreferrer" target="_blank">{{ routine.apiUrl }}</a>
                                    {% endif %}
                                </td>
                                <td><span class="batch-pill">{{ routine.sourceType }}</span></td>
                                <td>
                                    <div class="fw-semibold">{{ routine.cronExpression ?: 'Nao configurado' }}</div>
                                    <div class="text-secondary small">{{ routine.scheduledTime ?: 'Sem horario definido' }}</div>
                                </td>
                                <td>{{ routine.lastExecutionAt ? routine.lastExecutionAt|format_datetime('medium', 'short', locale='pt_BR') : 'Nao executado' }}</td>
                                <td>{{ routine.nextExecutionAt ? routine.nextExecutionAt|format_datetime('medium', 'short', locale='pt_BR') : 'Nao agendado' }}</td>
                                <td>{{ routine.recordsProcessed }}</td>
                                <td>{{ routine.recordsCreated }}</td>
                                <td>{{ routine.recordsUpdated }}</td>
                                <td>{{ routine.recordsFailed }}</td>
                                <td>{{ routine.executionTimeSeconds is not null ? routine.executionTimeSeconds|number_format(1, ',', '.') ~ ' s' : 'Em andamento' }}</td>
                                <td>
                                    <div class="batch-actions">
                                        <a class="btn btn-sm btn-outline-primary" href="{{ path('app_batch_monitor_show', {id: routine.id}) }}">Ver detalhes</a>
                                        <a class="btn btn-sm btn-outline-success" href="{{ path('app_batch_monitor_export_csv') ~ '?routine=' ~ routine.id }}">Exportar CSV</a>
                                        <button class="btn btn-sm btn-outline-secondary" type="button" disabled>Futuro: Executar agora</button>
                                        <button class="btn btn-sm btn-outline-secondary" type="button" disabled>Futuro: Editar cron</button>
                                    </div>
                                </td>
                            </tr>
                        {% else %}
                            <tr>
                                <td colspan="13" class="text-center py-5 text-secondary">Nenhuma rotina batch cadastrada ainda.</td>
                            </tr>
                        {% endfor %}
                    </tbody>
                </table>
            </div>
        </div>
    </section>
{% endblock %}