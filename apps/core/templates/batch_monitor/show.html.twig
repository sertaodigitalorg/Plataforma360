{# Generated by GitHub Copilot #}
{% extends 'base.html.twig' %}

{% block title %}{{ routine.name }} | Monitoramento Batch{% endblock %}

{% block stylesheets %}
    <style>
        .batch-detail-hero {
            background: linear-gradient(140deg, #0b3c5d 0%, #1b6b7e 52%, #f1f5f8 100%);
            border-radius: 1.5rem;
            color: #fff;
        }

        .batch-panel,
        .batch-metric {
            background: #fff;
            border: 1px solid rgba(11, 60, 93, 0.08);
            border-radius: 1.25rem;
            box-shadow: 0 1rem 2rem rgba(11, 60, 93, 0.06);
        }

        .batch-status {
            align-items: center;
            border-radius: 999px;
            display: inline-flex;
            font-size: 0.875rem;
            font-weight: 600;
            gap: 0.5rem;
            padding: 0.375rem 0.75rem;
        }

        .batch-status__dot {
            border-radius: 50%;
            display: inline-block;
            height: 0.625rem;
            width: 0.625rem;
        }

        .batch-status__dot--pulse {
            animation: batch-pulse 1.6s infinite;
        }

        .batch-status--success { background: rgba(25, 135, 84, 0.12); color: #146c43; }
        .batch-status--success .batch-status__dot { background: #198754; }
        .batch-status--running { background: rgba(13, 110, 253, 0.12); color: #0a58ca; }
        .batch-status--running .batch-status__dot { background: #0d6efd; }
        .batch-status--warning { background: rgba(255, 193, 7, 0.18); color: #997404; }
        .batch-status--warning .batch-status__dot { background: #ffc107; }
        .batch-status--failed { background: rgba(220, 53, 69, 0.12); color: #b02a37; }
        .batch-status--failed .batch-status__dot { background: #dc3545; }
        .batch-status--pending { background: rgba(108, 117, 125, 0.14); color: #495057; }
        .batch-status--pending .batch-status__dot { background: #6c757d; }
        .batch-status--disabled { background: rgba(33, 37, 41, 0.12); color: #212529; }
        .batch-status--disabled .batch-status__dot { background: #212529; }

        .batch-definition-list dt {
            color: #5b6f7d;
            font-size: 0.8rem;
            letter-spacing: 0.04em;
            margin-bottom: 0.4rem;
            text-transform: uppercase;
        }

        .batch-definition-list dd {
            margin-bottom: 1.25rem;
        }

        @keyframes batch-pulse {
            0% { box-shadow: 0 0 0 0 rgba(13, 110, 253, 0.45); }
            70% { box-shadow: 0 0 0 10px rgba(13, 110, 253, 0); }
            100% { box-shadow: 0 0 0 0 rgba(13, 110, 253, 0); }
        }
    </style>
{% endblock %}

{% block body %}
    <section class="py-4 py-lg-5" aria-labelledby="batch-routine-title">
        <div class="batch-detail-hero p-4 p-lg-5 mb-4">
            <div class="d-flex justify-content-between align-items-start gap-3 flex-wrap">
                <div>
                    <p class="text-uppercase small fw-semibold mb-2">Rotina monitorada</p>
                    <h1 id="batch-routine-title" class="display-6 fw-bold mb-3">{{ routine.name }}</h1>
                    <p class="lead mb-3">{{ routine.description ?: 'Estrutura de monitoramento preparada para futura integracao com coleta real.' }}</p>
                    {% include 'batch_monitor/_status_badge.html.twig' with {status: routine.status, statusPresentation: statusPresentation} only %}
                </div>
                <div class="d-flex flex-wrap gap-2">
                    <a class="btn btn-light" href="{{ path('app_batch_monitor_export_csv') ~ '?routine=' ~ routine.id }}">Exportar CSV</a>
                    <a class="btn btn-outline-light" href="{{ path('app_batch_monitor') }}">Voltar</a>
                </div>
            </div>
        </div>

        <div class="row g-3 mb-4" aria-label="Metricas da rotina batch">
            <div class="col-12 col-md-6 col-xl-3">
                <article class="batch-metric h-100 p-4">
                    <p class="text-muted text-uppercase small fw-semibold mb-2">Processados</p>
                    <p class="display-6 fw-bold mb-0">{{ routine.recordsProcessed }}</p>
                </article>
            </div>
            <div class="col-12 col-md-6 col-xl-3">
                <article class="batch-metric h-100 p-4">
                    <p class="text-muted text-uppercase small fw-semibold mb-2">Criados</p>
                    <p class="display-6 fw-bold mb-0">{{ routine.recordsCreated }}</p>
                </article>
            </div>
            <div class="col-12 col-md-6 col-xl-3">
                <article class="batch-metric h-100 p-4">
                    <p class="text-muted text-uppercase small fw-semibold mb-2">Atualizados</p>
                    <p class="display-6 fw-bold mb-0">{{ routine.recordsUpdated }}</p>
                </article>
            </div>
            <div class="col-12 col-md-6 col-xl-3">
                <article class="batch-metric h-100 p-4">
                    <p class="text-muted text-uppercase small fw-semibold mb-2">Erros</p>
                    <p class="display-6 fw-bold mb-0">{{ routine.recordsFailed }}</p>
                </article>
            </div>
        </div>

        <div class="row g-4">
            <div class="col-lg-8">
                <div class="batch-panel p-4 h-100">
                    <h2 class="h4 mb-4">Detalhes operacionais</h2>
                    <dl class="row batch-definition-list mb-0">
                        <dt class="col-sm-4">Fonte</dt>
                        <dd class="col-sm-8">{{ routine.sourceName }}</dd>

                        <dt class="col-sm-4">Tipo</dt>
                        <dd class="col-sm-8">{{ routine.sourceType }}</dd>

                        <dt class="col-sm-4">URL da API</dt>
                        <dd class="col-sm-8">
                            {% if routine.apiUrl %}
                                <a href="{{ routine.apiUrl }}" rel="noopener noreferrer" target="_blank">{{ routine.apiUrl }}</a>
                            {% else %}
                                Nao informada
                            {% endif %}
                        </dd>

                        <dt class="col-sm-4">Expressao cron</dt>
                        <dd class="col-sm-8">{{ routine.cronExpression ?: 'Nao configurada' }}</dd>

                        <dt class="col-sm-4">Horario agendado</dt>
                        <dd class="col-sm-8">{{ routine.scheduledTime ?: 'Nao definido' }}</dd>

                        <dt class="col-sm-4">Ultima execucao</dt>
                        <dd class="col-sm-8">{{ routine.lastExecutionAt ? routine.lastExecutionAt|format_datetime('full', 'short', locale='pt_BR') : 'Nao executada' }}</dd>

                        <dt class="col-sm-4">Proxima execucao</dt>
                        <dd class="col-sm-8">{{ routine.nextExecutionAt ? routine.nextExecutionAt|format_datetime('full', 'short', locale='pt_BR') : 'Nao agendada' }}</dd>

                        <dt class="col-sm-4">Tempo de execucao</dt>
                        <dd class="col-sm-8">{{ routine.executionTimeSeconds is not null ? routine.executionTimeSeconds|number_format(1, ',', '.') ~ ' segundos' : 'Ainda nao concluido' }}</dd>

                        <dt class="col-sm-4">Ativa</dt>
                        <dd class="col-sm-8">{{ routine.active ? 'Sim' : 'Nao' }}</dd>

                        <dt class="col-sm-4">Ultima mensagem</dt>
                        <dd class="col-sm-8">{{ routine.lastMessage ?: 'Nenhuma mensagem registrada.' }}</dd>
                    </dl>
                </div>
            </div>
            <div class="col-lg-4">
                <div class="batch-panel p-4 mb-4">
                    <h2 class="h5 mb-3">Observabilidade</h2>
                    <p class="text-secondary mb-3">Esta tela representa a estrutura de monitoramento das futuras rotinas automatizadas de coleta de dados. A execucao real sera implementada posteriormente com Symfony Console Commands e cron.</p>
                    <ul class="list-unstyled mb-0 text-secondary">
                        <li class="mb-2">Slug tecnico: <strong>{{ routine.slug }}</strong></li>
                        <li class="mb-2">Criada em: <strong>{{ routine.createdAt|format_datetime('medium', 'short', locale='pt_BR') }}</strong></li>
                        <li>Ultima atualizacao: <strong>{{ routine.updatedAt ? routine.updatedAt|format_datetime('medium', 'short', locale='pt_BR') : 'Sem alteracoes posteriores' }}</strong></li>
                    </ul>
                </div>
                <div class="batch-panel p-4">
                    <h2 class="h5 mb-3">Proximos passos</h2>
                    <p class="text-secondary mb-0">A proxima etapa natural e conectar cada rotina a comandos Symfony dedicados, persistindo resultados, mensagens de erro, telemetria de execucao e agendamento cron em ambiente operacional.</p>
                </div>
            </div>
        </div>
    </section>
{% endblock %}